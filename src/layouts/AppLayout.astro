---
import "@/styles/global.css";

interface Props {
  title?: string;
}

const { title = "Bodega" } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;

const nav = [
  {
    href: "/dashboard",
    label: "Dashboard",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><rect x="3" y="3" width="7" height="9" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="14" y="3" width="7" height="5" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="14" y="12" width="7" height="9" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="16" width="7" height="5" rx="1" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/products",
    label: "Productos",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 3H8L6 7h12l-2-4z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/customers",
    label: "Clientes",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke-linecap="round" stroke-linejoin="round"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/sale-orders",
    label: "Pedidos de Venta",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke-linecap="round" stroke-linejoin="round"/><rect x="9" y="3" width="6" height="4" rx="1" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 12h6M9 16h4" stroke-linecap="round"/></svg>`,
  },
  {
    href: "/production-orders",
    label: "Producción",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><path d="M12 2L2 7l10 5 10-5-10-5z" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 17l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/production-orders/calendar",
    label: "Calendario",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><rect x="3" y="4" width="18" height="18" rx="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 2v4M8 2v4M3 10h18" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/dry-supplies",
    label: "Insumos",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><rect x="3" y="3" width="7" height="7" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="14" y="3" width="7" height="7" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="14" width="7" height="7" rx="1" stroke-linecap="round" stroke-linejoin="round"/><rect x="14" y="14" width="7" height="7" rx="1" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/audit",
    label: "Trazabilidad",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 5a2 2 0 012-2h2a2 2 0 012 2M9 5h6" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 14l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/reports",
    label: "Informes",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/inventory/predictions",
    label: "Predicciones",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/maps",
    label: "Mapas",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    href: "/chat",
    label: "Asistente IA",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 12h8M12 8v8" stroke-linecap="round"/></svg>`,
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Bodega</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="h-screen overflow-hidden bg-background text-foreground antialiased">
    <div class="flex h-full">

      <!-- ── Sidebar ────────────────────────────────────── -->
      <aside class="w-55 shrink-0 border-r border-sidebar-border bg-sidebar text-sidebar-foreground flex flex-col h-full overflow-y-auto">

        <!-- Logo -->
        <a href="/dashboard" class="flex items-center gap-3 px-5 py-5 border-b border-sidebar-border hover:bg-sidebar-accent/40 transition-colors">
          <div class="size-8 rounded-md bg-sidebar-primary flex items-center justify-center shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4 text-sidebar-primary-foreground">
              <path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold leading-none font-display tracking-wide">Bodega</p>
            <p class="text-[10px] text-sidebar-foreground/50 mt-0.5">Gestión</p>
          </div>
        </a>

        <!-- Nav -->
        <nav class="flex-1 p-3 space-y-0.5">
          {nav.map((link) => {
            const active = pathname.startsWith(link.href);
            return (
              <a
                href={link.href}
                class:list={[
                  "flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] transition-colors",
                  active
                    ? "bg-sidebar-accent text-sidebar-accent-foreground font-semibold"
                    : "text-sidebar-foreground/60 hover:bg-sidebar-accent/40 hover:text-sidebar-foreground",
                ]}
              >
                <Fragment set:html={link.icon} />
                {link.label}
              </a>
            );
          })}
        </nav>

        <!-- Footer -->
        <div class="px-4 py-4 border-t border-sidebar-border space-y-2">
          <form method="POST" action="/api/auth/logout">
            <button
              type="submit"
              class="w-full flex items-center gap-2 px-3 py-2 rounded-md text-[13px] text-sidebar-foreground/60 hover:bg-sidebar-accent/40 hover:text-sidebar-foreground transition-colors"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4 shrink-0">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="16 17 21 12 16 7" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="21" y1="12" x2="9" y2="12" stroke-linecap="round"/>
              </svg>
              Cerrar sesión
            </button>
          </form>
          <p class="text-[11px] text-sidebar-foreground/40 px-3">v0.1.0 · SSR + gRPC</p>
        </div>
      </aside>

      <!-- ── Content ─────────────────────────────────────── -->
      <main class="flex-1 min-w-0 overflow-auto">
        <slot />
      </main>

    </div>

    <!-- ── Chat Global ────────────────────────────────────── -->

    <!-- Botón flotante -->
    <button
      id="global-chat-btn"
      aria-label="Abrir asistente IA"
      class="fixed bottom-6 right-6 z-40 size-13 rounded-full bg-primary text-primary-foreground shadow-lg flex items-center justify-center hover:bg-primary/90 active:scale-95 transition-all"
    >
      <svg id="chat-icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-5">
        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <svg id="chat-icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-5 hidden">
        <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Drawer -->
    <div
      id="global-chat-drawer"
      class="fixed bottom-22 right-6 z-40 hidden w-96 flex-col rounded-2xl border border-border bg-card shadow-xl overflow-hidden"
      style="height: 560px;"
    >
      <!-- Header -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-border bg-sidebar shrink-0">
        <div class="size-7 rounded-full bg-primary/20 flex items-center justify-center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4 text-primary">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-sidebar-foreground leading-none">Asistente Ricitelli</p>
          <p class="text-[11px] text-sidebar-foreground/50 mt-0.5" id="chat-status-label">listo</p>
        </div>
        <button id="chat-clear-btn" title="Nueva conversación" class="text-sidebar-foreground/40 hover:text-sidebar-foreground transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4">
            <path d="M3 12a9 9 0 1018 0 9 9 0 00-18 0M12 8v4M12 16h.01" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- Messages -->
      <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3 text-sm"></div>

      <!-- Sugerencias rápidas (visibles solo al inicio) -->
      <div id="chat-suggestions" class="px-4 pb-3 flex flex-wrap gap-1.5">
        {[
          "Cargar un pedido",
          "Ver stock bajo",
          "Crear un producto",
          "Resumen del sistema",
        ].map((s) => (
          <button
            class="chat-suggestion text-[11px] px-2.5 py-1 rounded-full border border-border hover:bg-secondary/60 transition-colors text-muted-foreground"
            data-text={s}
          >{s}</button>
        ))}
      </div>

      <!-- Input -->
      <div class="px-3 pb-3 shrink-0">
        <div class="flex items-end gap-2 rounded-xl border border-input bg-background px-3 py-2 focus-within:ring-2 focus-within:ring-ring">
          <textarea
            id="chat-input"
            rows="1"
            placeholder="Escribí tu consulta…"
            class="flex-1 resize-none bg-transparent text-sm outline-none placeholder:text-muted-foreground max-h-28 leading-snug"
          ></textarea>
          <button
            id="chat-send-btn"
            class="size-7 rounded-lg bg-primary text-primary-foreground flex items-center justify-center hover:bg-primary/90 transition-colors shrink-0 disabled:opacity-40"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
              <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

  </body>
</html>

<script is:inline>
(function () {
  const btn      = document.getElementById("global-chat-btn");
  const drawer   = document.getElementById("global-chat-drawer");
  const messages = document.getElementById("chat-messages");
  const input    = document.getElementById("chat-input");
  const sendBtn  = document.getElementById("chat-send-btn");
  const statusEl = document.getElementById("chat-status-label");
  const clearBtn = document.getElementById("chat-clear-btn");
  const suggestionsEl = document.getElementById("chat-suggestions");
  const iconOpen  = document.getElementById("chat-icon-open");
  const iconClose = document.getElementById("chat-icon-close");

  let history = [];
  let busy = false;
  let open = false;

  // ── Toggle drawer ──────────────────────────────────────────────────────────
  function toggleDrawer() {
    open = !open;
    drawer.classList.toggle("hidden", !open);
    drawer.classList.toggle("flex", open);
    iconOpen.classList.toggle("hidden", open);
    iconClose.classList.toggle("hidden", !open);
    if (open) { input.focus(); scrollBottom(); }
  }
  btn.addEventListener("click", toggleDrawer);

  // ── Sugerencias ────────────────────────────────────────────────────────────
  document.querySelectorAll(".chat-suggestion").forEach((s) => {
    s.addEventListener("click", () => {
      input.value = s.dataset.text;
      send();
    });
  });

  // ── Clear ──────────────────────────────────────────────────────────────────
  clearBtn.addEventListener("click", () => {
    history = [];
    messages.innerHTML = "";
    suggestionsEl.classList.remove("hidden");
    statusEl.textContent = "listo";
  });

  // ── Input auto-resize + Enter ──────────────────────────────────────────────
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); send(); }
  });
  input.addEventListener("input", () => {
    input.style.height = "auto";
    input.style.height = Math.min(input.scrollHeight, 112) + "px";
  });
  sendBtn.addEventListener("click", send);

  function scrollBottom() {
    setTimeout(() => { messages.scrollTop = messages.scrollHeight; }, 30);
  }

  // ── Render helpers ─────────────────────────────────────────────────────────
  function bubble(role, text) {
    const wrap = document.createElement("div");
    wrap.className = (role === "user" ? "flex justify-end" : "flex justify-start") + " msg-wrap";
    const el = document.createElement("div");
    el.className = role === "user"
      ? "max-w-[80%] rounded-2xl rounded-tr-sm bg-primary text-primary-foreground px-3.5 py-2.5 text-[13px] leading-relaxed whitespace-pre-wrap"
      : "max-w-[90%] rounded-2xl rounded-tl-sm bg-secondary text-foreground px-3.5 py-2.5 text-[13px] leading-relaxed";
    el.textContent = text;
    wrap.appendChild(el);
    messages.appendChild(wrap);
    scrollBottom();
    return el;
  }

  function toolChip(name, done) {
    const el = document.createElement("div");
    el.className = "flex items-center gap-1.5 text-[11px] text-muted-foreground";
    el.innerHTML = done
      ? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3 text-green-600"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg>${name}`
      : `<span class="size-3 rounded-full border-2 border-primary border-t-transparent animate-spin inline-block"></span>${name}…`;
    messages.appendChild(el);
    scrollBottom();
    return el;
  }

  // ── Formulario inline ─────────────────────────────────────────────────────
  function renderForm(spec) {
    const wrap = document.createElement("div");
    wrap.className = "rounded-xl border border-border bg-background p-4 space-y-3 text-[13px]";

    const title = document.createElement("p");
    title.className = "font-semibold text-foreground text-sm";
    title.textContent = spec.title;
    wrap.appendChild(title);

    const fieldEls = {};

    for (const f of spec.fields) {
      const group = document.createElement("div");
      group.className = "space-y-1";

      const lbl = document.createElement("label");
      lbl.className = "text-[11px] font-medium text-muted-foreground uppercase tracking-wide";
      lbl.textContent = f.label + (f.required ? " *" : "");
      group.appendChild(lbl);

      let el;
      if (f.type === "select") {
        el = document.createElement("select");
        el.className = "w-full rounded-lg border border-input bg-card px-3 py-2 text-[13px] focus:outline-none focus:ring-2 focus:ring-ring";
        (f.options ?? []).forEach((opt) => {
          const o = document.createElement("option");
          o.value = opt; o.textContent = opt;
          if (f.default === opt) o.selected = true;
          el.appendChild(o);
        });
      } else if (f.type === "textarea") {
        el = document.createElement("textarea");
        el.rows = 2;
        el.className = "w-full rounded-lg border border-input bg-card px-3 py-2 text-[13px] resize-none focus:outline-none focus:ring-2 focus:ring-ring";
        el.placeholder = f.placeholder ?? "";
        // Don't pre-fill text areas from LLM defaults — could confuse users
      } else {
        el = document.createElement("input");
        el.type = f.type === "number" ? "number" : "text";
        el.className = "w-full rounded-lg border border-input bg-card px-3 py-2 text-[13px] focus:outline-none focus:ring-2 focus:ring-ring";
        el.placeholder = f.placeholder ?? "";
        // Don't pre-fill from LLM defaults — placeholder is enough hint
        if (f.required) el.required = true;
      }

      fieldEls[f.name] = el;
      group.appendChild(el);
      wrap.appendChild(group);
    }

    // Botones
    const actions = document.createElement("div");
    actions.className = "flex gap-2 pt-1";

    const submitBtn = document.createElement("button");
    submitBtn.type = "button";
    submitBtn.className = "flex-1 rounded-lg bg-primary text-primary-foreground px-3 py-2 text-[13px] font-medium hover:bg-primary/90 transition-colors";
    submitBtn.textContent = spec.submit_label ?? "Confirmar";

    const cancelBtn = document.createElement("button");
    cancelBtn.type = "button";
    cancelBtn.className = "rounded-lg border border-input bg-background px-3 py-2 text-[13px] text-muted-foreground hover:bg-secondary/60 transition-colors";
    cancelBtn.textContent = "Cancelar";

    actions.appendChild(submitBtn);
    actions.appendChild(cancelBtn);
    wrap.appendChild(actions);
    messages.appendChild(wrap);
    scrollBottom();

    // Focus primer campo
    const first = Object.values(fieldEls)[0];
    if (first) setTimeout(() => first.focus(), 50);

    cancelBtn.addEventListener("click", () => {
      wrap.remove();
      statusEl.textContent = "listo";
    });

    submitBtn.addEventListener("click", () => {
      if (submitBtn.disabled) return;
      // Validar requeridos
      for (const f of spec.fields) {
        if (f.required && !fieldEls[f.name].value.trim()) {
          fieldEls[f.name].classList.add("border-destructive");
          fieldEls[f.name].focus();
          return;
        }
        fieldEls[f.name].classList.remove("border-destructive");
      }
      submitBtn.disabled = true;
      // Construir resumen legible para el usuario
      const vals = {};
      for (const f of spec.fields) { vals[f.name] = fieldEls[f.name].value; }
      const summary = spec.fields
        .map((f) => `${f.label}: ${vals[f.name]}`)
        .join(", ");
      wrap.remove();
      // Enviar datos como mensaje con JSON embebido — incluye __tool__ para que el LLM sepa qué ejecutar
      const payload = { __tool__: spec.next_tool ?? "", ...vals };
      input.value = `[FORM_DATA:${JSON.stringify(payload)}] ${summary}`;
      send();
    });
  }

  // ── Send ───────────────────────────────────────────────────────────────────
  async function send() {
    const text = input.value.trim();
    if (!text || busy) return;

    suggestionsEl.classList.add("hidden");
    // Strip [FORM_DATA:{...}] prefix — show only the human-readable summary
    const displayText = text.replace(/^\[FORM_DATA:\{.*?\}\]\s*/s, "");
    bubble("user", displayText || text);
    input.value = "";
    input.style.height = "auto";
    busy = true;
    sendBtn.disabled = true;
    statusEl.textContent = "pensando…";

    let assistantEl = null;
    let assistantText = "";
    let activeChip = null;

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ message: text, history }),
      });

      const reader = res.body.getReader();
      const dec = new TextDecoder();
      let buf = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const lines = buf.split("\n");
        buf = lines.pop() ?? "";

        for (const line of lines) {
          if (!line.startsWith("data: ")) continue;
          let ev;
          try { ev = JSON.parse(line.slice(6)); } catch { continue; }

          if (ev.type === "token") {
            if (!assistantEl) {
              assistantEl = bubble("assistant", "");
            }
            assistantText += ev.content;
            assistantEl.textContent = assistantText;
            scrollBottom();

          } else if (ev.type === "tool_start") {
            // Hide raw tool-call text emitted before the tool executes
            if (assistantEl) {
              assistantEl.closest(".msg-wrap")?.remove();
              assistantEl = null;
              assistantText = "";
            }
            if (ev.name === "solicitar_datos") {
              statusEl.textContent = "preparando formulario…";
            } else {
              statusEl.textContent = ev.name + "…";
              activeChip = toolChip(ev.name, false);
            }

          } else if (ev.type === "tool_end") {
            // ── Formulario inline ──────────────────────────────
            if (ev.result && ev.result.__form__) {
              if (activeChip) { activeChip.remove(); activeChip = null; }
              renderForm(ev.result);
              busy = false;
              sendBtn.disabled = false;
              statusEl.textContent = "esperando datos…";
              return; // pausa el loop — el form retomará al submit
            }
            if (activeChip) {
              activeChip.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3 text-green-600"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg>${ev.name}`;
              activeChip = null;
            }
            assistantEl = null;
            assistantText = "";
            statusEl.textContent = "procesando…";

            // Refresh page data when a mutation tool succeeds on the relevant page
            const pageRefreshMap = {
              crear_insumo:    ["/dry-supplies"],
              agregar_stock_insumo: ["/dry-supplies"],
              crear_producto:  ["/products"],
              hacer_pedido_cliente: ["/sale-orders"],
              crear_cliente:   ["/customers"],
            };
            const currentPath = window.location.pathname.replace(/\/$/, "");
            const refreshPaths = pageRefreshMap[ev.name] ?? [];
            if (ev.result && !ev.result.error && refreshPaths.some(p => currentPath.startsWith(p))) {
              setTimeout(() => window.location.reload(), 800);
            }

          } else if (ev.type === "done") {
            history = ev.history ?? history;
            statusEl.textContent = "listo";

          } else if (ev.type === "error") {
            bubble("assistant", "Error: " + ev.message);
            statusEl.textContent = "error";
          }
        }
      }
    } catch (e) {
      bubble("assistant", "Error de conexión: " + e.message);
      statusEl.textContent = "error";
    } finally {
      busy = false;
      sendBtn.disabled = false;
      if (statusEl.textContent !== "listo") statusEl.textContent = "listo";
    }
  }
})();
</script>
