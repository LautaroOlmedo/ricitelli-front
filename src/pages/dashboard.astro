---
import AppLayout from "@/layouts/AppLayout.astro";
import { getSaleOrders } from "@/lib/grpc/saleOrderClient";
import { getProducts } from "@/lib/grpc/productClient";
import { COOKIE_NAME } from "@/lib/auth";

const token = Astro.cookies.get(COOKIE_NAME)?.value;

let data: any = null;
let error = "";

try {
  const [orders, products] = await Promise.all([
    getSaleOrders(token),
    getProducts(token),
  ]);

  const activeOrders = orders.filter((o) => o.status !== "CANCELLED");

  // proto-loader devuelve quantity y unit_price como strings — normalizar
  const qty = (i: any) => { const n = Number(i.quantity); return isFinite(n) ? n : 0; };
  const price = (i: any) => { const n = Number(i.unit_price); return isFinite(n) ? n : 0; };
  const orderBottles = (o: any) => (o.items ?? []).reduce((s: number, i: any) => s + qty(i), 0);
  const orderValue   = (o: any) => (o.items ?? []).reduce((s: number, i: any) => s + price(i) * qty(i), 0);

  // KPIs
  const totalBottles = activeOrders.reduce((s, o) => s + orderBottles(o), 0);

  // Agrupar revenue por moneda
  const revenueByCurrency: Record<string, number> = {};
  for (const o of activeOrders) {
    const cur = o.currency || "ARS";
    revenueByCurrency[cur] = (revenueByCurrency[cur] ?? 0) + orderValue(o);
  }
  const revenueUSD = revenueByCurrency["USD"] ?? 0;
  const revenueARS = revenueByCurrency["ARS"] ?? 0;
  const [dominantCurrency, dominantRevenue] = Object.entries(revenueByCurrency).sort((a, b) => b[1] - a[1])[0] ?? ["ARS", 0];

  // Pipeline
  const pipeline: Record<string, number> = {
    NEW: 0, CONFIRMED: 0, INVOICED: 0, DISPATCHED: 0,
  };
  for (const o of activeOrders) {
    if (o.status in pipeline) pipeline[o.status]++;
  }

  // Bottles by country
  const bottlesByCountry: Record<string, number> = {};
  for (const o of activeOrders) {
    if (o.market === "EXPORT" && o.destination_country) {
      const c = o.destination_country.toUpperCase();
      bottlesByCountry[c] = (bottlesByCountry[c] ?? 0) + orderBottles(o);
    }
  }

  // Top products
  const productQty: Record<string, number> = {};
  for (const o of activeOrders) {
    for (const item of o.items) {
      productQty[item.product_id] = (productQty[item.product_id] ?? 0) + qty(item);
    }
  }
  const productMap = Object.fromEntries(products.map((p) => [p.id, p.name]));
  const topProducts = Object.entries(productQty)
    .map(([id, q]) => ({ id, name: productMap[id] ?? id, qty: q }))
    .sort((a, b) => b.qty - a.qty)
    .slice(0, 5);
  const maxQty = topProducts[0]?.qty ?? 1;

  // Export breakdown
  const exportBottles  = activeOrders.filter((o) => o.market === "EXPORT").reduce((s, o) => s + orderBottles(o), 0);
  const domesticBottles = activeOrders.filter((o) => o.market === "DOMESTIC").reduce((s, o) => s + orderBottles(o), 0);

  // Recent orders
  const recentOrders = [...orders]
    .sort((a, b) => (b.created_at > a.created_at ? 1 : -1))
    .slice(0, 6)
    .map((o) => ({
      ...o,
      bottles: orderBottles(o),
      value: orderValue(o),
    }));

  const exportOrdersCount = activeOrders.filter((o) => o.market === "EXPORT").length;
  const avgBottlesPerOrder = activeOrders.length > 0 ? Math.round(totalBottles / activeOrders.length) : 0;

  data = {
    kpis: {
      active: activeOrders.length,
      bottles: totalBottles,
      revenueUSD,
      revenueARS,
      dominantCurrency,
      dominantRevenue,
      exportOrdersCount,
      avgBottlesPerOrder,
      markets: Object.keys(bottlesByCountry).length,
    },
    pipeline,
    bottlesByCountry,
    topProducts,
    maxQty,
    exportBottles,
    domesticBottles,
    recentOrders,
  };
} catch (e: any) {
  error = e.message;
}

const statusLabel: Record<string, string> = {
  NEW: "Nuevo", CONFIRMED: "Confirmado", INVOICED: "Facturado",
  DISPATCHED: "Despachado", CANCELLED: "Cancelado",
};
const statusColor: Record<string, string> = {
  NEW: "bg-amber-100 text-amber-800",
  CONFIRMED: "bg-blue-100 text-blue-800",
  INVOICED: "bg-purple-100 text-purple-800",
  DISPATCHED: "bg-green-100 text-green-800",
  CANCELLED: "bg-red-100 text-red-800",
};
const pipelineColor: Record<string, string> = {
  NEW: "#e8c468", CONFIRMED: "#6ea8d8", INVOICED: "#a78bda", DISPATCHED: "#6ec99a",
};
const countryNames: Record<string, string> = {
  GB: "Reino Unido", US: "Estados Unidos", JP: "Japón", BR: "Brasil",
  CA: "Canadá", DE: "Alemania", CN: "China", FR: "Francia",
  NL: "Países Bajos", CH: "Suiza", MX: "México", AR: "Argentina",
  CL: "Chile", PE: "Perú", CO: "Colombia", AU: "Australia",
  SE: "Suecia", NO: "Noruega", DK: "Dinamarca", IT: "Italia",
};
---

<AppLayout title="Dashboard">
  <div class="p-8 space-y-8 max-w-350">

    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-display font-medium text-foreground">Dashboard Ejecutivo</h1>
        <p class="text-sm text-muted-foreground mt-1">Visión en tiempo real del negocio</p>
      </div>
      <div class="text-right">
        <p class="text-xs text-muted-foreground">Actualizado</p>
        <p class="text-sm font-medium text-foreground" id="last-updated">—</p>
      </div>
    </div>

    {error && (
      <div class="rounded-xl border border-destructive/30 bg-destructive/5 px-5 py-4 text-sm text-destructive">
        Error al cargar datos: {error}
      </div>
    )}

    {data && (
      <>
        <!-- ── KPIs ──────────────────────────────────────────────────────── -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="rounded-2xl border border-border bg-card p-5 shadow-(--shadow-ring)">
            <p class="text-xs text-muted-foreground uppercase tracking-widest mb-1">Pedidos Activos</p>
            <p class="text-4xl font-display font-medium text-foreground">{data.kpis.active}</p>
            <p class="text-xs text-muted-foreground mt-1">pedidos en curso</p>
          </div>
          <div class="rounded-2xl border border-border bg-card p-5 shadow-(--shadow-ring)">
            <p class="text-xs text-muted-foreground uppercase tracking-widest mb-1">Botellas</p>
            <p class="text-4xl font-display font-medium text-primary">{data.kpis.bottles.toLocaleString("es-AR")}</p>
            <p class="text-xs text-muted-foreground mt-1">comprometidas</p>
          </div>
          <div class="rounded-2xl border border-border bg-card p-5 shadow-(--shadow-ring)">
            {data.kpis.dominantRevenue > 0 ? (
              <>
                <p class="text-xs text-muted-foreground uppercase tracking-widest mb-1">Revenue {data.kpis.dominantCurrency}</p>
                <p class="text-4xl font-display font-medium text-foreground">
                  {data.kpis.dominantRevenue >= 1_000_000
                    ? `$${(data.kpis.dominantRevenue / 1_000_000).toFixed(1)}M`
                    : `$${Math.round(data.kpis.dominantRevenue / 1000)}k`}
                </p>
                <p class="text-xs text-muted-foreground mt-1">en pedidos activos</p>
              </>
            ) : (
              <>
                <p class="text-xs text-muted-foreground uppercase tracking-widest mb-1">Promedio por Pedido</p>
                <p class="text-4xl font-display font-medium text-foreground">{data.kpis.avgBottlesPerOrder}</p>
                <p class="text-xs text-muted-foreground mt-1">botellas · <a href="/sale-orders/new" class="text-primary hover:underline">cargar precios</a></p>
              </>
            )}
          </div>
          <div class="rounded-2xl border border-border bg-card p-5 shadow-(--shadow-ring)">
            <p class="text-xs text-muted-foreground uppercase tracking-widest mb-1">Pedidos Export</p>
            <p class="text-4xl font-display font-medium text-foreground">{data.kpis.exportOrdersCount}</p>
            <p class="text-xs text-muted-foreground mt-1">
              {data.kpis.markets > 0 ? `${data.kpis.markets} países destino` : "mercado doméstico"}
            </p>
          </div>
        </div>

        <!-- ── Mapa + Pipeline ────────────────────────────────────────────── -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

          <!-- Mapa mundi -->
          <div class="lg:col-span-2 rounded-2xl border border-border bg-card shadow-(--shadow-ring) overflow-hidden">
            <div class="px-6 pt-5 pb-3 border-b border-border flex items-center justify-between">
              <div>
                <h2 class="font-display font-medium text-foreground">Destinos de Exportación</h2>
                <p class="text-xs text-muted-foreground mt-0.5">Botellas por país — pedidos activos</p>
              </div>
              <span class="text-xs px-2.5 py-1 rounded-full bg-primary/10 text-primary font-medium">
                {Object.keys(data.bottlesByCountry).length} países
              </span>
            </div>
            <div id="world-map" class="h-80 bg-card"></div>
          </div>

          <!-- Pipeline -->
          <div class="rounded-2xl border border-border bg-card shadow-(--shadow-ring) p-6">
            <h2 class="font-display font-medium text-foreground mb-1">Pipeline de Ventas</h2>
            <p class="text-xs text-muted-foreground mb-5">Pedidos por estado</p>
            <div class="space-y-4">
              {Object.entries(data.pipeline).map(([status, count]) => {
                const total = Object.values(data.pipeline).reduce((s: number, v) => s + (v as number), 0) || 1;
                const pct = Math.round(((count as number) / (total as number)) * 100);
                return (
                  <div>
                    <div class="flex justify-between items-center mb-1.5">
                      <span class="text-[13px] text-foreground/80">{statusLabel[status]}</span>
                      <span class="text-[13px] font-semibold text-foreground">{count as number}</span>
                    </div>
                    <div class="h-2 rounded-full bg-secondary overflow-hidden">
                      <div
                        class="h-full rounded-full transition-all duration-700"
                        style={`width: ${pct}%; background-color: ${pipelineColor[status] ?? "#c96442"}`}
                      ></div>
                    </div>
                  </div>
                );
              })}
            </div>

            <!-- Export vs Domestic -->
            <div class="mt-6 pt-5 border-t border-border">
              <h3 class="text-xs text-muted-foreground uppercase tracking-widest mb-3">Mercado</h3>
              <div class="space-y-2">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <div class="size-2 rounded-full bg-primary"></div>
                    <span class="text-[13px] text-foreground/80">Export</span>
                  </div>
                  <span class="text-[13px] font-semibold">{data.exportBottles.toLocaleString("es-AR")} bot.</span>
                </div>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <div class="size-2 rounded-full bg-muted-foreground/40"></div>
                    <span class="text-[13px] text-foreground/80">Doméstico</span>
                  </div>
                  <span class="text-[13px] font-semibold">{data.domesticBottles.toLocaleString("es-AR")} bot.</span>
                </div>
              </div>
              {(data.exportBottles + data.domesticBottles) > 0 && (
                <div class="mt-3 h-2 rounded-full bg-secondary overflow-hidden">
                  <div
                    class="h-full rounded-full bg-primary"
                    style={`width: ${Math.round(data.exportBottles / (data.exportBottles + data.domesticBottles) * 100)}%`}
                  ></div>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- ── Top Products + Recent Orders ──────────────────────────────── -->
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

          <!-- Top Products -->
          <div class="lg:col-span-2 rounded-2xl border border-border bg-card shadow-(--shadow-ring) p-6">
            <h2 class="font-display font-medium text-foreground mb-1">Top Productos</h2>
            <p class="text-xs text-muted-foreground mb-5">Por botellas vendidas</p>
            {data.topProducts.length === 0 && (
              <p class="text-sm text-muted-foreground">Sin datos</p>
            )}
            <div class="space-y-4">
              {data.topProducts.map((p: any, i: number) => (
                <div>
                  <div class="flex justify-between items-center mb-1.5">
                    <div class="flex items-center gap-2.5">
                      <span class="text-[11px] font-semibold text-muted-foreground/50 w-4 text-right">{i + 1}</span>
                      <span class="text-[13px] text-foreground/90 font-medium">{p.name}</span>
                    </div>
                    <span class="text-[13px] font-semibold text-foreground">{p.qty.toLocaleString("es-AR")}</span>
                  </div>
                  <div class="h-1.5 rounded-full bg-secondary overflow-hidden ml-6">
                    <div
                      class="h-full rounded-full bg-primary/70 transition-all duration-700"
                      style={`width: ${Math.round((p.qty / data.maxQty) * 100)}%`}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Recent Orders -->
          <div class="lg:col-span-3 rounded-2xl border border-border bg-card shadow-(--shadow-ring) overflow-hidden">
            <div class="px-6 pt-5 pb-3 border-b border-border flex items-center justify-between">
              <div>
                <h2 class="font-display font-medium text-foreground">Últimos Pedidos</h2>
                <p class="text-xs text-muted-foreground mt-0.5">Actividad reciente</p>
              </div>
              <a href="/sale-orders" class="text-xs text-primary hover:underline">Ver todos →</a>
            </div>
            <div class="divide-y divide-border">
              {data.recentOrders.map((o: any) => (
                <a href={`/sale-orders/${o.id}`} class="flex items-center gap-4 px-6 py-3.5 hover:bg-secondary/30 transition-colors">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <span class="text-[13px] font-medium text-foreground truncate">
                        {o.customer_id.slice(0, 8)}…
                      </span>
                      {o.destination_country && (
                        <span class="text-xs text-muted-foreground">{countryNames[o.destination_country] ?? o.destination_country}</span>
                      )}
                    </div>
                    <p class="text-[11px] text-muted-foreground mt-0.5">
                      {o.bottles} bot. · {o.currency} {o.value > 0 ? o.value.toLocaleString("es-AR") : "—"}
                    </p>
                  </div>
                  <span class:list={["text-[11px] px-2 py-0.5 rounded-full font-medium", statusColor[o.status] ?? "bg-secondary text-foreground"]}>
                    {statusLabel[o.status] ?? o.status}
                  </span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </>
    )}
  </div>
</AppLayout>

<!-- Leaflet world map -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script is:inline define:vars={{ bottlesByCountry: data?.bottlesByCountry ?? {}, countryNames }}>
  // Update timestamp
  document.getElementById("last-updated").textContent =
    new Date().toLocaleTimeString("es-AR", { hour: "2-digit", minute: "2-digit" });

  // ── Leaflet World Map ──────────────────────────────────────────────────────
  const mapEl = document.getElementById("world-map");
  if (!mapEl || typeof L === "undefined") {
    // fallback: show country list
  } else {
    const map = L.map("world-map", {
      zoomControl: false,
      attributionControl: false,
      dragging: false,
      scrollWheelZoom: false,
      doubleClickZoom: false,
      touchZoom: false,
    }).setView([20, 10], 1.4);

    // Tile layer — light neutral style
    L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png",
      { subdomains: "abcd", maxZoom: 4 }
    ).addTo(map);

    // Country ISO → centroid approx for circle markers
    const centroids = {
      GB: [54.7, -3.4], US: [37.1, -95.7], JP: [36.2, 138.2],
      BR: [-14.2, -51.9], CA: [56.1, -106.3], DE: [51.2, 10.4],
      CN: [35.9, 104.2], FR: [46.2, 2.2], NL: [52.1, 5.3],
      CH: [46.8, 8.2], MX: [23.6, -102.5], CL: [-35.7, -71.5],
      PE: [-9.2, -75.0], CO: [4.6, -74.1], AU: [-25.3, 133.8],
      SE: [60.1, 18.6], NO: [60.5, 8.5], DK: [56.3, 9.5],
      IT: [41.9, 12.6], AR: [-38.4, -63.6],
    };

    const maxBottles = Math.max(...Object.values(bottlesByCountry), 1);

    for (const [country, bottles] of Object.entries(bottlesByCountry)) {
      const coords = centroids[country];
      if (!coords) continue;

      const intensity = Number(bottles) / maxBottles;
      const radius = 8 + intensity * 28;
      const opacity = 0.35 + intensity * 0.45;

      const circle = L.circleMarker(coords, {
        radius,
        fillColor: "#c96442",
        fillOpacity: opacity,
        color: "#c96442",
        weight: 1.5,
        opacity: 0.7,
      }).addTo(map);

      const name = countryNames[country] ?? country;
      circle.bindTooltip(
        `<div style="font-family:Inter,sans-serif;font-size:12px;line-height:1.5">
          <strong>${name}</strong><br>
          ${Number(bottles).toLocaleString("es-AR")} botellas
        </div>`,
        { direction: "top", offset: [0, -radius] }
      );

      // Pulse animation on circles with high volume
      if (intensity > 0.5) {
        let t = 0;
        setInterval(() => {
          t += 0.05;
          circle.setStyle({ fillOpacity: opacity + Math.sin(t) * 0.15 });
        }, 60);
      }
    }

    // If no export data, show a message
    if (Object.keys(bottlesByCountry).length === 0) {
      mapEl.innerHTML = `
        <div style="display:flex;align-items:center;justify-content:center;height:100%;color:#87867f;font-size:13px;font-family:Inter,sans-serif">
          Sin pedidos de exportación activos
        </div>`;
    }
  }
</script>
