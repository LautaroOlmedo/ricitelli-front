---
import AppLayout from "@/layouts/AppLayout.astro";
import { getProductionOrders } from "@/lib/grpc/productionOrderClient";
import { getSaleOrders } from "@/lib/grpc/saleOrderClient";
import { getCustomers } from "@/lib/grpc/customerClient";
import { COOKIE_NAME } from "@/lib/auth";

const token = Astro.cookies.get(COOKIE_NAME)?.value;

const [productionOrders, saleOrders, customers] = await Promise.all([
  getProductionOrders(token).catch(() => []),
  getSaleOrders(token).catch(() => []),
  getCustomers(token).catch(() => []),
]);

const customerMap: Record<string, string> = {};
for (const c of customers) customerMap[c.id] = c.social_reason;

// ── Calendar state ─────────────────────────────────────────────────────────
const url = new URL(Astro.request.url);
const paramYear  = parseInt(url.searchParams.get("year")  ?? "0");
const paramMonth = parseInt(url.searchParams.get("month") ?? "0");

const today = new Date();
const viewYear  = paramYear  || today.getFullYear();
const viewMonth = paramMonth || (today.getMonth() + 1);

const firstDay   = new Date(viewYear, viewMonth - 1, 1);
const lastDay    = new Date(viewYear, viewMonth, 0);
const totalDays  = lastDay.getDate();
const startOffset = (firstDay.getDay() + 6) % 7;

const monthNames = [
  "Enero","Febrero","Marzo","Abril","Mayo","Junio",
  "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre",
];
const dayNames = ["Lun","Mar","Mié","Jue","Vie","Sáb","Dom"];

function navURL(y: number, m: number) {
  const adj = m < 1 ? [y - 1, 12] : m > 12 ? [y + 1, 1] : [y, m];
  return `/production-orders/calendar?year=${adj[0]}&month=${adj[1]}`;
}
const prevURL = navURL(viewYear, viewMonth - 1);
const nextURL = navURL(viewYear, viewMonth + 1);

function padDay(d: number) { return String(d).padStart(2, "0"); }
function dayKey(d: number) { return `${viewYear}-${padDay(viewMonth)}-${padDay(d)}`; }
function isToday(d: number) {
  return d === today.getDate() && viewMonth === today.getMonth() + 1 && viewYear === today.getFullYear();
}

// ── Map events to days ─────────────────────────────────────────────────────
type CalEvent = { type: "production" | "sale"; id: string; label: string; href: string; status: string };
const eventsByDay: Record<string, CalEvent[]> = {};

function addEvent(dateStr: string, event: CalEvent) {
  if (!dateStr) return;
  const day = dateStr.slice(0, 10);
  const [oy, om] = day.split("-").map(Number);
  if (oy === viewYear && om === viewMonth) {
    if (!eventsByDay[day]) eventsByDay[day] = [];
    eventsByDay[day].push(event);
  }
}

for (const o of productionOrders) {
  addEvent(o.created_at, {
    type: "production",
    id: o.id,
    label: `${o.items?.length ?? 0} prod.`,
    href: `/production-orders/${o.id}`,
    status: o.status ?? "IN_PROGRESS",
  });
}

for (const o of saleOrders) {
  const customer = customerMap[o.customer_id] ?? o.customer_id.slice(0, 8) + "…";
  addEvent(o.created_at, {
    type: "sale",
    id: o.id,
    label: customer,
    href: `/sale-orders/${o.id}`,
    status: o.status ?? "NEW",
  });
}

const cells: (number | null)[] = [
  ...Array(startOffset).fill(null),
  ...Array.from({ length: totalDays }, (_, i) => i + 1),
];
while (cells.length % 7 !== 0) cells.push(null);

const totalProduction = Object.values(eventsByDay).flat().filter(e => e.type === "production").length;
const totalSale       = Object.values(eventsByDay).flat().filter(e => e.type === "sale").length;

// All events sorted for the list below
const allEvents = Object.entries(eventsByDay)
  .sort(([a], [b]) => a.localeCompare(b))
  .flatMap(([date, evs]) => evs.map(e => ({ ...e, _date: date })));
---

<AppLayout title="Calendario">
  <div class="px-8 py-8 max-w-5xl mx-auto">

    <!-- Header -->
    <div class="flex items-start justify-between mb-6">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">
          {monthNames[viewMonth - 1]} {viewYear}
        </h1>
        <p class="text-sm text-muted-foreground mt-1">
          <span class="inline-flex items-center gap-1">
            <span class="size-2 rounded-full bg-primary inline-block"></span>
            {totalProduction} producción
          </span>
          <span class="mx-2 text-border">·</span>
          <span class="inline-flex items-center gap-1">
            <span class="size-2 rounded-full bg-emerald-500 inline-block"></span>
            {totalSale} ventas
          </span>
        </p>
      </div>

      <div class="flex items-center gap-2">
        <a href={prevURL}
          class="inline-flex items-center justify-center size-9 rounded-lg border border-input bg-background hover:bg-accent transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/production-orders/calendar"
          class="inline-flex items-center justify-center rounded-lg border border-input bg-background px-3 py-2 text-xs font-medium hover:bg-accent transition-colors">
          Hoy
        </a>
        <a href={nextURL}
          class="inline-flex items-center justify-center size-9 rounded-lg border border-input bg-background hover:bg-accent transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Calendar grid -->
    <div class="rounded-xl border border-border bg-card overflow-hidden">

      <!-- Day headers -->
      <div class="grid grid-cols-7 border-b border-border">
        {dayNames.map((d, i) => (
          <div class:list={[
            "px-2 py-2.5 text-center text-xs font-medium text-muted-foreground uppercase tracking-wider",
            i < 6 ? "border-r border-border" : "",
          ]}>
            {d}
          </div>
        ))}
      </div>

      <!-- Day cells -->
      <div class="grid grid-cols-7">
        {cells.map((day, idx) => {
          const isLastRow  = idx >= cells.length - 7;
          const isLastCol  = idx % 7 === 6;
          const evs        = day ? (eventsByDay[dayKey(day as number)] ?? []) : [];
          const visible    = evs.slice(0, 3);
          const overflow   = evs.length - visible.length;
          return (
            <div class:list={[
              "min-h-24 p-2 flex flex-col",
              !isLastRow ? "border-b border-border" : "",
              !isLastCol ? "border-r border-border" : "",
              !day ? "bg-muted/20" : "",
              day && isToday(day as number) ? "bg-primary/5" : "",
            ]}>
              {day && (
                <>
                  <span class:list={[
                    "text-xs font-semibold mb-1.5 size-6 flex items-center justify-center rounded-full",
                    isToday(day as number)
                      ? "bg-primary text-primary-foreground"
                      : "text-foreground",
                  ]}>
                    {day}
                  </span>
                  <div class="flex flex-col gap-0.5">
                    {visible.map((e) => (
                      <a
                        href={e.href}
                        class:list={[
                          "block rounded px-1.5 py-0.5 text-xs font-medium truncate transition-colors",
                          e.type === "production"
                            ? "bg-primary/10 text-primary hover:bg-primary/20"
                            : "bg-emerald-100 text-emerald-700 hover:bg-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-300",
                        ]}
                        title={`${e.type === "sale" ? "Venta" : "Producción"}: ${e.label} — ${e.status}`}
                      >
                        {e.label}
                      </a>
                    ))}
                    {overflow > 0 && (
                      <span class="text-xs text-muted-foreground px-1">+{overflow} más</span>
                    )}
                  </div>
                </>
              )}
            </div>
          );
        })}
      </div>
    </div>

    <!-- Event list -->
    {allEvents.length > 0 && (
      <div class="mt-6 rounded-xl border border-border bg-card overflow-hidden">
        <div class="px-5 py-4 border-b border-border flex items-center gap-4">
          <h2 class="text-sm font-semibold flex-1">Eventos de {monthNames[viewMonth - 1]}</h2>
          <!-- Filter buttons -->
          <div class="flex gap-1" id="filter-btns">
            <button data-filter="all"     class="filter-btn active rounded-full px-2.5 py-1 text-xs font-medium bg-primary text-primary-foreground">Todos</button>
            <button data-filter="production" class="filter-btn rounded-full px-2.5 py-1 text-xs font-medium border border-input bg-background hover:bg-accent transition-colors">Producción</button>
            <button data-filter="sale"    class="filter-btn rounded-full px-2.5 py-1 text-xs font-medium border border-input bg-background hover:bg-accent transition-colors">Ventas</button>
          </div>
        </div>
        <div class="divide-y divide-border">
          {allEvents.map((e) => (
            <a
              href={e.href}
              data-type={e.type}
              class="event-row flex items-center justify-between px-5 py-3 text-sm hover:bg-muted/30 transition-colors group"
            >
              <div class="flex items-center gap-3">
                <span class:list={[
                  "size-2 rounded-full shrink-0",
                  e.type === "production" ? "bg-primary" : "bg-emerald-500",
                ]}></span>
                <div>
                  <span class="text-xs text-muted-foreground">{e._date}</span>
                  <p class="text-sm font-medium group-hover:text-primary transition-colors">{e.label}</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-xs text-muted-foreground capitalize">
                  {e.type === "production" ? "Producción" : "Venta"}
                </span>
                <span class:list={[
                  "inline-flex rounded-full px-2 py-0.5 text-xs font-medium",
                  e.status === "NEW"               ? "bg-secondary text-secondary-foreground" :
                  e.status === "CONFIRMED"          ? "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300" :
                  e.status === "READY_TO_DISPATCH"  ? "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300" :
                  e.status === "INVOICED"           ? "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300" :
                  e.status === "DISPATCHED"         ? "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300" :
                  e.status === "CANCELLED"          ? "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300" :
                                                     "bg-secondary text-secondary-foreground",
                ]}>
                  {e.status}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</AppLayout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const rows = document.querySelectorAll<HTMLElement>(".event-row");

  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;
      btns.forEach((b) => {
        const active = b.dataset.filter === filter;
        b.classList.toggle("bg-primary", active);
        b.classList.toggle("text-primary-foreground", active);
        b.classList.toggle("active", active);
        b.classList.toggle("border-input", !active);
        b.classList.toggle("bg-background", !active);
      });
      rows.forEach((row) => {
        row.style.display = filter === "all" || row.dataset.type === filter ? "" : "none";
      });
    });
  });
</script>
