---
import AppLayout from "@/layouts/AppLayout.astro";
import { getPlots } from "@/lib/grpc/vineyardClient";
import { COOKIE_NAME } from "@/lib/auth";
import type { Plot } from "@/lib/grpc/types";

const token = Astro.cookies.get(COOKIE_NAME)?.value;
let plots: Plot[] = [];
let loadError: string | null = null;

try {
  plots = await getPlots(token);
} catch (e: any) {
  loadError = e.details ?? e.message ?? "Error al conectar con el servidor";
}
---

<AppLayout title="Mapa del Viñedo">
  <div class="flex h-[calc(100vh-0px)] overflow-hidden">

    <!-- ── Left panel ────────────────────────────────────── -->
    <aside class="w-72 shrink-0 border-r border-border bg-card flex flex-col overflow-hidden">

      <!-- Panel header -->
      <div class="px-4 pt-5 pb-4 border-b border-border">
        <h1 class="font-display font-bold text-[15px]">Mapa de Fincas</h1>
        <p class="text-[11px] text-muted-foreground mt-0.5">Alto Valle · Río Negro · Patagonia</p>

        <!-- Totals -->
        <div class="mt-3 flex items-center gap-2">
          <div class="flex-1 rounded-lg bg-muted/50 px-3 py-2 text-center">
            <p class="text-[10px] font-medium text-muted-foreground uppercase tracking-wider">Superficie</p>
            <p id="total-ha" class="font-display font-bold text-xl" style="color:#4E0707;">— ha</p>
          </div>
          <div class="flex-1 rounded-lg bg-muted/50 px-3 py-2 text-center">
            <p class="text-[10px] font-medium text-muted-foreground uppercase tracking-wider">Parcelas</p>
            <p id="total-plots" class="font-display font-bold text-xl" style="color:#4E0707;">—</p>
          </div>
        </div>
      </div>

      <!-- Indicator selector -->
      <div class="px-4 py-3 border-b border-border">
        <p class="text-[10px] font-semibold uppercase tracking-widest text-muted-foreground mb-2">Indicador</p>
        <div class="grid grid-cols-2 gap-1.5">
          {[
            { id: "ndvi",        label: "NDVI",        icon: "🌿" },
            { id: "moisture",    label: "Humedad",      icon: "💧" },
            { id: "temperature", label: "Temperatura",  icon: "🌡️" },
            { id: "maturity",    label: "Maduración",   icon: "🍇" },
          ].map(({ id, label, icon }) => (
            <button
              class="indicator-btn rounded-md px-2.5 py-2 text-[11px] font-semibold text-left flex items-center gap-1.5 border border-border hover:bg-muted/60 transition-colors"
              data-indicator={id}>
              <span>{icon}</span> {label}
            </button>
          ))}
        </div>
      </div>

      <!-- Heatmap legend -->
      <div id="legend-panel" class="px-4 py-3 border-b border-border hidden">
        <p class="text-[10px] font-semibold uppercase tracking-widest text-muted-foreground mb-2">Escala</p>
        <div id="legend-gradient" class="flex items-center gap-0 rounded-md overflow-hidden h-3" style="background:linear-gradient(to right,#3B82F6,#22C55E,#F59E0B,#EF4444);"/>
        <div class="flex justify-between mt-1">
          <span id="legend-min" class="text-[9px] text-muted-foreground">Bajo</span>
          <span id="legend-mid" class="text-[9px] text-muted-foreground">Medio</span>
          <span id="legend-max" class="text-[9px] text-muted-foreground">Alto</span>
        </div>
        <p id="legend-unit" class="text-[9px] text-muted-foreground mt-1 text-center"></p>
      </div>

      <!-- Error state -->
      {loadError && (
        <div class="px-4 py-4 text-center">
          <p class="text-[11px] text-destructive font-medium">{loadError}</p>
          <p class="text-[10px] text-muted-foreground mt-1">El mapa cargará sin datos del backend</p>
        </div>
      )}

      <!-- Plot list -->
      <div id="plot-list" class="flex-1 overflow-y-auto py-2">
        <!-- Populated by JS from API -->
      </div>

      <!-- Footer actions -->
      <div class="px-4 py-3 border-t border-border flex gap-2">
        <button id="btn-new-plot"
          class="flex-1 flex items-center justify-center gap-1.5 rounded-md bg-primary text-primary-foreground py-2 text-[11px] font-semibold hover:bg-primary/90 transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
            <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
          </svg>
          Nueva Parcela
        </button>
        <button id="btn-mode-toggle"
          class="flex-1 flex items-center justify-center gap-1.5 rounded-md border border-border py-2 text-[11px] font-medium hover:bg-muted/60 transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
            <path d="M12 2L2 7l10 5 10-5-10-5z" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Mapa de Calor
        </button>
      </div>
    </aside>

    <!-- ── Map container ─────────────────────────────────── -->
    <div class="flex-1 relative">
      <div id="map" class="w-full h-full"/>

      <!-- Zoom controls -->
      <div class="absolute top-4 right-4 z-1000 flex flex-col overflow-hidden rounded-lg shadow-md border border-border">
        <button id="zoom-in"  class="bg-card hover:bg-muted/60 px-3 py-2.5 text-sm font-bold transition-colors border-b border-border">+</button>
        <button id="zoom-out" class="bg-card hover:bg-muted/60 px-3 py-2.5 text-sm font-bold transition-colors">−</button>
      </div>

      <!-- Mode pill -->
      <div class="absolute top-4 left-4 z-1000 flex gap-2 items-center">
        <button id="btn-normal"
          class="rounded-lg px-3 py-1.5 text-[12px] font-semibold shadow-md border transition-colors"
          style="background:#4E0707;color:#F5F0EB;border-color:#4E0707;">Normal</button>
        <button id="btn-heatmap"
          class="rounded-lg px-3 py-1.5 text-[12px] font-semibold shadow-md border border-border bg-card transition-colors hover:bg-muted/60">Mapa de Calor</button>
        <!-- Weather loading indicator -->
        <div id="weather-loading" style="display:none;"
          class="flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-[11px] font-medium shadow-md border border-border bg-card">
          <svg class="size-3 animate-spin text-primary" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="32" stroke-dashoffset="12" stroke-linecap="round"/>
          </svg>
          <span class="text-muted-foreground">Cargando clima…</span>
        </div>
      </div>

      <!-- Infowindow -->
      <div id="infowindow"
        class="absolute bottom-6 left-4 z-1000 hidden w-72 rounded-xl bg-card border border-border shadow-xl overflow-hidden">
        <div id="iw-header" class="px-4 py-3 flex items-start justify-between" style="background:#4E070712;">
          <div>
            <p id="iw-name" class="font-display font-bold text-[15px] leading-tight"/>
            <p id="iw-variety" class="text-[11px] text-muted-foreground mt-0.5"/>
          </div>
          <div class="flex gap-1 mt-0.5">
            <button id="iw-edit"
              class="size-7 rounded-full flex items-center justify-center text-muted-foreground hover:bg-muted/60 transition-colors text-[11px] border border-border">✏️</button>
            <button id="iw-delete"
              class="size-7 rounded-full flex items-center justify-center text-destructive hover:bg-destructive/10 transition-colors text-[11px] border border-destructive/30">🗑</button>
            <button id="iw-close"
              class="size-7 rounded-full flex items-center justify-center text-muted-foreground hover:bg-muted/60 transition-colors text-sm border border-border">✕</button>
          </div>
        </div>
        <div class="px-4 py-3 grid grid-cols-3 gap-2 border-b border-border">
          <div class="text-center"><p id="iw-ha"  class="font-bold text-base font-display"/><p class="text-[10px] text-muted-foreground">Hectáreas</p></div>
          <div class="text-center"><p id="iw-age" class="font-bold text-base font-display"/><p class="text-[10px] text-muted-foreground">Años cepa</p></div>
          <div class="text-center"><p id="iw-stat" class="font-bold text-base"/><p class="text-[10px] text-muted-foreground">Estado</p></div>
        </div>
        <div id="iw-indicator-row" style="display:none;" class="px-4 py-2.5 items-center justify-between border-b border-border">
          <span id="iw-indicator-label" class="text-[11px] text-muted-foreground font-medium"></span>
          <span id="iw-indicator-value" class="text-[13px] font-bold font-display"></span>
        </div>
      </div>

      <!-- Draw toolbar — shown while drawing a polygon -->
      <div id="draw-toolbar"
        class="hidden absolute top-16 left-1/2 -translate-x-1/2 z-1500 items-center gap-3 rounded-xl bg-card border border-border shadow-xl px-5 py-3 whitespace-nowrap">
        <span class="size-2 rounded-full bg-destructive shrink-0 animate-pulse"></span>
        <p class="text-[12px] font-medium">
          Click para añadir vértices
          <span class="text-[11px] text-muted-foreground"> · doble&nbsp;click para finalizar</span>
        </p>
        <span id="draw-count" class="text-[11px] font-bold px-2 py-0.5 rounded-full" style="background:#4E070715;color:#4E0707;">0 pts</span>
        <div class="flex gap-2">
          <button id="draw-finish-btn"
            class="rounded-md px-3 py-1.5 text-[11px] font-semibold text-white transition-colors hover:opacity-90"
            style="background:#4E0707;">Confirmar</button>
          <button id="draw-cancel-draw"
            class="rounded-md border border-input bg-background px-3 py-1.5 text-[11px] font-medium hover:bg-muted/60 transition-colors">Cancelar</button>
        </div>
      </div>

      <!-- ── AI assistant floating button ─────────────────────── -->
      <button id="btn-open-ai"
        class="absolute bottom-6 right-4 z-1000 flex items-center gap-2 rounded-xl bg-card border border-border shadow-lg px-3.5 py-2 text-[12px] font-semibold hover:bg-muted/60 hover:shadow-xl transition-all">
        <span class="size-2 rounded-full bg-primary shrink-0 animate-pulse"></span>
        Asistente IA
      </button>
    </div>

    <!-- ── AI chat panel ─────────────────────────────────────────── -->
    <aside id="ai-panel" class="hidden w-80 shrink-0 border-l border-border bg-card flex-col overflow-hidden">

      <!-- Panel header -->
      <div class="px-4 py-3 border-b border-border flex items-center justify-between shrink-0">
        <div class="flex items-center gap-2">
          <span class="size-2 rounded-full bg-primary shrink-0 animate-pulse"></span>
          <span class="text-sm font-semibold">Asistente de Viñedo</span>
        </div>
        <button id="btn-close-ai"
          class="size-7 rounded-md text-muted-foreground hover:bg-muted/60 hover:text-foreground flex items-center justify-center transition-colors text-sm">
          ✕
        </button>
      </div>

      <!-- Messages area -->
      <div id="ai-messages" class="flex-1 overflow-y-auto p-4">

        <!-- Empty / welcome state -->
        <div id="ai-empty" class="flex flex-col items-center text-center gap-3 pt-6 pb-2">
          <div class="size-14 rounded-2xl flex items-center justify-center text-2xl" style="background:#c9644215;">🍇</div>
          <div>
            <p class="text-sm font-semibold">Preguntame sobre las fincas</p>
            <p class="text-[11px] text-muted-foreground mt-1 leading-relaxed">
              Cruzo datos de NDVI, humedad y maduración para recomendarte las mejores parcelas para cada vino.
            </p>
          </div>
          <div class="w-full space-y-1.5 mt-1">
            <button class="ai-suggestion w-full text-left rounded-lg border border-border px-3 py-2 text-[11px] text-muted-foreground hover:bg-muted/50 hover:text-foreground hover:border-primary/30 transition-colors leading-relaxed">
              ¿Qué parcelas recomendás para el próximo lote de Old Vines From Patagonia?
            </button>
            <button class="ai-suggestion w-full text-left rounded-lg border border-border px-3 py-2 text-[11px] text-muted-foreground hover:bg-muted/50 hover:text-foreground hover:border-primary/30 transition-colors leading-relaxed">
              ¿Cuáles tienen la mejor maduración hoy?
            </button>
            <button class="ai-suggestion w-full text-left rounded-lg border border-border px-3 py-2 text-[11px] text-muted-foreground hover:bg-muted/50 hover:text-foreground hover:border-primary/30 transition-colors leading-relaxed">
              ¿Hay alguna parcela en estado crítico que necesite atención?
            </button>
            <button class="ai-suggestion w-full text-left rounded-lg border border-border px-3 py-2 text-[11px] text-muted-foreground hover:bg-muted/50 hover:text-foreground hover:border-primary/30 transition-colors leading-relaxed">
              Comparame las parcelas de Malbec por nivel de maduración.
            </button>
          </div>
        </div>
      </div>

      <!-- Input area -->
      <div class="p-3 border-t border-border shrink-0">
        <div class="flex gap-2 items-end">
          <textarea
            id="ai-input"
            rows="2"
            placeholder="¿Qué parcelas para el próximo Malbec?"
            class="flex-1 resize-none rounded-lg border border-input bg-background px-3 py-2 text-[12px] placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring transition-shadow"
          ></textarea>
          <button
            id="ai-send"
            class="size-9 rounded-lg bg-primary text-primary-foreground flex items-center justify-center hover:bg-primary/90 transition-colors shrink-0 disabled:opacity-50 disabled:pointer-events-none"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
              <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <p class="text-[10px] text-muted-foreground mt-1.5">Cmd+Enter para enviar · indicadores simulados</p>
      </div>
    </aside>

  </div>
</AppLayout>

<!-- ── Plot form modal ─────────────────────────────────────── -->
<div id="modal-plot" class="hidden fixed inset-0 z-2000 items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-card border border-border rounded-2xl shadow-xl w-full max-w-lg mx-4 p-6">
    <h2 id="modal-title" class="text-base font-semibold mb-4">Nueva Parcela</h2>
    <div class="grid grid-cols-2 gap-3">
      <div class="col-span-2">
        <label class="text-sm font-medium">Nombre <span class="text-destructive">*</span></label>
        <input id="f-name" type="text" placeholder="ej: Parcela Noreste"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <div>
        <label class="text-sm font-medium">Varietal</label>
        <input id="f-variety" type="text" placeholder="ej: Malbec"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <div>
        <label class="text-sm font-medium">Estado</label>
        <select id="f-status" class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
          <option value="healthy">Saludable</option>
          <option value="attention">Atención</option>
          <option value="critical">Crítico</option>
        </select>
      </div>
      <div>
        <label class="text-sm font-medium flex items-center gap-2">
          Hectáreas
          <span id="ha-auto-badge" class="hidden text-[9px] font-bold px-1.5 py-0.5 rounded-full" style="background:#22C55E18;color:#16A34A;border:1px solid #22C55E40;">auto</span>
        </label>
        <input id="f-ha" type="number" step="0.01" min="0" value="1.0"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <div>
        <label class="text-sm font-medium">Años cepa</label>
        <input id="f-age" type="number" min="0" value="10"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>

      <!-- Polygon draw control -->
      <div class="col-span-2">
        <label class="text-sm font-medium">Polígono</label>
        <div id="poly-status" class="mt-1 flex items-center gap-3 rounded-md border border-input bg-muted/30 px-3 py-2.5">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-4 shrink-0 text-muted-foreground">
            <path d="M3 21l18-9L3 3v7l13 2-13 2z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <p id="poly-status-text" class="flex-1 text-[12px] text-muted-foreground">Sin polígono — dibujá en el mapa</p>
          <button id="btn-start-draw"
            class="rounded-md px-3 py-1 text-[11px] font-semibold border transition-colors hover:opacity-90"
            style="background:#4E0707;color:#F5F0EB;border-color:#4E0707;">
            Dibujar
          </button>
        </div>
      </div>
    </div>

    <p id="form-error" class="hidden text-xs text-destructive mt-3"></p>
    <div class="flex justify-end gap-2 mt-5">
      <button id="modal-cancel" class="rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-muted/60 transition-colors">Cancelar</button>
      <button id="modal-save" class="rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors">Guardar</button>
    </div>
  </div>
</div>

<!-- SSR data hydration -->
<script id="ssr-plots" type="application/json" is:inline set:html={JSON.stringify(plots)}></script>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>

<script>
  // ─── Types ───────────────────────────────────────────────────
  type LatLng = { lat: number; lng: number };
  type Plot = { id: string; name: string; variety: string; ha: number; age: number; status: string; polygon: LatLng[] };

  // ─── SSR hydration ───────────────────────────────────────────
  const _ssrEl = document.getElementById("ssr-plots");
  const _initialPlots: Plot[] = _ssrEl ? JSON.parse(_ssrEl.textContent || "[]") : [];

  // ─── Global state ────────────────────────────────────────────
  let map: any;
  let _L: any;
  let _plots: Plot[] = _initialPlots;
  let polygonLayers: { layer: any; plot: Plot }[] = [];
  let selectedPlotId: string | null = null;
  let editingPlotId: string | null = null;
  let heatmapMode = false;
  let activeIndicator: string = "ndvi";

  // ─── Geodesic area (Shoelace on local projection) ────────────
  function computeHectares(points: [number, number][]): number {
    if (points.length < 3) return 0;
    const latMeanRad = (points.reduce((s, p) => s + p[0], 0) / points.length) * Math.PI / 180;
    const mLat = 111320;
    const mLng = 111320 * Math.cos(latMeanRad);
    const xy = points.map(([lat, lng]) => [lat * mLat, lng * mLng] as [number, number]);
    let area = 0;
    const n = xy.length;
    for (let i = 0; i < n; i++) {
      const [x1, y1] = xy[i];
      const [x2, y2] = xy[(i + 1) % n];
      area += x1 * y2 - x2 * y1;
    }
    return Math.round((Math.abs(area) / 2 / 10000) * 100) / 100;
  }

  // ─── Indicator config ────────────────────────────────────────
  type IndicatorCfg = { min: number; max: number; unit: string; minLabel: string; midLabel: string; maxLabel: string; palette: [number,number,number][] };
  const INDICATOR_CFG: Record<string, IndicatorCfg> = {
    // palette: stops ordered low→high, each stop = [R,G,B]
    temperature: {
      min: -5, max: 45, unit: "°C", minLabel: "-5°C", midLabel: "20°C", maxLabel: "45°C",
      palette: [[148,0,211],[0,0,255],[0,150,255],[0,255,255],[0,220,0],[200,255,0],[255,255,0],[255,165,0],[255,60,0],[200,0,0]],
    },
    moisture: {
      min: 10, max: 100, unit: "%HR", minLabel: "10%", midLabel: "55%", maxLabel: "100%",
      palette: [[200,0,0],[255,100,0],[255,200,0],[150,255,50],[0,200,100],[0,150,255],[0,60,255],[80,0,180]],
    },
    ndvi: {
      min: 0, max: 1, unit: "NDVI", minLabel: "0.0", midLabel: "0.5", maxLabel: "1.0",
      palette: [[180,50,0],[220,120,0],[255,220,0],[120,200,0],[0,160,0],[0,100,0]],
    },
    maturity: {
      min: 0, max: 100, unit: "%", minLabel: "0%", midLabel: "50%", maxLabel: "100%",
      palette: [[100,0,180],[0,80,255],[0,200,200],[0,200,0],[200,220,0],[255,160,0],[200,0,0]],
    },
  };

  function paletteRGB(t: number, palette: [number,number,number][]): [number,number,number] {
    const n = palette.length - 1;
    const pos = Math.max(0, Math.min(1, t)) * n;
    const i = Math.min(Math.floor(pos), n - 1);
    const f = pos - i;
    const a = palette[i], b = palette[i + 1];
    return [
      Math.round(a[0] + f * (b[0] - a[0])),
      Math.round(a[1] + f * (b[1] - a[1])),
      Math.round(a[2] + f * (b[2] - a[2])),
    ];
  }
  function paletteCSS(t: number, cfg: IndicatorCfg): string {
    const [r,g,b] = paletteRGB(t, cfg.palette);
    return `rgb(${r},${g},${b})`;
  }
  function heatColor(value: number, cfg: IndicatorCfg): string {
    return paletteCSS(Math.max(0, Math.min(1, (value - cfg.min) / (cfg.max - cfg.min))), cfg);
  }

  // ─── Weather canvas overlay (IDW interpolation) ──────────────
  // Resolution: one sample per RES screen pixels → blurry/smooth look
  const CANVAS_RES = 6;
  let _canvasEl: HTMLCanvasElement | null = null;
  let _canvasVisible = false;

  function getOrCreateCanvas(): HTMLCanvasElement {
    if (!_canvasEl) {
      _canvasEl = document.createElement("canvas");
      _canvasEl.style.cssText = "position:absolute;top:0;left:0;pointer-events:none;image-rendering:pixelated;";
      // Insert BEFORE leaflet-map-pane so all Leaflet layers (markers, polygons) render on top
      const mapPane = map.getContainer().querySelector(".leaflet-map-pane");
      map.getContainer().insertBefore(_canvasEl, mapPane);
      map.on("moveend zoomend resize", () => { if (_canvasVisible) renderWeatherCanvas(); });
    }
    return _canvasEl;
  }

  function showCanvas() { _canvasVisible = true; if (_canvasEl) _canvasEl.style.display = "block"; }
  function hideCanvas() { _canvasVisible = false; if (_canvasEl) _canvasEl.style.display = "none"; }

  // Render full-map IDW heatmap
  function renderWeatherCanvas(pts?: Array<{lat:number;lng:number;value:number}>, cfg?: IndicatorCfg) {
    if (!map || !_L) return;
    const canvas  = getOrCreateCanvas();
    const container = map.getContainer() as HTMLElement;
    const W = container.offsetWidth;
    const H = container.offsetHeight;
    canvas.style.width  = W + "px";
    canvas.style.height = H + "px";

    const cw = Math.ceil(W / CANVAS_RES);
    const ch = Math.ceil(H / CANVAS_RES);
    canvas.width  = cw;
    canvas.height = ch;

    const points = pts ?? _lastWeatherPts;
    const icfg   = cfg ?? _lastWeatherCfg;
    if (!points?.length || !icfg) return;

    // Adaptive normalization: stretch palette to actual data range
    // with a minimum spread so subtle variations are visible
    const rawMin = Math.min(...points.map(p => p.value));
    const rawMax = Math.max(...points.map(p => p.value));
    const spread = Math.max(rawMax - rawMin, (icfg.max - icfg.min) * 0.08);
    const mid    = (rawMin + rawMax) / 2;
    const normMin = mid - spread / 2;
    const normMax = mid + spread / 2;

    const ctx = canvas.getContext("2d")!;
    const img = ctx.createImageData(cw, ch);

    for (let py = 0; py < ch; py++) {
      for (let px = 0; px < cw; px++) {
        const ll  = map.containerPointToLatLng([px * CANVAS_RES + CANVAS_RES / 2, py * CANVAS_RES + CANVAS_RES / 2]);
        let num = 0, den = 0;
        for (const p of points) {
          const d2 = (ll.lat - p.lat) ** 2 + (ll.lng - p.lng) ** 2;
          if (d2 < 1e-12) { num = p.value * 1e12; den = 1e12; break; }
          const w = 1 / d2;
          num += w * p.value; den += w;
        }
        const val = den ? num / den : normMin;
        const t   = Math.max(0, Math.min(1, (val - normMin) / (normMax - normMin)));
        const [r, g, b] = paletteRGB(t, icfg.palette);
        const i = (py * cw + px) * 4;
        img.data[i]   = r;
        img.data[i+1] = g;
        img.data[i+2] = b;
        img.data[i+3] = 110;
      }
    }
    ctx.putImageData(img, 0, 0);
    showCanvas();
  }

  // Cache last rendered data so map pan/zoom can re-render
  let _lastWeatherPts: Array<{lat:number;lng:number;value:number}> | null = null;
  let _lastWeatherCfg: IndicatorCfg | null = null;

  // ─── Fetch grid from Open-Meteo ──────────────────────────────
  let _weatherPending = false;

  async function fetchWeatherGrid(indicator: "temperature" | "moisture") {
    if (_weatherPending) return;
    _weatherPending = true;
    setWeatherLoadingUI(true);

    // Grid siempre grande (±8° ≈ 1600km) — captura gradientes regionales sin importar el zoom
    const center = map.getCenter();
    const SPAN   = 8.0;
    const STEPS  = 7;
    const grid: Array<{lat: number; lng: number}> = [];
    for (let r = 0; r < STEPS; r++) {
      for (let c = 0; c < STEPS; c++) {
        grid.push({
          lat: center.lat - SPAN + (r / (STEPS - 1)) * 2 * SPAN,
          lng: center.lng - SPAN + (c / (STEPS - 1)) * 2 * SPAN,
        });
      }
    }

    const results = await Promise.allSettled(
      grid.map(async ({ lat, lng }) => {
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat.toFixed(4)}&longitude=${lng.toFixed(4)}&current=temperature_2m,relative_humidity_2m&forecast_days=1&timezone=auto`;
        const res  = await fetch(url);
        const data = await res.json();
        const value = indicator === "temperature"
          ? data.current.temperature_2m
          : data.current.relative_humidity_2m;
        return { lat, lng, value: value as number };
      })
    );

    const pts = results
      .filter((r) => r.status === "fulfilled")
      .map((r) => (r as PromiseFulfilledResult<{lat:number;lng:number;value:number}>).value);

    _weatherPending = false;
    setWeatherLoadingUI(false);

    if (!pts.length) return;
    const cfg = INDICATOR_CFG[indicator];
    _lastWeatherPts = pts;
    _lastWeatherCfg = cfg;
    renderWeatherCanvas(pts, cfg);
    updateStyles();
    renderIndicatorMarkers();
    if (_currentPlot) openInfowindow(_plots.find((p) => p.id === _currentPlot!.id) ?? _currentPlot);
  }

  // Keep a per-plot weather value for infowindow (nearest grid point)
  function nearestGridValue(plot: Plot): number | null {
    if (!_lastWeatherPts?.length) return null;
    const c = plotCentroid(plot);
    if (!c) return null;
    let best = Infinity, val = 0;
    for (const p of _lastWeatherPts) {
      const d = (c[0] - p.lat) ** 2 + (c[1] - p.lng) ** 2;
      if (d < best) { best = d; val = p.value; }
    }
    return val;
  }

  function setWeatherLoadingUI(loading: boolean) {
    const el = document.getElementById("weather-loading");
    if (el) el.style.display = loading ? "flex" : "none";
  }

  function plotCentroid(plot: Plot): [number, number] | null {
    if (!plot.polygon?.length) return null;
    const lat = plot.polygon.reduce((s, p) => s + p.lat, 0) / plot.polygon.length;
    const lng = plot.polygon.reduce((s, p) => s + p.lng, 0) / plot.polygon.length;
    return [lat, lng];
  }

  // ─── Deterministic fallback for non-weather indicators ───────
  function strHash(s: string): number {
    let h = 0;
    for (let i = 0; i < s.length; i++) h = (Math.imul(31, h) + s.charCodeAt(i)) | 0;
    return Math.abs(h);
  }
  function indicatorValue(plot: Plot, indicator: string): number {
    const cfg = INDICATOR_CFG[indicator];
    if (!cfg) return 0;
    // For weather indicators use nearest grid point
    if (indicator === "temperature" || indicator === "moisture") {
      const v = nearestGridValue(plot);
      if (v !== null) return v;
    }
    const seed = strHash(plot.id + indicator);
    return cfg.min + ((seed % 1000) / 1000) * (cfg.max - cfg.min);
  }

  // AI highlight state
  let aiHighlightedIds: string[] = [];
  let _glowInterval: ReturnType<typeof setInterval> | null = null;

  // Draw state
  let drawActive = false;       // true while user is clicking vertices
  let drawPoints: [number, number][] = [];
  let drawPolyline: any = null;
  let drawPreviewLine: any = null;  // line from last point to cursor
  let drawMarkers: any[] = [];
  let drawCloseMarker: any = null;  // hover-snap circle on first vertex

  // ─── Helpers ─────────────────────────────────────────────────
  function showModal(el: HTMLElement) { el.classList.remove("hidden"); el.classList.add("flex"); }
  function hideModal(el: HTMLElement) { el.classList.add("hidden");    el.classList.remove("flex"); }

  const statusColor: Record<string, string> = {
    healthy:   "#22C55E",
    attention: "#F59E0B",
    critical:  "#EF4444",
  };
  function plotFill(p: Plot) { return statusColor[p.status] ?? "#4E0707"; }

  // ─── API helpers ─────────────────────────────────────────────
  async function apiGetPlots(): Promise<Plot[]> {
    const r = await fetch("/api/vineyard");
    if (!r.ok) throw new Error(await r.text());
    return r.json();
  }
  async function apiSavePlot(data: Omit<Plot, "id">): Promise<Plot> {
    const r = await fetch("/api/vineyard", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });
    if (!r.ok) { const b = await r.json(); throw new Error(b.error ?? "Error"); }
    return r.json();
  }
  async function apiUpdatePlot(id: string, data: Omit<Plot, "id">): Promise<Plot> {
    const r = await fetch(`/api/vineyard/${id}`, { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });
    if (!r.ok) { const b = await r.json(); throw new Error(b.error ?? "Error"); }
    return r.json();
  }
  async function apiDeletePlot(id: string): Promise<void> {
    const r = await fetch(`/api/vineyard/${id}`, { method: "DELETE" });
    if (!r.ok && r.status !== 204) throw new Error("Error al eliminar");
  }

  // ─── Sidebar list ────────────────────────────────────────────
  function renderList(plots: Plot[]) {
    const list = document.getElementById("plot-list")!;
    list.innerHTML = "";
    document.getElementById("total-ha")!.textContent   = `${plots.reduce((s, p) => s + p.ha, 0).toFixed(1)} ha`;
    document.getElementById("total-plots")!.textContent = String(plots.length);
    plots.forEach((plot) => {
      const btn = document.createElement("button");
      btn.className = "plot-list-item w-full text-left px-4 py-3 hover:bg-muted/50 transition-colors flex items-start gap-3 border-l-2";
      btn.dataset.plotId = plot.id;
      btn.style.borderColor = "transparent";
      btn.innerHTML = `
        <div class="size-8 rounded-lg shrink-0 flex items-center justify-center text-white text-[10px] font-bold" style="background:${plotFill(plot)};">
          ${plot.name.slice(0, 2).toUpperCase()}
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-[12px] font-semibold leading-tight truncate">${plot.name}</p>
          <p class="text-[10px] text-muted-foreground mt-0.5">${plot.variety} · ${plot.ha} ha · ${plot.age} años</p>
        </div>
        <span class="shrink-0 size-2 rounded-full mt-1.5" style="background:${plotFill(plot)};"></span>`;
      btn.addEventListener("click", () => {
        openInfowindow(plot);
        const entry = polygonLayers.find(({ plot: p }) => p.id === plot.id);
        if (entry && map) map.fitBounds(entry.layer.getBounds().pad(0.3));
      });
      list.appendChild(btn);
    });
  }

  // ─── Indicator label markers ─────────────────────────────────
  let indicatorMarkers: any[] = [];

  function clearIndicatorMarkers() {
    indicatorMarkers.forEach((m) => m.remove());
    indicatorMarkers = [];
  }

  function renderIndicatorMarkers() {
    clearIndicatorMarkers();
    if (!heatmapMode || !_L) return;
    const cfg = INDICATOR_CFG[activeIndicator];
    if (!cfg) return;

    polygonLayers.forEach(({ layer, plot }) => {
      const val   = indicatorValue(plot, activeIndicator);
      const color = heatColor(val, cfg);
      const isReal = (activeIndicator === "temperature" || activeIndicator === "moisture") && nearestGridValue(plot) !== null;
      const label = `${val.toFixed(1)}${cfg.unit}`;


      const icon = _L.divIcon({
        className: "",
        html: `<div style="
          background:rgba(8,8,8,0.88);
          backdrop-filter:blur(8px);
          -webkit-backdrop-filter:blur(8px);
          border-radius:12px;
          padding:7px 13px 6px;
          white-space:nowrap;
          box-shadow:0 4px 18px rgba(0,0,0,0.6);
          border:1.5px solid ${color}55;
          font-family:Inter,sans-serif;
          text-align:center;
          min-width:70px;
        ">
          <div style="font-size:9px;font-weight:700;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:.08em;margin-bottom:1px;">${plot.name}</div>
          <div style="font-size:18px;font-weight:900;color:${color};line-height:1.1;letter-spacing:-.5px;">${label}</div>
          ${isReal ? `<div style="font-size:8px;color:rgba(255,255,255,0.28);margin-top:2px;letter-spacing:.04em;">en vivo 🌐</div>` : `<div style="font-size:8px;color:rgba(255,255,255,0.2);margin-top:2px;">estimado</div>`}
        </div>`,
        iconAnchor: [43, 36],
      });

      const center = layer.getBounds().getCenter();
      const marker = _L.marker(center, { icon, interactive: false, zIndexOffset: 500 }).addTo(map);
      indicatorMarkers.push(marker);
    });
  }

  // ─── Polygon rendering ───────────────────────────────────────
  let nameLabelMarkers: any[] = [];

  function clearPolygons() {
    polygonLayers.forEach(({ layer }) => layer.remove());
    polygonLayers = [];
    nameLabelMarkers.forEach((m) => m.remove());
    nameLabelMarkers = [];
  }

  function updateNameLabels() {
    nameLabelMarkers.forEach((m) => {
      const el = m.getElement?.();
      if (el) el.style.display = heatmapMode ? "none" : "";
    });
  }

  function renderPolygons(plots: Plot[], L: any) {
    clearPolygons();
    plots.forEach((plot) => {
      if (!plot.polygon?.length) return;
      const coords = plot.polygon.map((ll) => [ll.lat, ll.lng] as [number, number]);
      const fill = plotFill(plot);
      const layer = L.polygon(coords, { fillColor: fill, fillOpacity: 0.45, color: fill, weight: 1.5, opacity: 0.8 }).addTo(map);
      const lbl = L.divIcon({
        className: "",
        html: `<div style="background:rgba(28,8,8,0.75);color:#F5F0EB;font-size:10px;font-weight:700;padding:2px 6px;border-radius:4px;white-space:nowrap;font-family:Inter,sans-serif;">${plot.name}</div>`,
        iconAnchor: [30, 10],
      });
      const nameMarker = L.marker(layer.getBounds().getCenter(), { icon: lbl, interactive: false }).addTo(map);
      nameLabelMarkers.push(nameMarker);
      layer.on("click", () => openInfowindow(plot));
      layer.on("mouseover", () => { if (plot.id !== selectedPlotId) layer.setStyle({ fillOpacity: 0.65, weight: 2 }); });
      layer.on("mouseout",  () => updateStyles());
      polygonLayers.push({ layer, plot });
    });
    updateStyles();
    updateNameLabels();
  }

  function updateStyles() {
    polygonLayers.forEach(({ layer, plot }) => {
      const sel  = plot.id === selectedPlotId;
      const glow = aiHighlightedIds.includes(plot.id);
      if (glow) {
        layer.setStyle({ fillColor: "#c96442", fillOpacity: 0.60, color: "#c96442", weight: 3, opacity: 1 });
        layer.bringToFront();
        return;
      }
      if (heatmapMode && (activeIndicator === "temperature" || activeIndicator === "moisture")) {
        // Canvas covers the map — polygons: white border + subtle white fill to stand out
        layer.setStyle({ fillColor: "#fff", fillOpacity: sel ? 0.18 : 0.10, color: "#fff", weight: sel ? 3.5 : 2.5, opacity: 1, dashArray: sel ? "" : "6 4" });
      } else if (heatmapMode) {
        const cfg  = INDICATOR_CFG[activeIndicator];
        const fill = cfg ? heatColor(indicatorValue(plot, activeIndicator), cfg) : plotFill(plot);
        layer.setStyle({ fillColor: fill, fillOpacity: sel ? 0.85 : 0.65, color: sel ? "#fff" : fill, weight: sel ? 2.5 : 1.5, opacity: 0.9 });
      } else {
        const fill = plotFill(plot);
        layer.setStyle({ fillColor: fill, fillOpacity: sel ? 0.75 : 0.45, color: sel ? "#f5f4ed" : fill, weight: sel ? 2.5 : 1.5, opacity: 0.9 });
      }
    });
  }

  // ─── Infowindow ──────────────────────────────────────────────
  let _currentPlot: Plot | null = null;

  function openInfowindow(plot: Plot) {
    _currentPlot = plot; selectedPlotId = plot.id; updateStyles();
    document.getElementById("iw-name")!.textContent    = plot.name;
    document.getElementById("iw-variety")!.textContent = plot.variety;
    document.getElementById("iw-ha")!.textContent      = `${plot.ha} ha`;
    document.getElementById("iw-age")!.textContent     = `${plot.age} a.`;
    const statEl = document.getElementById("iw-stat")!;
    statEl.textContent = plot.status === "healthy" ? "✓ OK" : plot.status === "attention" ? "⚠" : "✗";
    statEl.style.color = plotFill(plot);
    // Indicator row
    const iwRow = document.getElementById("iw-indicator-row") as HTMLElement;
    if (heatmapMode) {
      const cfg = INDICATOR_CFG[activeIndicator];
      const val = indicatorValue(plot, activeIndicator);
      document.getElementById("iw-indicator-label")!.textContent = cfg ? `${activeIndicator === "temperature" ? "Temperatura" : activeIndicator === "moisture" ? "Humedad" : activeIndicator === "ndvi" ? "NDVI" : "Maduración"}` : activeIndicator;
      const valEl = document.getElementById("iw-indicator-value") as HTMLElement;
      const isReal = (activeIndicator === "temperature" || activeIndicator === "moisture") && nearestGridValue(plot) !== null;
      valEl.textContent = cfg ? `${val.toFixed(1)} ${cfg.unit}${isReal ? " 🌐" : " ~"}` : String(val);
      valEl.style.color = cfg ? heatColor(val, cfg) : "";
      iwRow.style.display = "flex";
    } else {
      iwRow.style.display = "none";
    }
    document.getElementById("infowindow")!.classList.remove("hidden");
    document.querySelectorAll<HTMLElement>(".plot-list-item").forEach((b) => {
      const a = b.dataset.plotId === plot.id;
      b.style.borderColor = a ? "#4E0707" : "transparent";
      b.style.background  = a ? "rgba(78,7,7,0.06)" : "";
    });
  }

  function closeInfowindow() {
    _currentPlot = null; selectedPlotId = null; updateStyles();
    document.getElementById("infowindow")!.classList.add("hidden");
    document.querySelectorAll<HTMLElement>(".plot-list-item").forEach((b) => { b.style.borderColor = "transparent"; b.style.background = ""; });
  }

  document.getElementById("iw-close")!.addEventListener("click", closeInfowindow);
  document.getElementById("iw-delete")!.addEventListener("click", async () => {
    if (!_currentPlot) return;
    if (!confirm(`Eliminar parcela "${_currentPlot.name}"?`)) return;
    await apiDeletePlot(_currentPlot.id);
    closeInfowindow();
    await reloadMap();
  });

  // ─── Form modal ──────────────────────────────────────────────
  const modal    = document.getElementById("modal-plot")!;
  const fName    = document.getElementById("f-name")    as HTMLInputElement;
  const fVariety = document.getElementById("f-variety") as HTMLInputElement;
  const fStatus  = document.getElementById("f-status")  as HTMLSelectElement;
  const fHa      = document.getElementById("f-ha")      as HTMLInputElement;
  const fAge     = document.getElementById("f-age")     as HTMLInputElement;
  const formErr  = document.getElementById("form-error")!;

  // The polygon drawn interactively — stored here between draw session and save
  let pendingPolygon: LatLng[] = [];

  function updatePolyStatus() {
    const txt = document.getElementById("poly-status-text")!;
    const btn = document.getElementById("btn-start-draw")!;
    if (pendingPolygon.length >= 3) {
      txt.textContent = `✓ ${pendingPolygon.length} vértices capturados`;
      (txt as HTMLElement).style.color = "#22C55E";
      btn.textContent = "Redibujar";
    } else if (pendingPolygon.length > 0) {
      txt.textContent = `${pendingPolygon.length} vértice(s) — necesitás al menos 3`;
      (txt as HTMLElement).style.color = "#F59E0B";
      btn.textContent = "Redibujar";
    } else {
      txt.textContent = "Sin polígono — dibujá en el mapa";
      (txt as HTMLElement).style.color = "";
      btn.textContent = "Dibujar";
    }
  }

  function openNewForm() {
    editingPlotId = null; pendingPolygon = [];
    document.getElementById("modal-title")!.textContent = "Nueva Parcela";
    fName.value = ""; fVariety.value = ""; fStatus.value = "healthy";
    fHa.value = "1.0"; fAge.value = "10";
    formErr.classList.add("hidden");
    updatePolyStatus();
    showModal(modal);
  }

  function openEditForm(plot: Plot) {
    editingPlotId = plot.id;
    pendingPolygon = plot.polygon.slice();
    document.getElementById("modal-title")!.textContent = "Editar Parcela";
    fName.value = plot.name; fVariety.value = plot.variety; fStatus.value = plot.status;
    fHa.value = String(plot.ha); fAge.value = String(plot.age);
    formErr.classList.add("hidden");
    updatePolyStatus();
    showModal(modal);
  }

  fHa.addEventListener("input", () => document.getElementById("ha-auto-badge")!.classList.add("hidden"));

  document.getElementById("btn-new-plot")!.addEventListener("click", openNewForm);
  document.getElementById("iw-edit")!.addEventListener("click", () => { if (_currentPlot) openEditForm(_currentPlot); });
  document.getElementById("modal-cancel")!.addEventListener("click", () => { hideModal(modal); stopDraw(); });
  modal.addEventListener("click", (e) => { if (e.target === modal) { hideModal(modal); stopDraw(); } });

  document.getElementById("modal-save")!.addEventListener("click", async () => {
    formErr.classList.add("hidden");
    const name = fName.value.trim();
    if (!name) { formErr.textContent = "El nombre es obligatorio."; formErr.classList.remove("hidden"); return; }
    if (pendingPolygon.length < 3) { formErr.textContent = "Dibujá al menos 3 vértices en el mapa."; formErr.classList.remove("hidden"); return; }
    const data = { name, variety: fVariety.value, ha: parseFloat(fHa.value) || 0, age: parseInt(fAge.value) || 0, status: fStatus.value, polygon: pendingPolygon };
    try {
      editingPlotId ? await apiUpdatePlot(editingPlotId, data) : await apiSavePlot(data);
      hideModal(modal); stopDraw();
      await reloadMap();
      // Fit to the saved polygon
      if (_L && pendingPolygon.length >= 3) {
        map.fitBounds(_L.latLngBounds(pendingPolygon.map(ll => [ll.lat, ll.lng])).pad(0.3));
      }
      pendingPolygon = [];
    } catch (e: any) {
      formErr.textContent = e.message ?? "Error al guardar."; formErr.classList.remove("hidden");
    }
  });

  // ─── Interactive polygon draw ─────────────────────────────────
  // Flow: click "Dibujar" → modal hides (z collapses), draw toolbar appears,
  //       user clicks vertices on map; double-click OR "Confirmar" closes draw
  //       and reopens modal with captured polygon.

  const drawToolbar = document.getElementById("draw-toolbar")!;

  // Snapshot of form values preserved across the draw session
  let _savedForm: { name: string; variety: string; status: string; ha: string; age: string } | null = null;

  function saveFormState() {
    _savedForm = {
      name:    fName.value,
      variety: fVariety.value,
      status:  fStatus.value,
      ha:      fHa.value,
      age:     fAge.value,
    };
  }

  function restoreFormState() {
    if (!_savedForm) return;
    fName.value    = _savedForm.name;
    fVariety.value = _savedForm.variety;
    fStatus.value  = _savedForm.status;
    fHa.value      = _savedForm.ha;
    fAge.value     = _savedForm.age;
    _savedForm = null;
  }

  function startDraw() {
    if (!_L) return;
    saveFormState();          // ← preserve whatever the user typed
    drawPoints = [];
    clearDrawLayers();
    hideModal(modal);
    drawToolbar.classList.remove("hidden");
    drawToolbar.classList.add("flex");
    map.getContainer().style.cursor = "crosshair";
    drawActive = true;

    map.on("click",     onDrawClick);
    map.on("dblclick",  onDrawDblClick);
    map.on("mousemove", onDrawMouseMove);
  }

  function stopDraw() {
    drawActive = false;
    map?.off("click",     onDrawClick);
    map?.off("dblclick",  onDrawDblClick);
    map?.off("mousemove", onDrawMouseMove);
    map?.getContainer && (map.getContainer().style.cursor = "");
    clearDrawLayers();
    drawToolbar.classList.add("hidden");
    drawToolbar.classList.remove("flex");
  }

  function finishDraw() {
    if (drawPoints.length >= 3) {
      pendingPolygon = drawPoints.map(([lat, lng]) => ({ lat, lng }));
      if (_L && map) {
        map.fitBounds(_L.latLngBounds(drawPoints).pad(0.25));
      }
      // Auto-fill hectares from polygon area
      const ha = computeHectares(drawPoints);
      if (ha > 0) {
        restoreFormState();
        fHa.value = String(ha);
        document.getElementById("ha-auto-badge")!.classList.remove("hidden");
        stopDraw();
        updatePolyStatus();
        showModal(modal);
        return;
      }
    }
    stopDraw();
    restoreFormState();
    updatePolyStatus();
    showModal(modal);
  }

  function clearDrawLayers() {
    drawMarkers.forEach((m) => m.remove()); drawMarkers = [];
    if (drawPolyline)     { drawPolyline.remove();     drawPolyline = null; }
    if (drawPreviewLine)  { drawPreviewLine.remove();  drawPreviewLine = null; }
    if (drawCloseMarker)  { drawCloseMarker.remove();  drawCloseMarker = null; }
  }

  function onDrawClick(e: any) {
    if (!drawActive) return;
    // Snap-close: if within 15px of first point, finish
    if (drawPoints.length >= 3 && drawCloseMarker) {
      const firstLatLng = _L.latLng(drawPoints[0]);
      const dist = map.latLngToContainerPoint(firstLatLng).distanceTo(map.latLngToContainerPoint(e.latlng));
      if (dist < 15) { finishDraw(); return; }
    }
    const pt: [number, number] = [e.latlng.lat, e.latlng.lng];
    drawPoints.push(pt);

    // Vertex marker
    const vm = _L.circleMarker(pt, { radius: 5, fillColor: "#4E0707", fillOpacity: 1, color: "#fff", weight: 1.5, interactive: false }).addTo(map);
    drawMarkers.push(vm);

    // First-point close-snap indicator (shown after 2 more points)
    if (drawPoints.length === 1) {
      drawCloseMarker = _L.circleMarker(pt, { radius: 10, fillColor: "#4E0707", fillOpacity: 0, color: "#4E0707", weight: 1.5, dashArray: "3", interactive: false }).addTo(map);
    }

    // Solid polyline of placed vertices
    if (drawPolyline) drawPolyline.remove();
    drawPolyline = _L.polyline(drawPoints, { color: "#4E0707", weight: 2, opacity: 0.9 }).addTo(map);

    // Update toolbar counter
    document.getElementById("draw-count")!.textContent = `${drawPoints.length} pts`;
  }

  function onDrawDblClick(_e: any) {
    if (!drawActive) return;
    // Remove the last click that Leaflet fires before dblclick
    if (drawPoints.length > 0) drawPoints.pop();
    if (drawMarkers.length > 0) { drawMarkers[drawMarkers.length - 1].remove(); drawMarkers.pop(); }
    finishDraw();
  }

  function onDrawMouseMove(e: any) {
    if (!drawActive || drawPoints.length === 0) return;
    const last = drawPoints[drawPoints.length - 1];
    if (drawPreviewLine) drawPreviewLine.remove();
    drawPreviewLine = _L.polyline([last, [e.latlng.lat, e.latlng.lng]], { color: "#4E0707", weight: 1.5, opacity: 0.5, dashArray: "6" }).addTo(map);
  }

  document.getElementById("btn-start-draw")!.addEventListener("click", startDraw);
  document.getElementById("draw-finish-btn")!.addEventListener("click", finishDraw);
  document.getElementById("draw-cancel-draw")!.addEventListener("click", () => { stopDraw(); showModal(modal); });

  // ─── Heatmap mode ────────────────────────────────────────────
  function updateLegend(indicator: string) {
    const cfg = INDICATOR_CFG[indicator];
    if (!cfg) return;
    const stops = cfg.palette.map((c, i) => {
      const pct = Math.round((i / (cfg.palette.length - 1)) * 100);
      return `rgb(${c[0]},${c[1]},${c[2]}) ${pct}%`;
    }).join(", ");
    (document.getElementById("legend-gradient") as HTMLElement).style.background = `linear-gradient(to right, ${stops})`;
    document.getElementById("legend-min")!.textContent  = cfg.minLabel;
    document.getElementById("legend-mid")!.textContent  = cfg.midLabel;
    document.getElementById("legend-max")!.textContent  = cfg.maxLabel;
    document.getElementById("legend-unit")!.textContent = cfg.unit;
  }

  function activateIndicator(indicator: string) {
    activeIndicator = indicator;
    updateLegend(indicator);

    const isWeather = indicator === "temperature" || indicator === "moisture";
    if (isWeather) {
      _lastWeatherPts = null;
      _lastWeatherCfg = null;
      clearIndicatorMarkers();
      fetchWeatherGrid(indicator as "temperature" | "moisture");
    } else {
      hideCanvas();
      _lastWeatherPts = null;
      _lastWeatherCfg = null;
      renderIndicatorMarkers();
    }
    updateStyles();
  }

  document.getElementById("btn-normal")!.addEventListener("click", () => {
    heatmapMode = false;
    hideCanvas();
    clearIndicatorMarkers();
    updateNameLabels();
    document.getElementById("legend-panel")!.classList.add("hidden");
    document.getElementById("btn-normal")!.style.cssText  = "background:#4E0707;color:#F5F0EB;border-color:#4E0707;";
    document.getElementById("btn-heatmap")!.style.cssText = "";
    updateStyles();
  });
  document.getElementById("btn-heatmap")!.addEventListener("click", () => {
    heatmapMode = true;
    updateLegend(activeIndicator);
    document.getElementById("legend-panel")!.classList.remove("hidden");
    document.getElementById("btn-heatmap")!.style.cssText = "background:#4E0707;color:#F5F0EB;border-color:#4E0707;";
    document.getElementById("btn-normal")!.style.cssText  = "";
    updateNameLabels();
    activateIndicator(activeIndicator);
    renderIndicatorMarkers();
  });
  document.getElementById("btn-mode-toggle")!.addEventListener("click", () => document.getElementById("btn-heatmap")!.click());
  document.querySelectorAll<HTMLElement>(".indicator-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      if (!heatmapMode) document.getElementById("btn-heatmap")!.click();
      activateIndicator(btn.dataset.indicator ?? "ndvi");
      document.querySelectorAll<HTMLElement>(".indicator-btn").forEach((b) => {
        b.style.background  = b === btn ? "#4E070710" : "";
        b.style.borderColor = b === btn ? "#4E0707"   : "";
        b.style.color       = b === btn ? "#4E0707"   : "";
      });
    });
  });

  // ─── Load + reload ───────────────────────────────────────────
  async function reloadMap() {
    try { _plots = await apiGetPlots(); } catch { _plots = []; }
    renderList(_plots);
    if (_L) { renderPolygons(_plots, _L); renderIndicatorMarkers(); }
  }

  async function initMap() {
    const L = (window as any).L;
    if (!L) return;
    _L = L;
    map = L.map("map", { center: [-38.93, -68.05], zoom: 14, zoomControl: false, attributionControl: false });
    L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}", { maxZoom: 19 }).addTo(map);
    L.control.attribution({ prefix: false, position: "bottomright" }).addTo(map);
    renderList(_plots);
    renderPolygons(_plots, L);
    if (_plots.length > 0 && polygonLayers.length > 0) {
      map.fitBounds(_L.featureGroup(polygonLayers.map(({ layer }) => layer)).getBounds().pad(0.15));
    }
  }

  const script = document.createElement("script");
  script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
  script.crossOrigin = "";
  script.onload = initMap;
  document.head.appendChild(script);

  document.getElementById("zoom-in")!.addEventListener("click",  () => map?.zoomIn());
  document.getElementById("zoom-out")!.addEventListener("click", () => map?.zoomOut());

  // ─── AI chat panel ───────────────────────────────────────────
  let aiHistory: { role: string; content: string }[] = [];

  // Highlight polygons with a pulsing glow
  function highlightPlots(ids: string[]) {
    if (_glowInterval) { clearInterval(_glowInterval); _glowInterval = null; }
    aiHighlightedIds = ids;
    updateStyles();

    if (!ids.length) return;

    // Smooth pulse animation on highlighted polygons
    let tick = 0;
    _glowInterval = setInterval(() => {
      tick++;
      const opacity = 0.55 + Math.sin(tick * 0.12) * 0.15;
      const weight  = 2.5  + Math.sin(tick * 0.12) * 0.6;
      polygonLayers.forEach(({ layer, plot }) => {
        if (aiHighlightedIds.includes(plot.id)) {
          layer.setStyle({ fillOpacity: opacity, weight });
        }
      });
    }, 50);

    // Fit map to highlighted plots
    if (_L) {
      const layers = ids
        .map((id) => polygonLayers.find(({ plot }) => plot.id === id)?.layer)
        .filter(Boolean);
      if (layers.length) map.fitBounds(_L.featureGroup(layers).getBounds().pad(0.3));
    }
  }

  // Append a message bubble to the chat
  function appendMessage(role: "user" | "assistant", text: string) {
    const container = document.getElementById("ai-messages")!;
    document.getElementById("ai-empty")?.remove();
    const wrap   = document.createElement("div");
    wrap.className = role === "user" ? "flex justify-end mb-3" : "flex justify-start mb-3";
    const bubble = document.createElement("div");
    bubble.className = role === "user"
      ? "max-w-[85%] rounded-2xl rounded-tr-sm px-3 py-2 text-[12px] leading-relaxed text-primary-foreground"
      : "max-w-[90%] rounded-2xl rounded-tl-sm px-3 py-2 text-[12px] leading-relaxed text-foreground";
    bubble.style.background = role === "user" ? "var(--primary)" : "var(--muted)";
    bubble.textContent = text;
    wrap.appendChild(bubble);
    container.appendChild(wrap);
    container.scrollTop = container.scrollHeight;
  }

  // Typing indicator
  function appendThinking() {
    const container = document.getElementById("ai-messages")!;
    const wrap = document.createElement("div");
    wrap.id = "ai-thinking";
    wrap.className = "flex justify-start mb-3";
    wrap.innerHTML = `
      <div class="rounded-2xl rounded-tl-sm px-3 py-2.5 flex items-center gap-1.5" style="background:var(--muted);">
        <span style="width:6px;height:6px;border-radius:50%;background:var(--muted-foreground);opacity:0.5;display:inline-block;animation:bounce 1.2s 0s infinite;"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:var(--muted-foreground);opacity:0.5;display:inline-block;animation:bounce 1.2s 0.2s infinite;"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:var(--muted-foreground);opacity:0.5;display:inline-block;animation:bounce 1.2s 0.4s infinite;"></span>
      </div>`;
    container.appendChild(wrap);
    container.scrollTop = container.scrollHeight;
  }

  // Banner showing which plots are lit on the map
  function appendHighlightBanner(ids: string[]) {
    const container = document.getElementById("ai-messages")!;
    const existing  = container.querySelector(".ai-highlight-banner");
    existing?.remove();

    if (!ids.length) return;
    const names = ids
      .map((id) => _plots.find((p) => p.id === id)?.name ?? id.slice(0, 8))
      .join(", ");
    const banner = document.createElement("div");
    banner.className = "ai-highlight-banner flex items-center gap-2 rounded-lg px-3 py-2 mb-3 text-[11px] border";
    banner.style.cssText = "border-color:#c9644230;background:#c9644210;";
    banner.innerHTML = `
      <span style="width:7px;height:7px;border-radius:50%;background:#c96442;flex-shrink:0;animation:pulse 2s infinite;"></span>
      <span style="color:#c96442;font-weight:600;">Iluminadas:</span>
      <span style="color:var(--muted-foreground);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${names}</span>
      <button id="btn-clear-hl" style="color:var(--muted-foreground);font-size:10px;flex-shrink:0;cursor:pointer;">Limpiar</button>`;
    container.appendChild(banner);
    container.scrollTop = container.scrollHeight;
    document.getElementById("btn-clear-hl")?.addEventListener("click", () => {
      highlightPlots([]);
      banner.remove();
    });
  }

  // Send a message to the vineyard AI
  async function sendAIMessage(text: string) {
    const msg = text.trim();
    if (!msg) return;

    const sendBtn = document.getElementById("ai-send") as HTMLButtonElement;
    const inputEl = document.getElementById("ai-input") as HTMLTextAreaElement;
    sendBtn.disabled = true;
    inputEl.value = "";

    appendMessage("user", msg);
    appendThinking();

    try {
      const res = await fetch("/api/maps/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          message: msg,
          plots:   _plots.map(({ id, name, variety, ha, age, status }) => ({ id, name, variety, ha, age, status })),
          history: aiHistory,
        }),
      });

      document.getElementById("ai-thinking")?.remove();

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        appendMessage("assistant", err.error ?? `Error ${res.status} al consultar el asistente.`);
        return;
      }

      const data = await res.json();
      appendMessage("assistant", data.message);
      aiHistory = data.history ?? aiHistory;

      if (data.highlight_plots?.length) {
        highlightPlots(data.highlight_plots);
        appendHighlightBanner(data.highlight_plots);
      }
    } catch {
      document.getElementById("ai-thinking")?.remove();
      appendMessage("assistant", "No pude conectarme con el asistente. Verificá que el servidor esté disponible.");
    } finally {
      sendBtn.disabled = false;
      inputEl.focus();
    }
  }

  // ── Panel toggle ─────────────────────────────────────────────
  const aiPanel = document.getElementById("ai-panel")!;

  function openAIPanel() {
    aiPanel.classList.remove("hidden");
    aiPanel.classList.add("flex");
    document.getElementById("ai-input")?.focus();
  }
  function closeAIPanel() {
    aiPanel.classList.add("hidden");
    aiPanel.classList.remove("flex");
  }

  document.getElementById("btn-open-ai")!.addEventListener("click",  openAIPanel);
  document.getElementById("btn-close-ai")!.addEventListener("click", closeAIPanel);

  // ── Send button & keyboard shortcut ─────────────────────────
  document.getElementById("ai-send")!.addEventListener("click", () => {
    sendAIMessage((document.getElementById("ai-input") as HTMLTextAreaElement).value);
  });

  document.getElementById("ai-input")!.addEventListener("keydown", (e: Event) => {
    const ke = e as KeyboardEvent;
    if ((ke.ctrlKey || ke.metaKey) && ke.key === "Enter") {
      ke.preventDefault();
      sendAIMessage((ke.target as HTMLTextAreaElement).value);
    }
  });

  // ── Quick suggestion buttons ─────────────────────────────────
  document.querySelectorAll<HTMLElement>(".ai-suggestion").forEach((btn) => {
    btn.addEventListener("click", () => {
      openAIPanel();
      sendAIMessage(btn.textContent?.trim() ?? "");
    });
  });
</script>

<style>
  .leaflet-container { background: #1A2E1A; font-family: Inter, sans-serif; }
  .leaflet-control-attribution { font-size: 9px; opacity: 0.5; background: transparent !important; color: #fff !important; }
  .leaflet-control-attribution a { color: #fff !important; }

  @keyframes bounce {
    0%, 80%, 100% { transform: translateY(0); }
    40%            { transform: translateY(-5px); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.4; }
  }
</style>
