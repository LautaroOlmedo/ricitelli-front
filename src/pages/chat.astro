---
import AppLayout from "@/layouts/AppLayout.astro";
---

<AppLayout title="Asistente IA">
  <div class="flex flex-col" style="height: calc(100vh - 0px);">

    <!-- ── Header ────────────────────────────────────────────── -->
    <header class="shrink-0 flex items-center justify-between px-6 py-3.5 border-b border-border bg-card/80 backdrop-blur-sm">
      <div class="flex items-center gap-2.5">
        <div class="size-7 rounded-md bg-primary flex items-center justify-center shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="size-3.5 text-primary-foreground">
            <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold">Asistente Ricitelli</span>
          <span id="status-dot" class="size-1.5 rounded-full bg-muted-foreground/40"></span>
          <span id="status-label" class="text-xs text-muted-foreground">listo</span>
        </div>
      </div>
      <button id="btn-clear"
        class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1.5 text-xs text-muted-foreground hover:bg-accent hover:text-foreground transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
          <path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Limpiar
      </button>
    </header>

    <!-- ── Messages ──────────────────────────────────────────── -->
    <div id="messages" class="flex-1 overflow-y-auto px-4 py-6 space-y-6">

      <!-- Empty state -->
      <div id="welcome" class="flex flex-col items-center py-16 gap-5 text-center">
        <div class="size-12 rounded-xl bg-primary/10 flex items-center justify-center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-6 text-primary">
            <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="space-y-1">
          <p class="font-semibold text-base">¿En qué te puedo ayudar?</p>
          <p class="text-sm text-muted-foreground max-w-xs">
            Preguntame sobre productos, pedidos o producción, o pedime que cree uno nuevo.
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-2">
          {["¿Qué productos hay?", "Listar pedidos de venta", "Resumen del sistema", "¿Cuántas órdenes de producción hay?"].map(s => (
            <button class="suggestion rounded-full border border-border bg-card px-3 py-1.5 text-xs text-muted-foreground hover:border-primary/40 hover:text-foreground hover:bg-accent transition-colors" data-text={s}>{s}</button>
          ))}
        </div>
      </div>

    </div>

    <!-- ── Input ─────────────────────────────────────────────── -->
    <div class="shrink-0 border-t border-border bg-card px-4 pt-3 pb-4">
      <form id="chat-form" class="flex items-end gap-2.5 max-w-2xl mx-auto">
        <textarea
          id="chat-input"
          rows="1"
          placeholder="Preguntá sobre productos, pedidos o producción…"
          class="flex-1 rounded-xl border border-input bg-background px-4 py-2.5 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring resize-none overflow-hidden transition-all"
          style="max-height:140px"
        ></textarea>
        <button type="submit" id="btn-send"
          class="shrink-0 size-9 rounded-xl bg-primary text-primary-foreground flex items-center justify-center hover:bg-primary/90 active:scale-95 transition-all disabled:opacity-40 disabled:pointer-events-none">
          <svg id="icon-send" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="size-4">
            <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg id="icon-spin" class="hidden size-4 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
        </button>
      </form>
      <p class="text-center text-[10px] text-muted-foreground/60 mt-2">
        ⌘↩ para enviar
      </p>
    </div>

  </div>
</AppLayout>

<!-- ── Prose styles ─────────────────────────────────────────── -->
<style>
  .prose { font-size: 0.875rem; line-height: 1.65; color: inherit; }
  .prose p { margin: 0 0 0.6em; }
  .prose p:last-child { margin-bottom: 0; }
  .prose strong { font-weight: 600; }
  .prose em { font-style: italic; }
  .prose ul { list-style: disc; padding-left: 1.4em; margin: 0.4em 0 0.6em; }
  .prose ol { list-style: decimal; padding-left: 1.4em; margin: 0.4em 0 0.6em; }
  .prose li { margin-bottom: 0.2em; }
  .prose li > p { margin: 0; }
  .prose h1 { font-size: 1.15em; font-weight: 700; margin: 0.8em 0 0.3em; }
  .prose h2 { font-size: 1.05em; font-weight: 600; margin: 0.7em 0 0.25em; }
  .prose h3 { font-size: 1em; font-weight: 600; margin: 0.6em 0 0.2em; }
  .prose code {
    font-family: ui-monospace, monospace;
    font-size: 0.82em;
    background: hsl(var(--muted));
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }
  .prose pre {
    background: hsl(var(--muted));
    border: 1px solid hsl(var(--border));
    border-radius: 8px;
    padding: 0.75em 1em;
    overflow-x: auto;
    margin: 0.6em 0;
  }
  .prose pre code { background: none; padding: 0; font-size: 0.8em; }
  .prose blockquote {
    border-left: 3px solid hsl(var(--border));
    padding-left: 0.85em;
    margin: 0.5em 0;
    color: hsl(var(--muted-foreground));
    font-style: italic;
  }
  .prose hr { border: none; border-top: 1px solid hsl(var(--border)); margin: 0.75em 0; }
  .prose a { color: hsl(var(--primary)); text-decoration: underline; }
  .prose table { width: 100%; border-collapse: collapse; margin: 0.6em 0; font-size: 0.85em; }
  .prose th { font-weight: 600; text-align: left; padding: 0.4em 0.75em; border-bottom: 2px solid hsl(var(--border)); }
  .prose td { padding: 0.35em 0.75em; border-bottom: 1px solid hsl(var(--border)); }

  /* Typing cursor */
  .typing-cursor::after {
    content: '▋';
    animation: blink 1s step-start infinite;
    font-size: 0.75em;
    opacity: 0.7;
  }
  @keyframes blink { 0%, 100% { opacity: 0.7; } 50% { opacity: 0; } }

  /* Tool chip */
  .tool-chip summary { list-style: none; }
  .tool-chip summary::-webkit-details-marker { display: none; }

  /* Fade-in for messages */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .msg-enter { animation: fadeUp 0.18s ease-out; }
</style>

<script>
  import { marked } from "marked";

  // Configure marked
  marked.setOptions({ breaks: true, gfm: true } as any);

  // ── State ─────────────────────────────────────────────────
  let history: any[] = [];
  let isLoading = false;

  // ── DOM ───────────────────────────────────────────────────
  const messagesEl  = document.getElementById("messages")!;
  const welcomeEl   = document.getElementById("welcome")!;
  const form        = document.getElementById("chat-form")!;
  const inputEl     = document.getElementById("chat-input") as HTMLTextAreaElement;
  const btnSend     = document.getElementById("btn-send") as HTMLButtonElement;
  const iconSend    = document.getElementById("icon-send")!;
  const iconSpin    = document.getElementById("icon-spin")!;
  const statusLabel = document.getElementById("status-label")!;
  const statusDot   = document.getElementById("status-dot")!;

  // ── Textarea auto-resize ──────────────────────────────────
  inputEl.addEventListener("input", () => {
    inputEl.style.height = "auto";
    inputEl.style.height = Math.min(inputEl.scrollHeight, 140) + "px";
  });

  // ── Suggestions ───────────────────────────────────────────
  document.querySelectorAll<HTMLElement>(".suggestion").forEach(btn => {
    btn.addEventListener("click", () => {
      inputEl.value = btn.dataset.text ?? "";
      inputEl.dispatchEvent(new Event("input"));
      inputEl.focus();
    });
  });

  // ── Clear ─────────────────────────────────────────────────
  document.getElementById("btn-clear")!.addEventListener("click", () => {
    history = [];
    messagesEl.innerHTML = "";
    messagesEl.appendChild(welcomeEl);
    welcomeEl.style.display = "";
    inputEl.value = "";
    inputEl.style.height = "auto";
  });

  // ── Helpers ───────────────────────────────────────────────
  const scroll = () =>
    messagesEl.scrollTo({ top: messagesEl.scrollHeight, behavior: "smooth" });

  function setLoading(on: boolean) {
    isLoading = on;
    btnSend.disabled = on;
    iconSend.classList.toggle("hidden", on);
    iconSpin.classList.toggle("hidden", !on);
    inputEl.disabled = on;
    if (on) {
      statusLabel.textContent = "pensando…";
      statusDot.className = "size-1.5 rounded-full bg-amber-400 animate-pulse";
    } else {
      statusLabel.textContent = "listo";
      statusDot.className = "size-1.5 rounded-full bg-green-400";
      setTimeout(() => {
        statusDot.className = "size-1.5 rounded-full bg-muted-foreground/40";
      }, 2000);
    }
  }

  function setStatus(text: string) {
    statusLabel.textContent = text;
  }

  // ── Message builders ──────────────────────────────────────
  function appendUserMsg(text: string) {
    welcomeEl.style.display = "none";
    const el = document.createElement("div");
    el.className = "msg-enter flex justify-end px-1";
    el.innerHTML = `
      <div class="max-w-[78%] rounded-2xl rounded-tr-md bg-primary px-4 py-2.5 text-sm text-primary-foreground">
        <p class="whitespace-pre-wrap break-words leading-relaxed">${escHtml(text)}</p>
      </div>`;
    messagesEl.appendChild(el);
    scroll();
  }

  function appendToolsRow(): (name: string) => (result?: any, error?: string) => void {
    const row = document.createElement("div");
    row.className = "msg-enter flex flex-wrap gap-1.5 pl-9";
    messagesEl.appendChild(row);

    return function addChip(name: string) {
      const chip = document.createElement("details");
      chip.className = "tool-chip";
      chip.innerHTML = `
        <summary class="inline-flex items-center gap-1.5 rounded-full border border-border bg-muted/50 px-2.5 py-1 text-[11px] text-muted-foreground cursor-pointer hover:bg-muted transition-colors select-none">
          <svg class="size-2.5 shrink-0 text-amber-500 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
          <span class="font-mono">${escHtml(name)}</span>
          <svg class="size-2.5 shrink-0 chevron transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M6 9l6 6 6-6" stroke-linecap="round"/>
          </svg>
        </summary>
        <div class="result-panel mt-1.5 rounded-lg border border-border bg-card shadow-sm overflow-hidden hidden">
          <pre class="p-3 text-[11px] font-mono text-muted-foreground max-h-52 overflow-auto leading-relaxed whitespace-pre-wrap"></pre>
        </div>`;

      chip.addEventListener("toggle", () => {
        (chip.querySelector(".chevron") as SVGElement).style.transform =
          chip.open ? "rotate(180deg)" : "rotate(0deg)";
      });

      row.appendChild(chip);
      scroll();

      return function done(result?: any, error?: string) {
        const spinner = chip.querySelector("svg.animate-spin")!;
        if (error) {
          spinner.outerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="size-2.5 shrink-0 text-destructive"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6" stroke-linecap="round"/></svg>`;
        } else {
          spinner.outerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="size-2.5 shrink-0 text-green-500"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
        }
        const panel = chip.querySelector(".result-panel")!;
        const pre   = chip.querySelector("pre")!;
        panel.classList.remove("hidden");
        pre.textContent = error
          ? `Error: ${error}`
          : JSON.stringify(result, null, 2);
        scroll();
      };
    };
  }

  function appendAssistantMsg(): { setRawText: (text: string) => void; setContent: (html: string) => void; setTyping: (on: boolean) => void } {
    const el = document.createElement("div");
    el.className = "msg-enter flex gap-2.5 items-start px-1";
    el.innerHTML = `
      <div class="shrink-0 size-7 rounded-md bg-primary/10 flex items-center justify-center mt-0.5">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="size-3.5 text-primary">
          <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="min-w-0 flex-1 max-w-[84%]">
        <div class="rounded-2xl rounded-tl-md bg-card border border-border px-4 py-3">
          <div class="prose content typing-cursor"></div>
        </div>
      </div>`;
    messagesEl.appendChild(el);
    scroll();

    const content = el.querySelector(".content") as HTMLElement;

    return {
      // Show raw text token-by-token while streaming (no markdown parse overhead)
      setRawText(text: string) {
        content.classList.add("typing-cursor");
        content.textContent = text;
        scroll();
      },
      // Final render: replace raw text with parsed markdown
      setContent(html: string) {
        content.classList.remove("typing-cursor");
        content.innerHTML = html;
        scroll();
      },
      setTyping(on: boolean) {
        content.classList.toggle("typing-cursor", on);
      },
    };
  }

  function escHtml(s: string) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  // ── Send message ──────────────────────────────────────────
  async function send(text: string) {
    if (!text.trim() || isLoading) return;

    appendUserMsg(text);
    inputEl.value = "";
    inputEl.style.height = "auto";
    setLoading(true);

    let addChip: ((name: string) => (result?: any, error?: string) => void) | null = null;
    const pendingDone = new Map<string, (result?: any, error?: string) => void>();
    const bubble = appendAssistantMsg();

    // Accumulated raw text from streaming tokens
    let streamedText = "";

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ message: text, history }),
      });

      if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);

      const reader  = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });

        const lines = buffer.split("\n");
        buffer = lines.pop() ?? "";

        for (const line of lines) {
          if (!line.startsWith("data: ")) continue;
          let ev: any;
          try { ev = JSON.parse(line.slice(6)); } catch { continue; }

          // ── Streaming token: show raw text immediately ────────
          if (ev.type === "token") {
            // First token: remove the placeholder cursor, start showing text
            if (streamedText === "") bubble.setTyping(false);
            streamedText += ev.content;
            bubble.setRawText(streamedText);
          }

          if (ev.type === "tool_start") {
            if (!addChip) addChip = appendToolsRow();
            const chipDone = addChip(ev.name);
            pendingDone.set(ev.name, chipDone);
            setStatus(`llamando ${ev.name}…`);
          }

          if (ev.type === "tool_end") {
            pendingDone.get(ev.name)?.(ev.result, ev.error);
            pendingDone.delete(ev.name);
            // Reset stream buffer: next LLM call might produce new text
            streamedText = "";
          }

          // ── Done: render final markdown from accumulated text ─
          if (ev.type === "done") {
            bubble.setTyping(false);
            if (streamedText) {
              bubble.setContent(marked.parse(streamedText) as string);
            }
            if (ev.history) history = ev.history;
          }

          if (ev.type === "error") {
            bubble.setTyping(false);
            bubble.setContent(`<p class="text-destructive text-sm">Error: ${escHtml(ev.message)}</p>`);
          }
        }
      }
    } catch (e: any) {
      bubble.setTyping(false);
      bubble.setContent(`<p class="text-destructive text-sm">Error de conexión: ${escHtml(e.message)}</p>`);
    } finally {
      setLoading(false);
    }
  }

  form.addEventListener("submit", e => { e.preventDefault(); send(inputEl.value.trim()); });

  inputEl.addEventListener("keydown", e => {
    if ((e.metaKey || e.ctrlKey) && e.key === "Enter") { e.preventDefault(); send(inputEl.value.trim()); }
  });
</script>
