---
import AppLayout from "@/layouts/AppLayout.astro";
import { getProducts } from "@/lib/grpc/productClient";

let products: any[] = [];
try {
  products = await getProducts();
} catch {
  /* continue with empty list */
}
---

<AppLayout title="Nuevo Pedido">
  <div class="px-8 py-8 max-w-2xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-8">
      <a href="/sale-orders" class="hover:text-foreground transition-colors">Pedidos de Venta</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-foreground font-medium">Nuevo pedido</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-2xl font-semibold tracking-tight">Nuevo Pedido</h1>
      <p class="text-sm text-muted-foreground mt-1">
        Crea un pedido de venta y su orden de producción de forma automática.
      </p>
    </div>

    <form id="order-form" novalidate class="space-y-6">

      <!-- Customer -->
      <div class="rounded-xl border border-border bg-card p-6 space-y-4">
        <div>
          <h2 class="text-sm font-semibold">Cliente</h2>
          <p class="text-xs text-muted-foreground mt-0.5">Identificación del cliente para el pedido</p>
        </div>
        <div class="space-y-1.5">
          <label for="customer-id" class="text-sm font-medium">
            ID del Cliente <span class="text-destructive ml-0.5">*</span>
          </label>
          <input
            id="customer-id"
            type="text"
            placeholder="ej: cliente-001"
            autocomplete="off"
            class="w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring transition-shadow"
          />
          <p id="customer-error" class="hidden text-xs text-destructive mt-1">El ID del cliente es obligatorio.</p>
        </div>
      </div>

      <!-- Contexto Comercial -->
      <div class="rounded-xl border border-border bg-card p-6 space-y-4">
        <div>
          <h2 class="text-sm font-semibold">Contexto Comercial</h2>
          <p class="text-xs text-muted-foreground mt-0.5">Moneda, mercado y tipo de salida</p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label for="currency" class="text-sm font-medium">Moneda</label>
            <select id="currency"
              class="w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
              <option value="ARS">ARS — Peso argentino</option>
              <option value="USD">USD — Dólar</option>
              <option value="EUR">EUR — Euro</option>
              <option value="CAD">CAD — Dólar canadiense</option>
            </select>
          </div>
          <div class="space-y-1.5">
            <label for="market" class="text-sm font-medium">Mercado</label>
            <select id="market"
              class="w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
              <option value="DOMESTIC">Mercado Interno</option>
              <option value="EXPORT">Exportación</option>
            </select>
          </div>
          <div class="space-y-1.5">
            <label for="sale-type" class="text-sm font-medium">Tipo de Salida</label>
            <select id="sale-type"
              class="w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
              <option value="SALE">Venta</option>
              <option value="SAMPLE_CUSTOMS">Muestra Aduana</option>
              <option value="GIFT">Regalo</option>
              <option value="INTERNAL">Consumo Interno</option>
              <option value="COMMERCIAL_SAMPLE">Muestra Comercial</option>
            </select>
          </div>
          <div class="space-y-1.5">
            <label for="destination" class="text-sm font-medium">País de Destino</label>
            <input id="destination" type="text" placeholder="ej: Argentina, USA, Japón"
              class="w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"/>
          </div>
        </div>
      </div>

      <!-- Items -->
      <div class="rounded-xl border border-border bg-card p-6 space-y-4">
        <div class="flex items-start justify-between">
          <div>
            <h2 class="text-sm font-semibold">Productos</h2>
            <p class="text-xs text-muted-foreground mt-0.5">Items del pedido con cantidad y precio unitario</p>
          </div>
          <span id="items-count-badge" class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-medium">
            0 items
          </span>
        </div>

        <div class="grid grid-cols-[1fr_80px_100px_36px] gap-2.5 px-1">
          <p class="text-xs font-medium text-muted-foreground">Producto</p>
          <p class="text-xs font-medium text-muted-foreground text-center">Cant.</p>
          <p class="text-xs font-medium text-muted-foreground text-center">Precio unit.</p>
          <span></span>
        </div>

        <div id="items-rows" class="space-y-2.5 min-h-[40px]"></div>

        <p id="items-empty-hint" class="text-xs text-muted-foreground italic">
          Sin items. Agregá al menos uno.
        </p>

        <button
          type="button"
          id="btn-add-item"
          class="inline-flex items-center gap-2 rounded-lg border border-dashed border-input px-4 py-2 text-sm text-muted-foreground hover:border-foreground hover:text-foreground hover:bg-muted/30 transition-colors w-full justify-center"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
          </svg>
          Agregar producto
        </button>
      </div>

      <div id="form-feedback" class="hidden rounded-lg p-4 text-sm font-medium"></div>

      <div class="flex items-center justify-between pt-1">
        <a
          href="/sale-orders"
          class="inline-flex items-center gap-1.5 rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Cancelar
        </a>
        <button
          type="submit"
          id="btn-submit"
          class="inline-flex items-center gap-2 rounded-lg bg-primary text-primary-foreground px-5 py-2 text-sm font-medium hover:bg-primary/90 transition-colors disabled:opacity-50 disabled:pointer-events-none"
        >
          <svg id="submit-spinner" class="hidden size-4 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
          <span id="submit-label">Crear Pedido</span>
        </button>
      </div>
    </form>
  </div>
</AppLayout>

<script define:vars={{ products }}>
  let rowIdx = 0;

  function updateCounter() {
    const count = document.querySelectorAll(".item-row").length;
    document.getElementById("items-count-badge").textContent =
      `${count} ${count === 1 ? "item" : "items"}`;
    document.getElementById("items-empty-hint").style.display =
      count === 0 ? "" : "none";
  }

  function createItemRow() {
    const i = rowIdx++;
    const row = document.createElement("div");
    row.className = "item-row grid grid-cols-[1fr_80px_100px_36px] gap-2.5 items-center";

    const productOptions = products
      .map((p) => `<option value="${p.id}">${p.name}</option>`)
      .join("");

    row.innerHTML = `
      <select name="item_product_${i}"
        class="rounded-lg border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
        <option value="">— seleccionar —</option>
        ${productOptions}
      </select>
      <input type="number" name="item_qty_${i}" min="1" value="1"
        class="rounded-lg border border-input bg-background px-2 py-2 text-sm text-center focus:outline-none focus:ring-2 focus:ring-ring"/>
      <input type="number" name="item_price_${i}" min="0" step="0.01" value="0.00"
        class="rounded-lg border border-input bg-background px-2 py-2 text-sm text-center focus:outline-none focus:ring-2 focus:ring-ring"/>
      <button type="button" class="btn-remove size-9 rounded-lg border border-input bg-background text-muted-foreground hover:bg-destructive/10 hover:text-destructive hover:border-destructive/30 transition-colors flex items-center justify-center shrink-0">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
        </svg>
      </button>
    `;
    row.querySelector(".btn-remove").addEventListener("click", () => {
      row.remove();
      updateCounter();
    });
    return row;
  }

  const container = document.getElementById("items-rows");
  document.getElementById("btn-add-item").addEventListener("click", () => {
    container.appendChild(createItemRow());
    updateCounter();
  });

  updateCounter();

  // Form submit
  const form = document.getElementById("order-form");
  const feedback = document.getElementById("form-feedback");
  const btnSubmit = document.getElementById("btn-submit");
  const spinner = document.getElementById("submit-spinner");
  const submitLabel = document.getElementById("submit-label");
  const customerInput = document.getElementById("customer-id");
  const customerError = document.getElementById("customer-error");

  function showError(msg) {
    feedback.className =
      "rounded-lg p-4 text-sm font-medium border border-destructive/30 bg-destructive/5 text-destructive flex items-center gap-2";
    feedback.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15" stroke-linecap="round"/><line x1="9" y1="9" x2="15" y2="15" stroke-linecap="round"/></svg><span>${msg}</span>`;
    feedback.classList.remove("hidden");
    feedback.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  function setLoading(on) {
    btnSubmit.disabled = on;
    spinner.classList.toggle("hidden", !on);
    submitLabel.textContent = on ? "Creando…" : "Crear Pedido";
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    feedback.classList.add("hidden");

    const customerId = customerInput.value.trim();
    if (!customerId) {
      customerError.classList.remove("hidden");
      customerInput.focus();
      return;
    }
    customerError.classList.add("hidden");

    const items = [];
    document.querySelectorAll(".item-row").forEach((row) => {
      const selects = row.querySelectorAll("select");
      const inputs = row.querySelectorAll("input");
      const productId = selects[0]?.value;
      const qty = parseInt(inputs[0]?.value ?? "1", 10);
      const price = parseFloat(inputs[1]?.value ?? "0");
      if (productId && qty > 0) {
        items.push({ product_id: productId, quantity: qty, unit_price: price });
      }
    });

    if (items.length === 0) {
      showError("Agregá al menos un producto al pedido.");
      return;
    }

    const currency = document.getElementById("currency").value;
    const market = document.getElementById("market").value;
    const saleType = document.getElementById("sale-type").value;
    const destination = document.getElementById("destination").value.trim();

    setLoading(true);
    try {
      const res = await fetch("/api/orders", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          customer_id: customerId,
          items,
          currency,
          market,
          sale_type: saleType,
          destination_country: destination || undefined,
        }),
      });
      if (res.status === 201) {
        window.location.href = "/sale-orders";
        return;
      }
      const body = await res.json().catch(() => ({}));
      showError(body.error ?? `Error ${res.status}`);
    } catch {
      showError("Error de red. Verificá que el servidor esté disponible.");
    } finally {
      setLoading(false);
    }
  });

  customerInput.addEventListener("input", () => {
    if (customerInput.value.trim()) customerError.classList.add("hidden");
  });
</script>
