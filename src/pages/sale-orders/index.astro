---
import AppLayout from "@/layouts/AppLayout.astro";
import { getSaleOrders } from "@/lib/grpc/saleOrderClient";
import { getCustomers } from "@/lib/grpc/customerClient";
import { COOKIE_NAME } from "@/lib/auth";

const token = Astro.cookies.get(COOKIE_NAME)?.value;
let orders: any[] = [];
let customerMap: Record<string, string> = {};
let error = "";
try {
  [orders] = await Promise.all([
    getSaleOrders(token),
    getCustomers(token).then((cs) => { customerMap = Object.fromEntries(cs.map((c) => [c.id, c.social_reason])); }).catch(() => {}),
  ]);
} catch (e: any) {
  error = e.message;
}

const statusColor: Record<string, string> = {
  pending:    "bg-yellow-100 text-yellow-800",
  processing: "bg-blue-100 text-blue-800",
  completed:  "bg-green-100 text-green-800",
  cancelled:  "bg-red-100 text-red-800",
};
---

<AppLayout title="Pedidos de Venta">
  <div class="px-8 py-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">Pedidos de Venta</h1>
        <p class="text-sm text-muted-foreground mt-1">
          {error ? "Error al cargar" : `${orders.length} pedido${orders.length !== 1 ? "s" : ""} registrado${orders.length !== 1 ? "s" : ""}`}
        </p>
      </div>
      <div class="flex items-center gap-2">
        <a
          href="/sale-orders/kanban"
          class="inline-flex items-center gap-2 rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <rect x="3" y="3" width="5" height="18" rx="1" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="10" y="3" width="5" height="12" rx="1" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="17" y="3" width="5" height="15" rx="1" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Kanban
        </a>
        <a
          href="/sale-orders/new"
          class="inline-flex items-center gap-2 rounded-lg bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
          </svg>
          Nuevo Pedido
        </a>
      </div>
    </div>

    {error && (
      <div class="rounded-lg border border-destructive/30 bg-destructive/5 p-4 text-sm text-destructive mb-6">
        {error}
      </div>
    )}

    {!error && orders.length === 0 && (
      <div class="rounded-xl border border-border bg-card p-12 text-center">
        <p class="text-muted-foreground text-sm">No hay pedidos registrados aún.</p>
        <a href="/sale-orders/new" class="mt-4 inline-flex items-center gap-1.5 text-sm text-primary hover:underline">
          Crear el primer pedido
        </a>
      </div>
    )}

    {orders.length > 0 && (
      <div class="rounded-xl border border-border bg-card overflow-hidden">
        <table class="w-full text-sm">
          <thead class="border-b border-border bg-muted/40">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground">ID</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground">Cliente</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground">Estado</th>
              <th class="text-right px-4 py-3 font-medium text-muted-foreground">Items</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground">Creado</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            {orders.map((o) => (
              <tr
                class="hover:bg-muted/30 transition-colors cursor-pointer"
                onclick={`window.location='/sale-orders/${o.id}'`}
              >
                <td class="px-4 py-3 font-mono text-xs text-muted-foreground">{o.id}</td>
                <td class="px-4 py-3 font-medium">{customerMap[o.customer_id] ?? o.customer_id}</td>
                <td class="px-4 py-3">
                  <span class:list={[
                    "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium",
                    statusColor[o.status] ?? "bg-secondary text-secondary-foreground"
                  ]}>
                    {o.status || "—"}
                  </span>
                </td>
                <td class="px-4 py-3 text-right">{o.items?.length ?? 0}</td>
                <td class="px-4 py-3 text-muted-foreground text-xs">{o.created_at || "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AppLayout>
