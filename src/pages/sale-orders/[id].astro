---
import AppLayout from "@/layouts/AppLayout.astro";
import { getSaleOrderByID } from "@/lib/grpc/saleOrderClient";
import { getProducts } from "@/lib/grpc/productClient";
import { getCustomerByID } from "@/lib/grpc/customerClient";

const { id } = Astro.params;
let order: any = null;
let error = "";
let productMap: Record<string, string> = {};
let customerName = "";

try {
  [order] = await Promise.all([
    getSaleOrderByID(id!),
    getProducts().then((ps) => { productMap = Object.fromEntries(ps.map((p) => [p.id, p.name])); }).catch(() => {}),
  ]);
  if (order?.customer_id) {
    customerName = await getCustomerByID(order.customer_id).then((c) => c.social_reason).catch(() => "");
  }
} catch (e: any) {
  error = e.message;
}

const pipeline = ["NEW", "CONFIRMED", "INVOICED", "DISPATCHED"];
const pipelineLabel: Record<string, string> = {
  NEW: "Nuevo", CONFIRMED: "Confirmado", INVOICED: "Facturado",
  DISPATCHED: "Despachado", CANCELLED: "Cancelado",
};
const nextStatus: Record<string, string> = {
  NEW: "CONFIRMED", CONFIRMED: "INVOICED", INVOICED: "DISPATCHED",
};
const statusColor: Record<string, string> = {
  NEW:        "bg-secondary text-secondary-foreground",
  CONFIRMED:  "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300",
  INVOICED:   "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300",
  DISPATCHED: "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300",
  CANCELLED:  "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300",
};
const saleTypeLabel: Record<string, string> = {
  SALE: "Venta", SAMPLE_CUSTOMS: "Muestra Aduana", GIFT: "Regalo",
  INTERNAL: "Consumo Interno", COMMERCIAL_SAMPLE: "Muestra Comercial",
};
const marketLabel: Record<string, string> = {
  DOMESTIC: "Mercado Interno", EXPORT: "Exportación",
};

const currentIdx = pipeline.indexOf(order?.status ?? "NEW");
const total = (order?.items ?? []).reduce(
  (acc: number, item: any) => acc + item.quantity * item.unit_price, 0
);
---

<AppLayout title="Pedido de Venta">
  <div class="px-8 py-8 max-w-4xl">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6">
      <a href="/sale-orders" class="hover:text-foreground transition-colors">Pedidos de Venta</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-foreground font-mono text-xs">{id}</span>
    </nav>

    {error && (
      <div class="rounded-lg border border-destructive/30 bg-destructive/5 p-4 text-sm text-destructive">
        {error}
      </div>
    )}

    {order && order.status === "CANCELLED" && (
      <div class="rounded-xl border border-destructive/20 bg-destructive/5 px-5 py-3 mb-6 flex items-center gap-2">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4 text-destructive shrink-0">
          <circle cx="12" cy="12" r="10"/>
          <path d="M15 9l-6 6M9 9l6 6" stroke-linecap="round"/>
        </svg>
        <span class="text-sm text-destructive font-medium">Este pedido fue cancelado.</span>
      </div>
    )}

    {order && order.status !== "CANCELLED" && (
      <!-- ── Pipeline stepper ─────────────────────────────── -->
      <div class="rounded-xl border border-border bg-card p-5 mb-6">
        <div class="flex items-start justify-between relative">
          <!-- connector line -->
          <div class="absolute left-[5%] right-[5%] top-4 h-px bg-border hidden sm:block"/>

          {pipeline.map((step, i) => {
            const isTerminal = order?.status === "DISPATCHED";
            const isDone    = i <= currentIdx;
            const isCurrent = !isTerminal && i === currentIdx + 1;
            return (
              <div class="flex flex-col items-center gap-2 z-10 flex-1">
                <div class:list={[
                  "size-8 rounded-full flex items-center justify-center text-xs font-bold border-2 shrink-0",
                  isDone    ? "bg-primary border-primary text-primary-foreground" :
                  isCurrent ? "bg-card border-primary text-primary" :
                              "bg-card border-border text-muted-foreground"
                ]}>
                  {isDone ? (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="size-4">
                      <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  ) : (i + 1)}
                </div>
                <span class:list={[
                  "text-xs font-medium text-center",
                  isCurrent ? "text-primary" : isDone ? "text-foreground" : "text-muted-foreground"
                ]}>
                  {pipelineLabel[step]}
                </span>
              </div>
            );
          })}
        </div>

        {nextStatus[order.status] && (
          <div class="mt-5 pt-4 border-t border-border flex items-center justify-between gap-3 flex-wrap">
            <p class="text-xs text-muted-foreground">
              Siguiente: <strong class="text-foreground">{pipelineLabel[nextStatus[order.status]]}</strong>
            </p>
            <div class="flex gap-2">
              <button id="btn-cancel"
                class="rounded-lg border border-destructive/30 text-destructive px-3.5 py-1.5 text-xs font-medium hover:bg-destructive/5 transition-colors">
                Cancelar pedido
              </button>
              <button id="btn-advance" data-next={nextStatus[order.status]}
                class="rounded-lg bg-primary text-primary-foreground px-3.5 py-1.5 text-xs font-medium hover:bg-primary/90 transition-colors">
                Avanzar → {pipelineLabel[nextStatus[order.status]]}
              </button>
            </div>
          </div>
        )}

        {order.status === "DISPATCHED" && (
          <p class="mt-4 pt-4 border-t border-border text-xs text-green-600 font-medium text-center">
            Pedido completamente despachado ✓
          </p>
        )}
      </div>
    )}

    {order && (
      <div class="space-y-5">

        <!-- Summary -->
        <div class="rounded-xl border border-border bg-card p-6">
          <div class="flex items-start justify-between mb-5">
            <h1 class="text-base font-semibold">Detalle del Pedido</h1>
            <span class:list={[
              "inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium",
              statusColor[order.status] ?? "bg-secondary text-secondary-foreground"
            ]}>
              {pipelineLabel[order.status] ?? order.status}
            </span>
          </div>
          <dl class="grid grid-cols-2 sm:grid-cols-3 gap-x-8 gap-y-4 text-sm">
            <div>
              <dt class="text-xs text-muted-foreground uppercase tracking-wider mb-1">ID</dt>
              <dd class="font-mono text-xs truncate" title={order.id}>{order.id.slice(0,16)}…</dd>
            </div>
            <div>
              <dt class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Cliente</dt>
              <dd class="font-medium">{customerName || order.customer_id}</dd>
            </div>
            <div>
              <dt class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Creado</dt>
              <dd class="text-muted-foreground">{order.created_at || "—"}</dd>
            </div>
            <div>
              <dt class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Mercado</dt>
              <dd>{(marketLabel[order.market] ?? order.market) || "—"}</dd>
            </div>
            <div>
              <dt class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Tipo de Salida</dt>
              <dd>{(saleTypeLabel[order.sale_type] ?? order.sale_type) || "—"}</dd>
            </div>
            <div>
              <dt class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Moneda</dt>
              <dd class="font-mono">{order.currency || "—"}</dd>
            </div>
            {order.destination_country && (
              <div>
                <dt class="text-xs text-muted-foreground uppercase tracking-wider mb-1">País Destino</dt>
                <dd>{order.destination_country}</dd>
              </div>
            )}
          </dl>
        </div>

        <!-- Items -->
        {(order.items ?? []).length > 0 && (
          <div class="rounded-xl border border-border bg-card overflow-hidden">
            <div class="px-6 py-4 border-b border-border">
              <h2 class="text-sm font-semibold">Items del Pedido</h2>
              <p class="text-xs text-muted-foreground mt-0.5">{order.items.length} producto{order.items.length !== 1 ? "s" : ""}</p>
            </div>
            <div class="divide-y divide-border">
              {order.items.map((item: any) => (
                <div class="px-6 py-4 flex items-center justify-between text-sm gap-4">
                  <div>
                    <span class="font-medium text-sm">{productMap[item.product_id] ?? item.product_id}</span>
                    <span class="block font-mono text-xs text-muted-foreground mt-0.5">{item.product_id.slice(0,8)}…</span>
                  </div>
                  <div class="flex items-center gap-6 shrink-0">
                    <span class="text-muted-foreground">Cant: <strong class="text-foreground">{item.quantity}</strong></span>
                    <span class="text-muted-foreground">P.U.: <strong class="text-foreground">{item.unit_price}</strong></span>
                    <span class="text-muted-foreground">Sub: <strong class="text-foreground">{(item.quantity * item.unit_price).toFixed(2)}</strong></span>
                  </div>
                </div>
              ))}
            </div>
            <div class="px-6 py-4 border-t border-border bg-muted/30 flex justify-end text-sm font-semibold">
              {order.currency} {total.toFixed(2)}
            </div>
          </div>
        )}

      </div>
    )}
  </div>

  <!-- Toast -->
  <div id="toast-error" class="hidden fixed bottom-6 right-6 z-50 rounded-xl border border-destructive/30 bg-destructive/10 px-4 py-3 text-sm text-destructive max-w-xs shadow-lg">
    <p id="toast-msg"></p>
  </div>
</AppLayout>

<script>
  const orderId = window.location.pathname.split("/").filter(Boolean).pop()!;

  async function updateStatus(newStatus: string) {
    const res = await fetch(`/api/sale-orders/${orderId}`, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ status: newStatus }),
    });
    if (res.ok) {
      window.location.reload();
    } else {
      const data = await res.json().catch(() => ({}));
      const toast = document.getElementById("toast-error")!;
      document.getElementById("toast-msg")!.textContent = data.error ?? `Error ${res.status}`;
      toast.classList.remove("hidden");
      setTimeout(() => toast.classList.add("hidden"), 4500);
    }
  }

  document.getElementById("btn-advance")?.addEventListener("click", (e) => {
    const next = (e.currentTarget as HTMLElement).dataset.next!;
    updateStatus(next);
  });

  document.getElementById("btn-cancel")?.addEventListener("click", () => {
    if (confirm("¿Cancelar este pedido? Esta acción no se puede deshacer.")) {
      updateStatus("CANCELLED");
    }
  });
</script>
