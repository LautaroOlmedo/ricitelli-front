---
import AppLayout from "@/layouts/AppLayout.astro";
import { getProducts } from "@/lib/grpc/productClient";
import { getSaleOrders } from "@/lib/grpc/saleOrderClient";
import { getProductionOrders } from "@/lib/grpc/productionOrderClient";
import { getCustomers } from "@/lib/grpc/customerClient";
import { getLowStockAlerts } from "@/lib/grpc/inventoryClient";

const results = await Promise.allSettled([
  getProducts(),
  getSaleOrders(),
  getProductionOrders(),
  getCustomers(),
  getLowStockAlerts(),
]);

const products       = results[0].status === "fulfilled" ? results[0].value : [];
const saleOrders     = results[1].status === "fulfilled" ? results[1].value : [];
const prodOrders     = results[2].status === "fulfilled" ? results[2].value : [];
const customers      = results[3].status === "fulfilled" ? results[3].value : [];
const alertsReport   = results[4].status === "fulfilled" ? results[4].value : { products: [], dry_supply_alerts: [] };

const alerts = alertsReport.dry_supply_alerts ?? [];
const lowAlerts = alerts.filter((a: any) => a.is_low);

// Sale orders by status
const ordersByStatus = (saleOrders as any[]).reduce((acc: Record<string, number>, o: any) => {
  acc[o.status] = (acc[o.status] ?? 0) + 1;
  return acc;
}, {});

// Recent sale orders (last 5)
const recentOrders = [...(saleOrders as any[])]
  .sort((a, b) => (b.created_at > a.created_at ? 1 : -1))
  .slice(0, 5);

// Recent production orders (last 5)
const recentProd = [...(prodOrders as any[])]
  .sort((a, b) => (b.created_at > a.created_at ? 1 : -1))
  .slice(0, 5);

const statusColor: Record<string, string> = {
  NEW:        "bg-secondary text-secondary-foreground",
  CONFIRMED:  "bg-blue-100 text-blue-800",
  INVOICED:   "bg-yellow-100 text-yellow-800",
  DISPATCHED: "bg-green-100 text-green-800",
  CANCELLED:  "bg-red-100 text-red-800",
};
const statusLabel: Record<string, string> = {
  NEW: "Nuevo", CONFIRMED: "Confirmado", INVOICED: "Facturado",
  DISPATCHED: "Despachado", CANCELLED: "Cancelado",
};
---

<AppLayout title="Dashboard">
  <div class="px-8 py-8 max-w-6xl mx-auto">

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-2xl font-semibold tracking-tight">Dashboard</h1>
      <p class="text-sm text-muted-foreground mt-1">Resumen operativo — Bodega Riccitelli</p>
    </div>

    <!-- ── Top KPIs ─────────────────────────────────────── -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      {[
        { label: "Clientes",          value: String((customers as any[]).length),                href: "/customers",        color: "" },
        { label: "Pedidos de Venta",  value: String((saleOrders as any[]).length),              href: "/sale-orders",      color: "" },
        { label: "En Producción",     value: String((prodOrders as any[]).length),              href: "/production-orders",color: "" },
        { label: "Alertas de Stock",  value: String(lowAlerts.length),                           href: "/dry-supplies",     color: lowAlerts.length > 0 ? "text-destructive" : "text-green-600" },
      ].map(({ label, value, href, color }) => (
        <a href={href} class="rounded-xl border border-border bg-card p-5 hover:bg-muted/30 transition-colors group">
          <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">{label}</p>
          <p class:list={["mt-2 text-3xl font-bold tracking-tight group-hover:text-primary transition-colors", color || ""]}>
            {value}
          </p>
        </a>
      ))}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

      <!-- ── Pedidos por Estado ──────────────────────────── -->
      <div class="rounded-xl border border-border bg-card p-5">
        <h2 class="text-sm font-semibold mb-4">Pedidos por Estado</h2>
        {Object.keys(ordersByStatus).length === 0 ? (
          <p class="text-sm text-muted-foreground">Sin pedidos aún.</p>
        ) : (
          <div class="space-y-2">
            {(["NEW","CONFIRMED","INVOICED","DISPATCHED","CANCELLED"] as const).filter(s => ordersByStatus[s]).map((s) => {
              const count = ordersByStatus[s] ?? 0;
              const pct = Math.round((count / (saleOrders as any[]).length) * 100);
              return (
                <div>
                  <div class="flex items-center justify-between text-xs mb-1">
                    <span class:list={["inline-flex rounded-full px-2 py-0.5 font-medium", statusColor[s]]}>
                      {statusLabel[s]}
                    </span>
                    <span class="text-muted-foreground font-mono">{count} ({pct}%)</span>
                  </div>
                  <div class="h-1.5 rounded-full bg-muted overflow-hidden">
                    <div class="h-full bg-primary rounded-full" style={`width:${pct}%`}/>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>

      <!-- ── Alertas de Insumos ──────────────────────────── -->
      <div class="rounded-xl border border-border bg-card p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold">Alertas de Insumos</h2>
          <a href="/dry-supplies" class="text-xs text-primary hover:underline">Ver todo</a>
        </div>
        {lowAlerts.length === 0 ? (
          <div class="flex items-center gap-2 text-sm text-green-600">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4 shrink-0">
              <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Todos los insumos tienen stock suficiente
          </div>
        ) : (
          <div class="space-y-2">
            {lowAlerts.slice(0, 5).map((a: any) => (
              <div class="flex items-center justify-between text-sm">
                <div>
                  <span class="font-mono text-xs text-muted-foreground">{a.code}</span>
                  <p class="text-xs font-medium">{a.name}</p>
                </div>
                <span class="text-destructive font-mono text-xs font-semibold">
                  {a.available.toLocaleString("es-AR")}
                </span>
              </div>
            ))}
            {lowAlerts.length > 5 && (
              <p class="text-xs text-muted-foreground pt-1">
                + {lowAlerts.length - 5} más
              </p>
            )}
          </div>
        )}
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- ── Últimos Pedidos ─────────────────────────────── -->
      <div class="rounded-xl border border-border bg-card overflow-hidden">
        <div class="px-5 py-4 border-b border-border flex items-center justify-between">
          <h2 class="text-sm font-semibold">Últimos Pedidos de Venta</h2>
          <a href="/sale-orders" class="text-xs text-primary hover:underline">Ver todos</a>
        </div>
        {recentOrders.length === 0 ? (
          <p class="px-5 py-4 text-sm text-muted-foreground">Sin pedidos aún.</p>
        ) : (
          <div class="divide-y divide-border">
            {recentOrders.map((o: any) => (
              <a href={`/sale-orders/${o.id}`} class="flex items-center justify-between px-5 py-3 text-sm hover:bg-muted/30 transition-colors group">
                <div>
                  <p class="font-medium group-hover:text-primary transition-colors">{o.customer_id}</p>
                  <p class="text-xs text-muted-foreground font-mono mt-0.5">{o.id.slice(0,12)}…</p>
                </div>
                <div class="flex items-center gap-3">
                  <span class:list={[
                    "inline-flex rounded-full px-2 py-0.5 text-xs font-medium",
                    statusColor[o.status] ?? "bg-secondary text-secondary-foreground"
                  ]}>
                    {statusLabel[o.status] ?? o.status}
                  </span>
                  <span class="text-xs text-muted-foreground font-mono">{o.currency}</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- ── Órdenes de Producción Recientes ────────────── -->
      <div class="rounded-xl border border-border bg-card overflow-hidden">
        <div class="px-5 py-4 border-b border-border flex items-center justify-between">
          <h2 class="text-sm font-semibold">Producción Reciente</h2>
          <div class="flex items-center gap-3">
            <a href="/production-orders/calendar" class="text-xs text-primary hover:underline">Calendario</a>
            <a href="/production-orders" class="text-xs text-primary hover:underline">Ver todos</a>
          </div>
        </div>
        {recentProd.length === 0 ? (
          <p class="px-5 py-4 text-sm text-muted-foreground">Sin órdenes de producción aún.</p>
        ) : (
          <div class="divide-y divide-border">
            {recentProd.map((p: any) => (
              <a href={`/production-orders/${p.id}`} class="flex items-center justify-between px-5 py-3 text-sm hover:bg-muted/30 transition-colors group">
                <div>
                  <p class="font-mono text-xs text-muted-foreground group-hover:text-primary transition-colors">{p.id.slice(0,12)}…</p>
                  <p class="text-xs text-muted-foreground mt-0.5">{p.items?.length ?? 0} producto{(p.items?.length ?? 0) !== 1 ? "s" : ""}</p>
                </div>
                <div class="flex items-center gap-3">
                  <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium bg-secondary text-secondary-foreground">
                    {p.status || "IN PROGRESS"}
                  </span>
                  <span class="text-xs text-muted-foreground">{(p.created_at || "").slice(0, 10)}</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>

    </div>
  </div>
</AppLayout>
