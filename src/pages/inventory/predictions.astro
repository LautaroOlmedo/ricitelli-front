---
import AppLayout from "@/layouts/AppLayout.astro";
import { COOKIE_NAME } from "@/lib/auth";
import type { SupplyPrediction } from "@/pages/api/inventory/predictions";

const token = Astro.cookies.get(COOKIE_NAME)?.value;

let predictions: SupplyPrediction[] = [];
let loadError = "";

try {
  const res = await fetch(`${Astro.url.origin}/api/inventory/predictions`, {
    headers: token ? { Cookie: `${COOKIE_NAME}=${token}` } : {},
  });
  if (res.ok) {
    predictions = await res.json();
  } else {
    const body = await res.json().catch(() => ({}));
    loadError = body.error ?? `Error ${res.status}`;
  }
} catch (e: any) {
  loadError = e.message ?? "Error al cargar predicciones";
}

const critical = predictions.filter((p) => p.is_critical);
const warnings = predictions.filter((p) => p.is_warning);

const statusLabel: Record<string, string> = {
  NEW:       "Nuevo",
  CONFIRMED: "Confirmado",
  INVOICED:  "Facturado",
};
const statusColor: Record<string, string> = {
  NEW:       "#87867f",
  CONFIRMED: "#2563EB",
  INVOICED:  "#8a6b1a",
};
const marketLabel: Record<string, string> = {
  DOMESTIC: "Nacional",
  EXPORT:   "Export",
};
const currencySymbol: Record<string, string> = {
  ARS: "$", USD: "U$S", EUR: "€", CAD: "C$",
};
---

<AppLayout title="Predicción de Faltantes">
  <div class="px-8 py-8 max-w-5xl mx-auto space-y-8">

    <!-- ── Breadcrumb ──────────────────────────────────────── -->
    <nav class="flex items-center gap-2 text-sm text-muted-foreground">
      <a href="/dry-supplies" class="hover:text-foreground transition-colors">Insumos</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-foreground font-medium">Predicción de Faltantes</span>
    </nav>

    <!-- ── Header ─────────────────────────────────────────── -->
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight font-display">Predicción de Faltantes</h1>
        <p class="text-sm text-muted-foreground mt-1">
          Proyección de stock basada en pedidos activos (Nuevo + Confirmado + Facturado) cruzados con las listas de materiales (BOM) de cada producto.
        </p>
      </div>
      <a href="/dry-supplies"
        class="inline-flex items-center gap-1.5 rounded-lg border border-input bg-background px-3.5 py-2 text-sm font-medium hover:bg-muted/60 transition-colors shrink-0">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
          <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Ver insumos
      </a>
    </div>

    <!-- ── Error ───────────────────────────────────────────── -->
    {loadError && (
      <div class="rounded-xl border border-destructive/30 bg-destructive/5 p-4 text-sm text-destructive">
        {loadError}
      </div>
    )}

    <!-- ── Summary banner ─────────────────────────────────── -->
    {!loadError && (
      <div class="grid grid-cols-3 gap-4">
        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Críticos</p>
          <p class="text-3xl font-semibold mt-1 font-display" style={`color:${critical.length > 0 ? "#b53333" : "#3d6b35"};`}>
            {critical.length}
          </p>
          <p class="text-xs text-muted-foreground mt-0.5">
            {critical.length === 0 ? "Sin faltantes confirmados" : `insumo${critical.length !== 1 ? "s" : ""} sin stock suficiente`}
          </p>
        </div>
        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Avisos</p>
          <p class="text-3xl font-semibold mt-1 font-display" style={`color:${warnings.length > 0 ? "#8a6b1a" : "#3d6b35"};`}>
            {warnings.length}
          </p>
          <p class="text-xs text-muted-foreground mt-0.5">
            {warnings.length === 0 ? "Sin alertas de margen bajo" : `insumo${warnings.length !== 1 ? "s" : ""} con margen ajustado`}
          </p>
        </div>
        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">OK</p>
          <p class="text-3xl font-semibold mt-1 font-display" style="color:#3d6b35;">
            {predictions.length === 0 ? "—" : predictions.length === 0 ? "✓" : "✓"}
          </p>
          <p class="text-xs text-muted-foreground mt-0.5">
            {predictions.length === 0 ? "Todos los insumos cubiertos" : "Resto de insumos con stock OK"}
          </p>
        </div>
      </div>
    )}

    <!-- ── No alerts ───────────────────────────────────────── -->
    {!loadError && predictions.length === 0 && (
      <div class="rounded-xl border border-border bg-card p-10 text-center">
        <div class="size-14 rounded-2xl mx-auto flex items-center justify-center text-2xl mb-4" style="background:#3d6b3515;">
          ✓
        </div>
        <p class="font-semibold text-base">Todo en orden</p>
        <p class="text-sm text-muted-foreground mt-1">
          Los pedidos activos pueden cubrirse con el stock disponible. No hay faltantes proyectados.
        </p>
      </div>
    )}

    <!-- ── Critical alerts ─────────────────────────────────── -->
    {critical.length > 0 && (
      <section class="space-y-4">
        <div class="flex items-center gap-2">
          <span class="size-2 rounded-full shrink-0" style="background:#b53333;"></span>
          <h2 class="text-sm font-semibold">Faltantes Confirmados</h2>
          <span class="text-xs text-muted-foreground">— stock insuficiente para cubrir pedidos activos</span>
        </div>

        {critical.map((p) => (
          <div class="rounded-xl border bg-card overflow-hidden" style="border-color:#b5333330;">
            <!-- Card header -->
            <div class="px-6 py-4 flex items-start justify-between gap-4" style="background:#b5333308;">
              <div class="flex items-start gap-3">
                <div class="size-10 rounded-lg flex items-center justify-center shrink-0 text-xs font-bold text-white mt-0.5" style="background:#b53333;">
                  {p.code.slice(0, 3).toUpperCase()}
                </div>
                <div>
                  <p class="font-semibold text-[15px] leading-tight">{p.name}</p>
                  <p class="text-xs text-muted-foreground mt-0.5">{p.code} · {p.category}</p>
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <span class="rounded-full px-2.5 py-1 text-[11px] font-bold" style="background:#b5333320;color:#b53333;">
                  CRÍTICO — faltan {p.shortfall.toLocaleString("es-AR")} un.
                </span>
              </div>
            </div>

            <div class="px-6 py-5 space-y-5">
              <!-- Natural language alert -->
              <div class="rounded-lg border px-4 py-3.5" style="border-color:#b5333330;background:#b5333306;">
                <p class="text-sm leading-relaxed text-foreground">{p.natural_message}</p>
              </div>

              <!-- Stock bar -->
              <div class="space-y-2">
                <div class="flex items-center justify-between text-xs text-muted-foreground">
                  <span>Stock disponible vs. necesario</span>
                  <span class="font-semibold" style="color:#b53333;">{p.coverage_pct}% cubierto</span>
                </div>
                <div class="h-2.5 rounded-full overflow-hidden" style="background:#f0eee6;">
                  <div
                    class="h-full rounded-full transition-all"
                    style={`width:${Math.min(p.coverage_pct, 100)}%;background:${p.coverage_pct < 50 ? "#b53333" : "#8a6b1a"};`}
                  />
                </div>
                <div class="flex items-center justify-between text-[11px]">
                  <span class="text-muted-foreground">Disponible: <strong class="text-foreground">{p.available_stock.toLocaleString("es-AR")}</strong></span>
                  <span class="text-muted-foreground">Necesario: <strong class="text-foreground">{p.total_needed.toLocaleString("es-AR")}</strong></span>
                  <span style="color:#b53333;">Faltante: <strong>{p.shortfall.toLocaleString("es-AR")}</strong></span>
                </div>
              </div>

              <!-- Orders at risk -->
              <div class="space-y-1.5">
                <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">
                  Pedidos que generan la demanda
                </p>
                <div class="rounded-lg border border-border overflow-hidden divide-y divide-border">
                  {p.orders_at_risk.map((o, idx) => (
                    <div>
                      <!-- Row principal — clickeable para expandir -->
                      <button
                        type="button"
                        class="order-row w-full flex items-center gap-3 px-4 py-3 text-xs hover:bg-secondary/40 transition-colors text-left"
                        data-target={`order-detail-${p.dry_supply_id}-${idx}`}
                      >
                        <!-- Chevron -->
                        <svg class="order-chevron size-3 text-muted-foreground shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>

                        <!-- Cliente (protagonista) -->
                        <span class="flex-1 font-semibold text-foreground truncate">{o.customer_name}</span>

                        <!-- Unidades que consume -->
                        <span class="font-medium text-foreground shrink-0">
                          {o.quantity_contribution.toLocaleString("es-AR")} un.
                        </span>

                        <!-- Estado -->
                        <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold shrink-0" style={`background:${statusColor[o.status]}18;color:${statusColor[o.status]};`}>
                          {statusLabel[o.status] ?? o.status}
                        </span>

                        <!-- Mercado / destino -->
                        {o.market && (
                          <span class="rounded px-1.5 py-0.5 text-[10px] font-medium shrink-0" style="background:#f0eee6;color:#87867f;">
                            {marketLabel[o.market] ?? o.market}
                            {o.destination_country ? ` → ${o.destination_country}` : ""}
                          </span>
                        )}
                      </button>

                      <!-- Panel expandido con detalle del pedido -->
                      <div
                        id={`order-detail-${p.dry_supply_id}-${idx}`}
                        class="hidden border-t border-border/60"
                        style="background:#faf9f5;"
                      >
                        <div class="px-5 py-4 grid grid-cols-2 gap-x-8 gap-y-2 text-xs">
                          <div class="col-span-2 flex items-center justify-between mb-1">
                            <span class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Detalle del pedido</span>
                            <a
                              href={`/sale-orders/${o.order_id}`}
                              class="text-[11px] text-primary hover:underline font-medium"
                            >
                              Ir al pedido →
                            </a>
                          </div>
                          <div>
                            <span class="text-muted-foreground">ID</span>
                            <span class="ml-2 font-mono text-foreground">#{o.order_id.slice(0, 8).toUpperCase()}</span>
                          </div>
                          <div>
                            <span class="text-muted-foreground">Cliente</span>
                            <span class="ml-2 font-medium text-foreground">{o.customer_name}</span>
                          </div>
                          <div>
                            <span class="text-muted-foreground">Estado</span>
                            <span class="ml-2 font-semibold" style={`color:${statusColor[o.status]};`}>
                              {statusLabel[o.status] ?? o.status}
                            </span>
                          </div>
                          <div>
                            <span class="text-muted-foreground">Moneda</span>
                            <span class="ml-2 text-foreground">{o.currency || "—"}</span>
                          </div>
                          <div>
                            <span class="text-muted-foreground">Mercado</span>
                            <span class="ml-2 text-foreground">
                              {(marketLabel[o.market] ?? o.market) || "—"}
                              {o.destination_country ? ` → ${o.destination_country}` : ""}
                            </span>
                          </div>
                          <div>
                            <span class="text-muted-foreground">Demanda de este insumo</span>
                            <span class="ml-2 font-semibold text-foreground">{o.quantity_contribution.toLocaleString("es-AR")} un.</span>
                          </div>
                          <div>
                            <span class="text-muted-foreground">Vence en</span>
                            <span class="ml-2 font-medium" style={`color:${o.urgency_days <= 3 ? "#b53333" : "#8a6b1a"};`}>
                              {o.urgency_days} día{o.urgency_days !== 1 ? "s" : ""}
                            </span>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Actions -->
              <div class="flex items-center gap-2 pt-1">
                <button
                  class="btn-add-stock inline-flex items-center gap-1.5 rounded-lg bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors"
                  data-supply-id={p.dry_supply_id}
                  data-supply-name={p.name}
                  data-shortfall={p.shortfall}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
                    <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
                  </svg>
                  Agregar Stock
                </button>
                <a
                  href={`/chat?q=${encodeURIComponent(`¿Cómo manejo el faltante de "${p.name}"? Me faltan ${p.shortfall} unidades para cubrir ${p.orders_at_risk.length} pedidos activos.`)}`}
                  class="inline-flex items-center gap-1.5 rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-muted/60 transition-colors"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke-linecap="round"/>
                    <path d="M8 12h8M12 8v8" stroke-linecap="round"/>
                  </svg>
                  Consultar Asistente
                </a>
                <a href={`/dry-supplies/supply-detail?id=${p.dry_supply_id}`}
                  class="ml-auto text-xs text-muted-foreground hover:text-foreground transition-colors">
                  Ver detalle →
                </a>
              </div>
            </div>
          </div>
        ))}
      </section>
    )}

    <!-- ── Warning alerts ──────────────────────────────────── -->
    {warnings.length > 0 && (
      <section class="space-y-4">
        <div class="flex items-center gap-2">
          <span class="size-2 rounded-full shrink-0" style="background:#8a6b1a;"></span>
          <h2 class="text-sm font-semibold">Margen Ajustado</h2>
          <span class="text-xs text-muted-foreground">— cubiertos pero con poco margen de seguridad</span>
        </div>

        {warnings.map((p) => (
          <div class="rounded-xl border bg-card overflow-hidden" style="border-color:#8a6b1a30;">
            <div class="px-6 py-4 flex items-start justify-between gap-4" style="background:#8a6b1a08;">
              <div class="flex items-start gap-3">
                <div class="size-10 rounded-lg flex items-center justify-center shrink-0 text-xs font-bold text-white mt-0.5" style="background:#8a6b1a;">
                  {p.code.slice(0, 3).toUpperCase()}
                </div>
                <div>
                  <p class="font-semibold text-[15px] leading-tight">{p.name}</p>
                  <p class="text-xs text-muted-foreground mt-0.5">{p.code} · {p.category}</p>
                </div>
              </div>
              <span class="rounded-full px-2.5 py-1 text-[11px] font-bold shrink-0" style="background:#8a6b1a20;color:#8a6b1a;">
                {p.coverage_pct}% cubierto
              </span>
            </div>

            <div class="px-6 py-4 space-y-4">
              <p class="text-sm text-muted-foreground leading-relaxed">{p.natural_message}</p>

              <!-- Stock bar -->
              <div class="space-y-1.5">
                <div class="h-2 rounded-full overflow-hidden" style="background:#f0eee6;">
                  <div class="h-full rounded-full" style={`width:${Math.min(p.coverage_pct, 100)}%;background:#8a6b1a;`} />
                </div>
                <div class="flex items-center justify-between text-[11px] text-muted-foreground">
                  <span>Disponible: <strong class="text-foreground">{p.available_stock.toLocaleString("es-AR")}</strong></span>
                  <span>Necesario: <strong class="text-foreground">{p.total_needed.toLocaleString("es-AR")}</strong></span>
                </div>
              </div>

              <!-- Actions -->
              <div class="flex items-center gap-2">
                <button
                  class="btn-add-stock inline-flex items-center gap-1.5 rounded-lg border border-input bg-background px-3.5 py-2 text-sm font-medium hover:bg-muted/60 transition-colors"
                  data-supply-id={p.dry_supply_id}
                  data-supply-name={p.name}
                  data-shortfall={p.shortfall}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
                    <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
                  </svg>
                  Agregar Stock
                </button>
                <a href={`/dry-supplies/supply-detail?id=${p.dry_supply_id}`}
                  class="text-xs text-muted-foreground hover:text-foreground transition-colors ml-auto">
                  Ver detalle →
                </a>
              </div>
            </div>
          </div>
        ))}
      </section>
    )}

  </div>
</AppLayout>

<!-- ── Add stock modal ─────────────────────────────────────── -->
<div id="modal-stock" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-card border border-border rounded-2xl shadow-xl w-full max-w-sm mx-4 p-6 space-y-4">
    <div>
      <h2 class="text-base font-semibold">Agregar Stock</h2>
      <p id="modal-supply-name" class="text-sm text-muted-foreground mt-0.5"></p>
    </div>

    <div class="space-y-3">
      <div>
        <label class="text-sm font-medium">Cantidad a ingresar</label>
        <input id="stock-qty" type="number" min="1"
          class="mt-1.5 w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
          placeholder="ej: 500"/>
        <p id="stock-hint" class="text-xs text-muted-foreground mt-1"></p>
      </div>
      <div>
        <label class="text-sm font-medium">Referencia / remito</label>
        <input id="stock-ref" type="text"
          class="mt-1.5 w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
          placeholder="ej: Remito #1234"/>
      </div>
    </div>

    <p id="stock-error" class="hidden text-xs text-destructive"></p>

    <div class="flex justify-end gap-2 pt-1">
      <button id="modal-cancel-stock"
        class="rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-muted/60 transition-colors">
        Cancelar
      </button>
      <button id="modal-confirm-stock"
        class="rounded-lg bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors disabled:opacity-50">
        Confirmar ingreso
      </button>
    </div>
  </div>
</div>

<script is:inline>
  // ── Acordeón de pedidos ───────────────────────────────────────────────────
  document.querySelectorAll(".order-row").forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = btn.getAttribute("data-target");
      const panel = document.getElementById(targetId);
      const chevron = btn.querySelector(".order-chevron");
      if (!panel) return;

      const isOpen = !panel.classList.contains("hidden");
      panel.classList.toggle("hidden", isOpen);
      chevron.style.transform = isOpen ? "" : "rotate(90deg)";
    });
  });

  let _activeSupplyId = "";

  const modal     = document.getElementById("modal-stock");
  const qtyInput  = document.getElementById("stock-qty");
  const refInput  = document.getElementById("stock-ref");
  const errorEl   = document.getElementById("stock-error");
  const hintEl    = document.getElementById("stock-hint");
  const nameEl    = document.getElementById("modal-supply-name");
  const confirmBtn = document.getElementById("modal-confirm-stock");

  function showModal(supplyId, supplyName, shortfall) {
    _activeSupplyId = supplyId;
    nameEl.textContent = supplyName;
    hintEl.textContent = shortfall > 0
      ? `Faltante actual: ${Number(shortfall).toLocaleString("es-AR")} unidades`
      : "";
    qtyInput.value = shortfall > 0 ? String(shortfall) : "";
    refInput.value = "";
    errorEl.classList.add("hidden");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    qtyInput.focus();
  }
  function hideModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  }

  document.querySelectorAll(".btn-add-stock").forEach((btn) => {
    btn.addEventListener("click", () => {
      showModal(btn.dataset.supplyId, btn.dataset.supplyName, Number(btn.dataset.shortfall));
    });
  });

  document.getElementById("modal-cancel-stock").addEventListener("click", hideModal);
  modal.addEventListener("click", (e) => { if (e.target === modal) hideModal(); });

  confirmBtn.addEventListener("click", async () => {
    const qty = parseInt(qtyInput.value, 10);
    if (!qty || qty <= 0) {
      errorEl.textContent = "Ingresá una cantidad válida.";
      errorEl.classList.remove("hidden");
      return;
    }
    errorEl.classList.add("hidden");
    confirmBtn.disabled = true;
    confirmBtn.textContent = "Guardando…";

    try {
      const res = await fetch(`/api/dry-supplies/${_activeSupplyId}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ quantity: qty, reference: refInput.value.trim() || undefined }),
      });
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? `Error ${res.status}`);
      }
      hideModal();
      window.location.reload();
    } catch (e) {
      errorEl.textContent = e.message ?? "Error al guardar.";
      errorEl.classList.remove("hidden");
    } finally {
      confirmBtn.disabled = false;
      confirmBtn.textContent = "Confirmar ingreso";
    }
  });
</script>
