---
import AppLayout from "@/layouts/AppLayout.astro";
import { getInventoryReport } from "@/lib/grpc/inventoryClient";
import { COOKIE_NAME } from "@/lib/auth";
import type { InventoryReport } from "@/lib/grpc/types";

const token = Astro.cookies.get(COOKIE_NAME)?.value;
let report: InventoryReport | null = null;
let loadError: string | null = null;

try {
  report = await getInventoryReport(token);
} catch (e: any) {
  loadError = e.details ?? e.message ?? "Error al conectar con el servidor";
}

const products = report?.products ?? [];
const alerts = report?.dry_supply_alerts ?? [];
const lowAlerts = alerts.filter((a) => a.is_low);
const totalUndressed = products.reduce((s, p) => s + p.undressed_stock, 0);
const totalDressedAvail = products.reduce((s, p) => s + p.dressed_available, 0);

// One accent colour per product (cycles)
const palette = [
  { accent: "#4E0707", bg: "rgba(78,7,7,0.08)",    bar: "#4E0707" },
  { accent: "#556B2F", bg: "rgba(85,107,47,0.08)",  bar: "#556B2F" },
  { accent: "#B8860B", bg: "rgba(184,134,11,0.08)", bar: "#B8860B" },
  { accent: "#1E3A5F", bg: "rgba(30,58,95,0.08)",   bar: "#1E3A5F" },
];
---

<AppLayout title="Inventario">
  <div class="px-8 py-8 max-w-7xl mx-auto">

    <!-- ── Header ─────────────────────────────────────────── -->
    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold tracking-tight font-display">Inventario</h1>
        <p class="text-sm text-muted-foreground mt-1">Stock tricapa · SV sin vestir · PT producto terminado</p>
      </div>
      <div class="flex gap-2 shrink-0">
        <button id="btn-add-sv"
          class="inline-flex items-center gap-1.5 rounded-md border border-border bg-card px-3.5 py-2 text-sm font-medium hover:bg-muted/60 transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M12 5v14M5 12h14" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Agregar SV
        </button>
        <button id="btn-convert"
          class="inline-flex items-center gap-1.5 rounded-md bg-primary text-primary-foreground px-3.5 py-2 text-sm font-medium hover:bg-primary/90 transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M4 4v6h6M20 20v-6h-6" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M20 10A8 8 0 004.93 14.93M4 14a8 8 0 0015.07-4.07" stroke-linecap="round"/>
          </svg>
          SV → PT
        </button>
      </div>
    </div>

    <!-- ── Error ───────────────────────────────────────────── -->
    {loadError && (
      <div class="rounded-xl border border-destructive/30 bg-destructive/5 p-8 text-center mb-8">
        <h3 class="font-semibold text-sm text-destructive">No se pudo conectar con el servidor gRPC</h3>
        <p class="text-sm text-muted-foreground mt-1">{loadError}</p>
      </div>
    )}

    {!loadError && report && (
      <>
        <!-- ── KPI bar ────────────────────────────────────── -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
          {([
            { label: "Productos",     value: String(products.length),                    sub: "en sistema",           icon: "M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM16 3H8L6 7h12l-2-4z", color: "#4E0707" },
            { label: "SV disponible", value: totalUndressed.toLocaleString("es-AR"),     sub: "botellas sin vestir",  icon: "M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18", color: "#B8860B" },
            { label: "PT disponible", value: totalDressedAvail.toLocaleString("es-AR"),  sub: "producto terminado",   icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", color: "#22C55E" },
            { label: "Alertas",       value: String(lowAlerts.length),                   sub: "insumos stock bajo",   icon: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z", color: lowAlerts.length > 0 ? "#EF4444" : "#22C55E" },
          ] as const).map(({ label, value, sub, icon, color }) => (
            <div class="rounded-xl border border-border bg-card p-5 flex items-start gap-3">
              <div class="shrink-0 size-9 rounded-lg flex items-center justify-center mt-0.5" style={`background: ${color}18;`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4.5" style={`color: ${color};`}>
                  <path d={icon} stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-[11px] font-medium text-muted-foreground uppercase tracking-wider">{label}</p>
                <p class="mt-0.5 text-2xl font-bold tracking-tight font-display" style={`color: ${color};`}>{value}</p>
                <p class="text-[11px] text-muted-foreground mt-0.5">{sub}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- ── Products section ──────────────────────────── -->
        <div class="mb-10">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Vinos en Stock</h2>
            <div class="relative">
              <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 size-3.5 text-muted-foreground pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/>
              </svg>
              <input id="search-products" type="search" placeholder="Buscar…"
                class="pl-8 pr-3 py-1.5 text-sm rounded-md border border-input bg-card focus:outline-none focus:ring-2 focus:ring-ring w-44"/>
            </div>
          </div>

          {products.length === 0 ? (
            <div class="rounded-xl border border-border bg-card p-14 text-center">
              <p class="text-sm text-muted-foreground">Sin datos de inventario de producto.</p>
            </div>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
              {products.map((p, i) => {
                const pal = palette[i % palette.length];
                const total = p.dressed_physical + p.undressed_stock;
                const svPct  = total > 0 ? Math.min(Math.round((p.undressed_stock    / total) * 100), 100) : 0;
                const availPct = total > 0 ? Math.min(Math.round((p.dressed_available / total) * 100), 100) : 0;
                return (
                  <div class="product-row rounded-xl bg-card border border-border overflow-hidden hover:shadow-lg transition-all duration-200 flex flex-col"
                    data-name={p.product_name.toLowerCase()}>

                    <!-- Bottle hero -->
                    <div class="relative flex items-end justify-center pt-8 pb-4 overflow-hidden" style={`background: ${pal.bg};`}>
                      <!-- subtle radial glow -->
                      <div class="absolute inset-0 pointer-events-none"
                        style={`background: radial-gradient(ellipse 60% 40% at 50% 90%, ${pal.accent}22 0%, transparent 70%);`}/>
                      <!-- wine bottle SVG -->
                      <svg viewBox="0 0 56 140" class="relative h-[130px] drop-shadow-lg" xmlns="http://www.w3.org/2000/svg">
                        <!-- cork -->
                        <rect x="24" y="0" width="8" height="11" rx="3" fill="#C8A97E" opacity="0.95"/>
                        <!-- foil capsule -->
                        <path d="M20 7 L36 7 L37 22 Q36 26 28 26 Q20 26 19 22 Z" fill={pal.accent} opacity="0.8"/>
                        <!-- neck -->
                        <rect x="22" y="22" width="12" height="26" rx="2" fill={pal.accent} opacity="0.96"/>
                        <!-- shoulder -->
                        <path d="M22 48 Q14 60 13 74 L43 74 Q42 60 34 48 Z" fill={pal.accent}/>
                        <!-- body -->
                        <rect x="13" y="73" width="30" height="54" rx="2" fill={pal.accent}/>
                        <!-- bottom -->
                        <path d="M13 125 Q13 130 16 131 L40 131 Q43 130 43 125 Z" fill={pal.accent} opacity="0.85"/>
                        <!-- label rect -->
                        <rect x="16" y="82" width="24" height="30" rx="3" fill="white" opacity="0.18"/>
                        <!-- punt dip -->
                        <ellipse cx="28" cy="130" rx="8" ry="3" fill={pal.accent} opacity="0.5"/>
                      </svg>
                      <!-- SKU badge -->
                      <span class="absolute top-3 right-3 font-mono text-[10px] font-bold px-2 py-1 rounded-md text-white/90 tracking-wide"
                        style={`background: ${pal.accent};`}>
                        {p.sku || p.product_id.slice(0, 4).toUpperCase()}
                      </span>
                    </div>

                    <!-- Card body -->
                    <div class="px-4 pt-4 pb-3 flex-1">
                      <h3 class="font-display font-bold text-[15px] leading-tight text-foreground">{p.product_name}</h3>
                      <p class="text-[11px] text-muted-foreground font-mono mt-0.5 truncate">{p.product_id.slice(0, 12)}…</p>

                      <!-- Stock bars -->
                      <div class="mt-4 space-y-3">
                        <div>
                          <div class="flex justify-between mb-1">
                            <span class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">Sin Vestir</span>
                            <span class="text-[12px] font-bold font-mono">{p.undressed_stock.toLocaleString("es-AR")}</span>
                          </div>
                          <div class="h-1.5 rounded-full overflow-hidden" style="background: rgba(0,0,0,0.08);">
                            <div class="h-full rounded-full" style={`width:${svPct}%; background:#B8860B;`}/>
                          </div>
                        </div>
                        <div>
                          <div class="flex justify-between mb-1">
                            <span class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">PT Disponible</span>
                            <span class="text-[12px] font-bold font-mono" style={`color:${pal.accent};`}>{p.dressed_available.toLocaleString("es-AR")}</span>
                          </div>
                          <div class="h-1.5 rounded-full overflow-hidden" style="background: rgba(0,0,0,0.08);">
                            <div class="h-full rounded-full" style={`width:${availPct}%; background:${pal.bar};`}/>
                          </div>
                        </div>
                        {p.dressed_committed > 0 && (
                          <div class="flex justify-between text-[11px] pt-0.5">
                            <span class="text-muted-foreground">Comprometido</span>
                            <span class="font-mono font-semibold" style="color:#B8860B;">{p.dressed_committed.toLocaleString("es-AR")}</span>
                          </div>
                        )}
                      </div>
                    </div>

                    <!-- Card footer actions -->
                    <div class="px-4 pb-4 flex gap-2">
                      <button
                        class="btn-card-sv flex-1 text-[12px] font-semibold py-1.5 rounded-md border border-border bg-background hover:bg-muted/60 transition-colors"
                        data-product-id={p.product_id}
                        data-product-name={p.product_name}>
                        + SV
                      </button>
                      <button
                        class="btn-card-convert flex-1 text-[12px] font-semibold py-1.5 rounded-md text-white transition-colors hover:opacity-90"
                        style={`background:${pal.accent};`}
                        data-product-id={p.product_id}
                        data-product-name={p.product_name}>
                        SV → PT
                      </button>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>

        <!-- ── Insumos alerts ─────────────────────────────── -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <h2 class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Alertas de Insumos</h2>
            {lowAlerts.length > 0 && (
              <span class="inline-flex items-center rounded-full bg-destructive/10 text-destructive px-2.5 py-0.5 text-[11px] font-semibold">
                {lowAlerts.length} bajo stock
              </span>
            )}
          </div>

          {alerts.length === 0 ? (
            <div class="rounded-xl border border-border bg-card p-10 text-center">
              <p class="text-sm text-muted-foreground">Sin datos de insumos.</p>
            </div>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
              {alerts.map((a) => {
                const pct = a.physical > 0 ? Math.min(Math.round((a.available / a.physical) * 100), 100) : 0;
                const color = a.is_low ? "#EF4444" : "#22C55E";
                return (
                  <div class:list={[
                    "rounded-xl border bg-card p-4 flex flex-col gap-3 transition-shadow hover:shadow-md",
                    a.is_low ? "border-destructive/30 bg-destructive/5" : "border-border",
                  ]}>
                    <div class="flex items-start justify-between gap-2">
                      <div class="min-w-0">
                        <span class="font-mono text-[10px] text-muted-foreground">{a.code}</span>
                        <p class="font-semibold text-sm leading-tight mt-0.5 truncate">{a.name}</p>
                      </div>
                      <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-bold"
                        style={`background:${color}18; color:${color};`}>
                        {a.is_low ? "BAJO" : "OK"}
                      </span>
                    </div>
                    <div class="space-y-1.5 text-[12px]">
                      <div class="flex justify-between text-muted-foreground">
                        <span>Físico</span>
                        <span class="font-mono font-medium text-foreground">{a.physical.toLocaleString("es-AR")}</span>
                      </div>
                      <div class="flex justify-between text-muted-foreground">
                        <span>Comprometido</span>
                        <span class="font-mono font-medium" style="color:#B8860B;">{a.committed.toLocaleString("es-AR")}</span>
                      </div>
                      <div class="flex justify-between text-muted-foreground">
                        <span>Disponible</span>
                        <span class="font-mono font-bold" style={`color:${color};`}>{a.available.toLocaleString("es-AR")}</span>
                      </div>
                    </div>
                    <div>
                      <div class="h-1.5 rounded-full overflow-hidden" style="background:rgba(0,0,0,0.08);">
                        <div class="h-full rounded-full transition-all" style={`width:${pct}%; background:${color};`}/>
                      </div>
                      <p class="text-[10px] text-muted-foreground mt-1 text-right">{pct}% disponible</p>
                    </div>
                    <button
                      class="btn-add-stock w-full flex items-center justify-center gap-1.5 rounded-md border border-border bg-background py-1.5 text-[12px] font-semibold hover:bg-muted/60 transition-colors"
                      data-supply-id={a.dry_supply_id}
                      data-supply-name={a.name}>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
                        <path d="M12 5v14M5 12h14" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      Añadir Stock
                    </button>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </>
    )}
  </div>
</AppLayout>

<!-- ── Modal Agregar SV ────────────────────────────────────── -->
<div id="modal-add-sv" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-card border border-border rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
    <h2 class="text-base font-semibold mb-1">Agregar botellas Sin Vestir</h2>
    <p class="text-xs text-muted-foreground mb-4">Ingresa botellas sin vestir al inventario de un producto.</p>
    <div class="space-y-3">
      <div>
        <label for="sv-product" class="text-sm font-medium">Producto <span class="text-destructive">*</span></label>
        <select id="sv-product" class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
          <option value="">— seleccionar —</option>
          {products.map((p) => <option value={p.product_id}>{p.product_name}</option>)}
        </select>
      </div>
      <div>
        <label for="sv-quantity" class="text-sm font-medium">Cantidad <span class="text-destructive">*</span></label>
        <input id="sv-quantity" type="number" min="1" value="100"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <div>
        <label for="sv-reference" class="text-sm font-medium">Referencia</label>
        <input id="sv-reference" type="text" placeholder="ej: ingreso cosecha 2025"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <p id="sv-error" class="hidden text-xs text-destructive"></p>
      <p id="sv-success" class="hidden text-xs text-success font-medium"></p>
    </div>
    <div class="flex justify-end gap-2 mt-6">
      <button id="sv-cancel" class="rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-muted/60 transition-colors">Cancelar</button>
      <button id="sv-confirm" class="rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors">Agregar</button>
    </div>
  </div>
</div>

<!-- ── Modal SV → PT ──────────────────────────────────────── -->
<div id="modal-convert" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-card border border-border rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
    <h2 class="text-base font-semibold mb-1">Convertir SV → PT</h2>
    <p class="text-xs text-muted-foreground mb-4">Transforma botellas Sin Vestir en Producto Terminado asignando un lote.</p>
    <div class="space-y-3">
      <div>
        <label for="cv-product" class="text-sm font-medium">Producto <span class="text-destructive">*</span></label>
        <select id="cv-product" class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
          <option value="">— seleccionar —</option>
          {products.map((p) => <option value={p.product_id}>{p.product_name}</option>)}
        </select>
      </div>
      <div>
        <label for="cv-quantity" class="text-sm font-medium">Cantidad <span class="text-destructive">*</span></label>
        <input id="cv-quantity" type="number" min="1" value="100"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <div>
        <label for="cv-lot" class="text-sm font-medium">Número de Lote <span class="text-destructive">*</span></label>
        <input id="cv-lot" type="text" placeholder="ej: L-050326-2400"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <p id="cv-error" class="hidden text-xs text-destructive"></p>
      <p id="cv-success" class="hidden text-xs text-success font-medium"></p>
    </div>
    <div class="flex justify-end gap-2 mt-6">
      <button id="cv-cancel" class="rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-muted/60 transition-colors">Cancelar</button>
      <button id="cv-confirm" class="rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors">Convertir</button>
    </div>
  </div>
</div>

<!-- ── Modal Añadir Stock Insumo ───────────────────────────── -->
<div id="modal-add-stock-ds" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-card border border-border rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
    <h2 class="text-base font-semibold mb-1">Añadir Stock</h2>
    <p id="ds-modal-name" class="text-xs text-muted-foreground mb-4"></p>
    <div class="space-y-3">
      <div>
        <label for="ds-quantity" class="text-sm font-medium">Cantidad <span class="text-destructive">*</span></label>
        <input id="ds-quantity" type="number" min="1" value="100"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <div>
        <label for="ds-reference" class="text-sm font-medium">Referencia</label>
        <input id="ds-reference" type="text" placeholder="ej: compra proveedor"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <p id="ds-error"   class="hidden text-xs text-destructive"></p>
      <p id="ds-success" class="hidden text-xs font-medium" style="color:#22C55E;"></p>
    </div>
    <div class="flex justify-end gap-2 mt-6">
      <button id="ds-cancel"  class="rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-muted/60 transition-colors">Cancelar</button>
      <button id="ds-confirm" class="rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors">Añadir</button>
    </div>
  </div>
</div>

<script>
  function showModal(el: HTMLElement) { el.classList.remove("hidden"); el.classList.add("flex"); }
  function hideModal(el: HTMLElement) { el.classList.add("hidden"); el.classList.remove("flex"); }

  // Search
  document.getElementById("search-products")?.addEventListener("input", (e) => {
    const q = (e.target as HTMLInputElement).value.toLowerCase().trim();
    document.querySelectorAll<HTMLElement>(".product-row").forEach((row) => {
      row.style.display = !q || (row.dataset.name ?? "").includes(q) ? "" : "none";
    });
  });

  // ── SV modal ────────────────────────────────────────────
  const modalSV = document.getElementById("modal-add-sv")!;
  const svProduct = document.getElementById("sv-product") as HTMLSelectElement;
  const svQty     = document.getElementById("sv-quantity") as HTMLInputElement;
  const svRef     = document.getElementById("sv-reference") as HTMLInputElement;
  const svError   = document.getElementById("sv-error")!;
  const svSuccess = document.getElementById("sv-success")!;

  document.getElementById("btn-add-sv")!.addEventListener("click", () => showModal(modalSV));
  document.getElementById("sv-cancel")!.addEventListener("click", () => hideModal(modalSV));
  modalSV.addEventListener("click", (e) => { if (e.target === modalSV) hideModal(modalSV); });

  // per-card SV button — pre-select product
  document.querySelectorAll<HTMLElement>(".btn-card-sv").forEach((btn) => {
    btn.addEventListener("click", () => {
      svProduct.value = btn.dataset.productId ?? "";
      showModal(modalSV);
    });
  });

  document.getElementById("sv-confirm")!.addEventListener("click", async () => {
    svError.classList.add("hidden"); svSuccess.classList.add("hidden");
    const product_id = svProduct.value;
    const quantity   = parseInt(svQty.value, 10);
    if (!product_id) { svError.textContent = "Seleccioná un producto."; svError.classList.remove("hidden"); return; }
    if (!quantity || quantity < 1) { svError.textContent = "Cantidad debe ser > 0."; svError.classList.remove("hidden"); return; }
    try {
      const res = await fetch("/api/inventory/add-undressed", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ product_id, quantity, reference: svRef.value.trim() }),
      });
      if (res.ok) {
        svSuccess.textContent = "Stock SV agregado. Recargando…"; svSuccess.classList.remove("hidden");
        setTimeout(() => { hideModal(modalSV); window.location.reload(); }, 1200);
      } else {
        const body = await res.json().catch(() => ({}));
        svError.textContent = body.error ?? `Error ${res.status}`; svError.classList.remove("hidden");
      }
    } catch { svError.textContent = "Error de red."; svError.classList.remove("hidden"); }
  });

  // ── Convert modal ────────────────────────────────────────
  const modal    = document.getElementById("modal-convert")!;
  const cvProduct = document.getElementById("cv-product") as HTMLSelectElement;
  const cvQty     = document.getElementById("cv-quantity") as HTMLInputElement;
  const cvLot     = document.getElementById("cv-lot") as HTMLInputElement;
  const cvError   = document.getElementById("cv-error")!;
  const cvSuccess = document.getElementById("cv-success")!;

  document.getElementById("btn-convert")!.addEventListener("click", () => showModal(modal));
  document.getElementById("cv-cancel")!.addEventListener("click", () => hideModal(modal));
  modal.addEventListener("click", (e) => { if (e.target === modal) hideModal(modal); });

  document.querySelectorAll<HTMLElement>(".btn-card-convert").forEach((btn) => {
    btn.addEventListener("click", () => {
      cvProduct.value = btn.dataset.productId ?? "";
      showModal(modal);
    });
  });

  document.getElementById("cv-confirm")!.addEventListener("click", async () => {
    cvError.classList.add("hidden"); cvSuccess.classList.add("hidden");
    const productId = cvProduct.value;
    const quantity  = parseInt(cvQty.value, 10);
    const lotNumber = cvLot.value.trim();
    if (!productId) { cvError.textContent = "Seleccioná un producto."; cvError.classList.remove("hidden"); return; }
    if (!quantity || quantity < 1) { cvError.textContent = "Cantidad debe ser > 0."; cvError.classList.remove("hidden"); return; }
    if (!lotNumber) { cvError.textContent = "El número de lote es obligatorio."; cvError.classList.remove("hidden"); return; }
    try {
      const res = await fetch("/api/inventory/convert", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ product_id: productId, quantity, lot_number: lotNumber }),
      });
      if (res.ok) {
        cvSuccess.textContent = "Conversión exitosa. Recargando…"; cvSuccess.classList.remove("hidden");
        setTimeout(() => { hideModal(modal); window.location.reload(); }, 1200);
      } else {
        const body = await res.json().catch(() => ({}));
        cvError.textContent = body.error ?? `Error ${res.status}`; cvError.classList.remove("hidden");
      }
    } catch { cvError.textContent = "Error de red."; cvError.classList.remove("hidden"); }
  });

  // ── Add dry supply stock modal ────────────────────────────
  const modalDS  = document.getElementById("modal-add-stock-ds")!;
  const dsQty    = document.getElementById("ds-quantity")    as HTMLInputElement;
  const dsRef    = document.getElementById("ds-reference")   as HTMLInputElement;
  const dsError  = document.getElementById("ds-error")!;
  const dsSuccess = document.getElementById("ds-success")!;
  let _dsSupplyId = "";

  document.getElementById("ds-cancel")!.addEventListener("click", () => hideModal(modalDS));
  modalDS.addEventListener("click", (e) => { if (e.target === modalDS) hideModal(modalDS); });

  document.querySelectorAll<HTMLElement>(".btn-add-stock").forEach((btn) => {
    btn.addEventListener("click", () => {
      _dsSupplyId = btn.dataset.supplyId ?? "";
      document.getElementById("ds-modal-name")!.textContent = btn.dataset.supplyName ?? "";
      dsQty.value = "100"; dsRef.value = "";
      dsError.classList.add("hidden"); dsSuccess.classList.add("hidden");
      showModal(modalDS);
    });
  });

  document.getElementById("ds-confirm")!.addEventListener("click", async () => {
    dsError.classList.add("hidden"); dsSuccess.classList.add("hidden");
    const qty = parseInt(dsQty.value, 10);
    if (!_dsSupplyId) { dsError.textContent = "Insumo no identificado."; dsError.classList.remove("hidden"); return; }
    if (!qty || qty < 1) { dsError.textContent = "Cantidad debe ser > 0."; dsError.classList.remove("hidden"); return; }
    try {
      const res = await fetch(`/api/dry-supplies/${_dsSupplyId}`, {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ quantity: qty, reference: dsRef.value.trim() || "manual" }),
      });
      if (res.ok) {
        dsSuccess.textContent = "Stock añadido. Recargando…"; dsSuccess.classList.remove("hidden");
        setTimeout(() => { hideModal(modalDS); window.location.reload(); }, 1200);
      } else {
        const body = await res.json().catch(() => ({}));
        dsError.textContent = body.error ?? `Error ${res.status}`; dsError.classList.remove("hidden");
      }
    } catch { dsError.textContent = "Error de red."; dsError.classList.remove("hidden"); }
  });
</script>
