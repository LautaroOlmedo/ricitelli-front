---
import AppLayout from "@/layouts/AppLayout.astro";
import { getProductByID } from "@/lib/grpc/productClient";
import { getDrySupplies } from "@/lib/grpc/drySupplyClient";
import { COOKIE_NAME } from "@/lib/auth";

const token = Astro.cookies.get(COOKIE_NAME)?.value;
const id = Astro.url.searchParams.get("id") ?? "";

let product: any = null;
let supplies: any[] = [];
let loadError = "";

if (!id) return Astro.redirect("/products");

try {
  [product, supplies] = await Promise.all([
    getProductByID(id, token),
    getDrySupplies(token).catch(() => []),
  ]);
} catch (e: any) {
  loadError = e.details ?? e.message ?? "Error al cargar";
}
---

<AppLayout title="Editar Producto">
  <div class="px-8 py-8 max-w-2xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6">
      <a href="/products" class="hover:text-foreground transition-colors">Productos</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {product && (
        <>
          <a href={`/products/product-detail?id=${id}`} class="hover:text-foreground transition-colors">{product.name}</a>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
            <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </>
      )}
      <span class="text-foreground font-medium">Editar</span>
    </nav>

    <h1 class="text-2xl font-semibold tracking-tight mb-6">Editar Producto</h1>

    {loadError && (
      <div class="rounded-xl border border-destructive/30 bg-destructive/5 p-4 text-sm text-destructive mb-6">{loadError}</div>
    )}

    {product && (
      <div class="rounded-xl border border-border bg-card p-6">
        <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-800/40 px-4 py-3 text-sm text-amber-800 dark:text-amber-300">
          Modificar el BOM afectará únicamente las nuevas órdenes de producción.
        </div>

        <form id="edit-form" class="space-y-5">
          <input type="hidden" id="product-id" value={product.id} />

          <div>
            <label for="product-name" class="block text-sm font-medium mb-1.5">
              Nombre del Producto <span class="text-destructive">*</span>
            </label>
            <input
              id="product-name"
              type="text"
              required
              value={product.name}
              class="w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
            />
          </div>

          <!-- BOM -->
          <div>
            <label class="block text-sm font-medium mb-2">Bill of Materials (BOM)</label>
            <div id="bom-rows" class="space-y-2 mb-3">
              {product.bom.map((b: any, idx: number) => (
                <div class="bom-row flex items-center gap-2">
                  <select
                    class="bom-supply flex-1 rounded-lg border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
                    data-value={b.dry_supply_id}
                  >
                    <option value="">— Seleccionar insumo —</option>
                    {supplies.map((s: any) => (
                      <option value={s.id} selected={s.id === b.dry_supply_id}>
                        {s.code} — {s.name}
                      </option>
                    ))}
                  </select>
                  <input
                    type="number"
                    min="1"
                    value={b.quantity_per_unit}
                    placeholder="Cant."
                    class="bom-qty w-24 rounded-lg border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
                  />
                  <button
                    type="button"
                    class="bom-remove inline-flex items-center justify-center size-8 rounded-lg border border-destructive/30 text-destructive hover:bg-destructive/10 transition-colors"
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
                      <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
                    </svg>
                  </button>
                </div>
              ))}
            </div>
            <button
              type="button"
              id="add-bom-row"
              class="inline-flex items-center gap-1.5 text-sm text-primary hover:underline"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
                <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
              </svg>
              Agregar insumo
            </button>
          </div>

          <p id="error-msg" class="hidden text-sm text-destructive"></p>

          <div class="flex justify-end gap-2 pt-2">
            <a
              href={`/products/product-detail?id=${product.id}`}
              class="inline-flex items-center rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent transition-colors"
            >
              Cancelar
            </a>
            <button
              type="submit"
              id="save-btn"
              class="inline-flex items-center rounded-lg bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors disabled:opacity-60"
            >
              Guardar cambios
            </button>
          </div>
        </form>
      </div>
    )}
  </div>
</AppLayout>

<script define:vars={{ suppliesData: supplies }}>
  const bomRows = document.getElementById("bom-rows");
  const addBtn  = document.getElementById("add-bom-row");
  const form    = document.getElementById("edit-form");
  const errorMsg = document.getElementById("error-msg");
  const saveBtn  = document.getElementById("save-btn");

  function buildSupplyOptions(selected = "") {
    return `<option value="">— Seleccionar insumo —</option>` +
      suppliesData.map((s) =>
        `<option value="${s.id}" ${s.id === selected ? "selected" : ""}>${s.code} — ${s.name}</option>`
      ).join("");
  }

  function addRow(supplyId = "", qty = 1) {
    const div = document.createElement("div");
    div.className = "bom-row flex items-center gap-2";
    div.innerHTML = `
      <select class="bom-supply flex-1 rounded-lg border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
        ${buildSupplyOptions(supplyId)}
      </select>
      <input type="number" min="1" value="${qty}" placeholder="Cant."
        class="bom-qty w-24 rounded-lg border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      <button type="button" class="bom-remove inline-flex items-center justify-center size-8 rounded-lg border border-destructive/30 text-destructive hover:bg-destructive/10 transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
        </svg>
      </button>`;
    bomRows.appendChild(div);
    div.querySelector(".bom-remove").addEventListener("click", () => div.remove());
  }

  // Bind remove buttons on existing rows
  document.querySelectorAll(".bom-remove").forEach((btn) => {
    btn.addEventListener("click", () => btn.closest(".bom-row")?.remove());
  });

  addBtn?.addEventListener("click", () => addRow());

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorMsg.classList.add("hidden");
    saveBtn.disabled = true;
    saveBtn.textContent = "Guardando...";

    const id = document.getElementById("product-id").value;
    const name = document.getElementById("product-name").value.trim();
    const rows = document.querySelectorAll(".bom-row");
    const bom = [];
    for (const row of rows) {
      const supplyId = row.querySelector(".bom-supply").value;
      const qty = parseInt(row.querySelector(".bom-qty").value, 10);
      if (supplyId && qty > 0) bom.push({ dry_supply_id: supplyId, quantity_per_unit: qty });
    }

    try {
      const res = await fetch(`/api/products/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, bom }),
      });
      if (res.ok) {
        window.location.href = `/products/product-detail?id=${id}`;
      } else {
        const d = await res.json().catch(() => ({}));
        errorMsg.textContent = d.error ?? `Error ${res.status}`;
        errorMsg.classList.remove("hidden");
      }
    } catch {
      errorMsg.textContent = "Error de red.";
      errorMsg.classList.remove("hidden");
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = "Guardar cambios";
    }
  });
</script>
