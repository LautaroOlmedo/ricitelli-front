---
import AppLayout from "@/layouts/AppLayout.astro";
import { getDrySupplies } from "@/lib/grpc/drySupplyClient";
import { COOKIE_NAME } from "@/lib/auth";

const token = Astro.cookies.get(COOKIE_NAME)?.value;
const supplies = await getDrySupplies(token).catch(() => []) as any[];

const categoryColor: Record<string, string> = {
  LABEL: "#3B82F6", CONTRAETIQUETA: "#A855F7", BOX: "#B8860B",
  CORK: "#556B2F", CAPSULE: "#EF4444", BOTTLE: "#4E0707", OTHER: "#8B7355",
};
---

<AppLayout title="Nuevo Producto">
  <div class="px-6 py-8 max-w-3xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6">
      <a href="/products" class="hover:text-foreground transition-colors">Productos</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-foreground font-medium">Nuevo producto</span>
    </nav>

    <!-- Hero header -->
    <div class="rounded-2xl border border-border overflow-hidden mb-6"
      style="background: linear-gradient(135deg, rgba(78,7,7,0.06) 0%, transparent 60%);">
      <div class="p-6 flex items-center gap-5">
        <div class="size-14 rounded-2xl flex items-center justify-center shrink-0"
          style="background:rgba(78,7,7,0.12); border:2px solid rgba(78,7,7,0.2);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-7"
            style="color:#4E0707;">
            <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <h1 class="text-xl font-bold tracking-tight">Nuevo Producto</h1>
          <p class="text-sm text-muted-foreground mt-0.5">
            Definí el nombre y la lista de materiales requeridos para fabricar este producto.
          </p>
        </div>
      </div>
    </div>

    <form id="product-form" novalidate class="space-y-5">

      <!-- ── Información general ──────────────────────────── -->
      <div class="rounded-xl border border-border bg-card overflow-hidden">
        <div class="px-5 py-4 border-b border-border bg-muted/30">
          <h2 class="text-sm font-semibold">Información general</h2>
          <p class="text-xs text-muted-foreground mt-0.5">Identificación del producto en el catálogo</p>
        </div>
        <div class="px-5 py-5 space-y-4">
          <div>
            <label for="product-name" class="text-sm font-medium">
              Nombre del Producto <span class="text-destructive">*</span>
            </label>
            <input
              id="product-name"
              type="text"
              placeholder="ej: Hey Malbec! 750ml"
              autocomplete="off"
              class="mt-1.5 w-full rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring transition-shadow"
            />
            <p id="name-error" class="hidden text-xs text-destructive mt-1.5">El nombre es obligatorio.</p>
          </div>
          <div>
            <label for="product-sku" class="text-sm font-medium">
              SKU <span class="text-destructive">*</span>
            </label>
            <input
              id="product-sku"
              type="text"
              placeholder="ej: HEYM-750"
              autocomplete="off"
              class="mt-1.5 w-full rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm font-mono placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring transition-shadow"
            />
            <p id="sku-error" class="hidden text-xs text-destructive mt-1.5">El SKU es obligatorio.</p>
          </div>
        </div>
      </div>

      <!-- ── BOM ──────────────────────────────────────────── -->
      <div class="rounded-xl border border-border bg-card overflow-hidden">
        <div class="px-5 py-4 border-b border-border bg-muted/30 flex items-center justify-between">
          <div>
            <h2 class="text-sm font-semibold">Lista de Materiales (BOM)</h2>
            <p class="text-xs text-muted-foreground mt-0.5">Insumos secos necesarios por unidad fabricada</p>
          </div>
          <span id="bom-count-badge"
            class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold"
            style="background:rgba(78,7,7,0.1); color:#4E0707;">
            0 items
          </span>
        </div>

        <!-- Column headers -->
        <div class="grid grid-cols-[1fr_110px_40px] gap-3 px-5 pt-4 pb-2">
          <p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">Insumo Seco</p>
          <p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground text-center">Cant. / unidad</p>
          <span></span>
        </div>

        <!-- Rows -->
        <div id="bom-rows" class="px-5 space-y-2.5 min-h-2"></div>

        <!-- Empty state -->
        <div id="bom-empty" class="px-5 py-8 flex flex-col items-center gap-2 text-center">
          <div class="size-10 rounded-xl flex items-center justify-center bg-muted">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-5 text-muted-foreground">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="text-sm text-muted-foreground">Sin materiales todavía.</p>
          <p class="text-xs text-muted-foreground">Usá el botón de abajo para agregar insumos al BOM.</p>
        </div>

        <!-- Add row -->
        <div class="px-5 pb-5 pt-3">
          <button type="button" id="btn-add-bom"
            class="w-full inline-flex items-center justify-center gap-2 rounded-xl border border-dashed border-border py-2.5 text-sm text-muted-foreground hover:border-foreground/40 hover:text-foreground hover:bg-muted/30 transition-all">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
              <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
            </svg>
            Agregar insumo
          </button>
        </div>
      </div>

      <!-- Feedback -->
      <div id="form-feedback" class="hidden rounded-xl p-4 text-sm font-medium"></div>

      <!-- Actions -->
      <div class="flex items-center justify-between pt-1 pb-4">
        <a href="/products"
          class="inline-flex items-center gap-2 rounded-xl border border-input bg-background px-4 py-2.5 text-sm font-medium hover:bg-muted/60 transition-colors">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Cancelar
        </a>
        <button type="submit" id="btn-submit"
          class="inline-flex items-center gap-2 rounded-xl px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:opacity-90 active:scale-[0.98] disabled:opacity-50 disabled:pointer-events-none"
          style="background:#4E0707;">
          <svg id="submit-spinner" class="hidden size-4 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
          <svg id="submit-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span id="submit-label">Crear Producto</span>
        </button>
      </div>

    </form>
  </div>
</AppLayout>

<script is:inline define:vars={{ suppliesData: supplies, categoryColor }}>
  // ── Helpers ──────────────────────────────────────────────────
  function selectedSupplyIds() {
    return Array.from(document.querySelectorAll(".bom-supply"))
      .map((el) => el.value)
      .filter(Boolean);
  }

  function refreshSelectOptions() {
    const used = new Set(selectedSupplyIds());
    document.querySelectorAll(".bom-supply").forEach((sel) => {
      const current = sel.value;
      Array.from(sel.options).forEach((opt) => {
        if (!opt.value) return;
        opt.disabled = used.has(opt.value) && opt.value !== current;
      });
    });
  }

  function updateBOMCounter() {
    const count = document.querySelectorAll(".bom-row").length;
    const badge = document.getElementById("bom-count-badge");
    const empty = document.getElementById("bom-empty");
    if (badge) badge.textContent = `${count} ${count === 1 ? "item" : "items"}`;
    if (empty) empty.style.display = count === 0 ? "" : "none";
  }

  function categoryDot(category) {
    const color = categoryColor[category] ?? "#8B7355";
    return `<span class="inline-block size-2 rounded-full shrink-0" style="background:${color};"></span>`;
  }

  function buildOptions(selectedId = "") {
    const used = new Set(selectedSupplyIds());
    return `<option value="">— Seleccionar insumo —</option>` +
      suppliesData.map((s) => {
        const isUsed = used.has(s.id) && s.id !== selectedId;
        return `<option value="${s.id}" ${s.id === selectedId ? "selected" : ""} ${isUsed ? "disabled" : ""}>${s.code} — ${s.name}</option>`;
      }).join("");
  }

  function createBOMRow() {
    const row = document.createElement("div");
    row.className = "bom-row grid grid-cols-[1fr_110px_40px] gap-3 items-center";

    const selectWrap = document.createElement("div");
    selectWrap.className = "relative";

    const sel = document.createElement("select");
    sel.className = "bom-supply w-full rounded-lg border border-input bg-background pl-3 pr-8 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring appearance-none cursor-pointer";
    sel.innerHTML = buildOptions();

    // chevron icon
    const chev = document.createElement("div");
    chev.className = "pointer-events-none absolute right-2.5 top-1/2 -translate-y-1/2 text-muted-foreground";
    chev.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

    selectWrap.appendChild(sel);
    selectWrap.appendChild(chev);

    const qtyInput = document.createElement("input");
    qtyInput.type = "number";
    qtyInput.min = "1";
    qtyInput.value = "1";
    qtyInput.className = "bom-qty rounded-lg border border-input bg-background px-2 py-2.5 text-sm text-center focus:outline-none focus:ring-2 focus:ring-ring w-full";

    const removeBtn = document.createElement("button");
    removeBtn.type = "button";
    removeBtn.title = "Eliminar";
    removeBtn.className = "size-9 rounded-lg border border-input bg-background text-muted-foreground hover:bg-destructive/10 hover:text-destructive hover:border-destructive/30 transition-colors flex items-center justify-center shrink-0";
    removeBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg>`;

    sel.addEventListener("change", refreshSelectOptions);
    removeBtn.addEventListener("click", () => {
      row.remove();
      updateBOMCounter();
      refreshSelectOptions();
    });

    row.appendChild(selectWrap);
    row.appendChild(qtyInput);
    row.appendChild(removeBtn);
    return row;
  }

  const bomContainer = document.getElementById("bom-rows");

  document.getElementById("btn-add-bom").addEventListener("click", () => {
    const row = createBOMRow();
    bomContainer.appendChild(row);
    updateBOMCounter();
    refreshSelectOptions();
    row.querySelector("select")?.focus();
  });

  updateBOMCounter();

  // ── Form submit ──────────────────────────────────────────────
  const form        = document.getElementById("product-form");
  const feedback    = document.getElementById("form-feedback");
  const btnSubmit   = document.getElementById("btn-submit");
  const spinner     = document.getElementById("submit-spinner");
  const submitIcon  = document.getElementById("submit-icon");
  const submitLabel = document.getElementById("submit-label");
  const nameInput   = document.getElementById("product-name");
  const nameError   = document.getElementById("name-error");
  const skuInput    = document.getElementById("product-sku");
  const skuError    = document.getElementById("sku-error");

  function showFeedback(msg, type = "error") {
    const isError = type === "error";
    feedback.className = `rounded-xl p-4 text-sm font-medium border flex items-start gap-3 ${
      isError
        ? "border-destructive/30 bg-destructive/5 text-destructive"
        : "border-green-500/30 bg-green-500/5 text-green-700"
    }`;
    feedback.innerHTML = `
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4 shrink-0 mt-0.5">
        ${isError
          ? `<circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15" stroke-linecap="round"/><line x1="9" y1="9" x2="15" y2="15" stroke-linecap="round"/>`
          : `<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>`
        }
      </svg>
      <span>${msg}</span>
    `;
    feedback.classList.remove("hidden");
    feedback.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  function setLoading(on) {
    btnSubmit.disabled = on;
    spinner.classList.toggle("hidden", !on);
    submitIcon.classList.toggle("hidden", on);
    submitLabel.textContent = on ? "Creando…" : "Crear Producto";
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    feedback.classList.add("hidden");

    const name = nameInput.value.trim();
    if (!name) { nameError.classList.remove("hidden"); nameInput.focus(); return; }
    nameError.classList.add("hidden");

    const sku = skuInput.value.trim().toUpperCase();
    if (!sku) { skuError.classList.remove("hidden"); skuInput.focus(); return; }
    skuError.classList.add("hidden");

    const bom = [];
    const seen = new Set();
    let hasDuplicate = false;

    document.querySelectorAll(".bom-row").forEach((row) => {
      const supplyId = row.querySelector(".bom-supply")?.value?.trim();
      const qty = parseInt(row.querySelector(".bom-qty")?.value ?? "1", 10);
      if (supplyId && qty > 0) {
        if (seen.has(supplyId)) { hasDuplicate = true; return; }
        seen.add(supplyId);
        bom.push({ dry_supply_id: supplyId, quantity_per_unit: qty });
      }
    });

    if (hasDuplicate) { showFeedback("Hay insumos duplicados en el BOM. Eliminá las filas repetidas."); return; }
    if (bom.length === 0) { showFeedback("Agregá al menos un insumo al BOM antes de guardar."); return; }

    setLoading(true);
    try {
      const res = await fetch("/api/products", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, sku, bom }),
      });
      if (res.status === 201) { window.location.href = "/products"; return; }
      const body = await res.json().catch(() => ({}));
      showFeedback(body.error ?? `Error ${res.status} al crear el producto`);
    } catch {
      showFeedback("Error de red. Verificá que el servidor esté disponible.");
    } finally {
      setLoading(false);
    }
  });

  nameInput.addEventListener("input", () => { if (nameInput.value.trim()) nameError.classList.add("hidden"); });
  skuInput.addEventListener("input", () => { if (skuInput.value.trim()) skuError.classList.add("hidden"); });
</script>
