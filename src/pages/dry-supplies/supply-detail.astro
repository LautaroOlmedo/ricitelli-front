---
import AppLayout from "@/layouts/AppLayout.astro";
import { getDrySupplyByID, getStockTricapa } from "@/lib/grpc/drySupplyClient";
import { COOKIE_NAME } from "@/lib/auth";

const token = Astro.cookies.get(COOKIE_NAME)?.value;
const id = Astro.url.searchParams.get("id") ?? "";

let supply: any = null;
let tricapa: any = null;
let loadError = "";

if (!id) return Astro.redirect("/dry-supplies");

try {
  [supply, tricapa] = await Promise.all([
    getDrySupplyByID(id, token),
    getStockTricapa(id, token).catch(() => null),
  ]);
} catch (e: any) {
  loadError = e.details ?? e.message ?? "Error al cargar";
}

const categoryLabel: Record<string, string> = {
  LABEL: "Etiqueta", CONTRAETIQUETA: "Contraetiqueta", BOX: "Caja de cartón",
  CORK: "Corcho", CAPSULE: "Cápsula", BOTTLE: "Botella", OTHER: "Otro",
};
---

<AppLayout title={supply?.name ?? "Insumo"}>
  <div class="px-8 py-8 max-w-3xl mx-auto">

    {loadError && (
      <div class="rounded-xl border border-destructive/30 bg-destructive/5 p-8 text-center">
        <p class="text-sm text-destructive">{loadError}</p>
        <a href="/dry-supplies" class="mt-4 inline-flex text-sm text-primary hover:underline">← Volver a insumos</a>
      </div>
    )}

    {supply && (
      <>
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6">
          <a href="/dry-supplies" class="hover:text-foreground transition-colors">Insumos</a>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
            <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-foreground font-medium">{supply.name}</span>
        </nav>

        <!-- Header -->
        <div class="flex items-start justify-between mb-8">
          <div>
            <div class="flex items-center gap-3 mb-1">
              <h1 class="text-2xl font-semibold tracking-tight">{supply.name}</h1>
            </div>
            <div class="flex items-center gap-3 text-sm text-muted-foreground">
              <code class="font-mono text-xs bg-muted px-2 py-0.5 rounded">{supply.code}</code>
              <span>{categoryLabel[supply.category] ?? supply.category}</span>
              <span>·</span>
              <span>{supply.unit}</span>
              {supply.reorder_point > 0 && (
                <span class="inline-flex items-center rounded-md px-2 py-0.5 bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300 text-xs font-medium">
                  Reorden: {supply.reorder_point}
                </span>
              )}
            </div>
          </div>

          <a
            href={`/dry-supplies/edit?id=${supply.id}`}
            class="inline-flex items-center gap-1.5 rounded-lg border border-input bg-background px-3.5 py-2 text-sm font-medium hover:bg-accent transition-colors"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
              <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Editar
          </a>
        </div>

        <!-- Stock Tricapa -->
        {tricapa && (
          <div class="grid grid-cols-3 gap-4 mb-8">
            {[
              { label: "Stock Físico",      value: tricapa.physical_stock, color: "" },
              { label: "Comprometido",      value: tricapa.committed_stock, color: "text-amber-600" },
              { label: "Disponible",        value: tricapa.available_stock,
                color: supply.reorder_point > 0 && tricapa.available_stock < supply.reorder_point
                  ? "text-destructive" : "text-green-600" },
            ].map(({ label, value, color }) => (
              <div class="rounded-xl border border-border bg-card p-5">
                <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">{label}</p>
                <p class:list={["mt-2 text-3xl font-bold tracking-tight", color || ""]}>
                  {value.toLocaleString("es-AR")}
                </p>
                <p class="text-xs text-muted-foreground mt-1">{supply.unit}</p>
              </div>
            ))}
          </div>
        )}
      </>
    )}
  </div>
</AppLayout>
