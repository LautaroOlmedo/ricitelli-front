---
import AppLayout from "@/layouts/AppLayout.astro";
import { getDrySupplies, getStockTricapa } from "@/lib/grpc/drySupplyClient";
import { COOKIE_NAME } from "@/lib/auth";
import type { DrySupply, StockTricapa } from "@/lib/grpc/types";

const token = Astro.cookies.get(COOKIE_NAME)?.value;
let supplies: DrySupply[] = [];
let triCapaMap: Record<string, StockTricapa> = {};
let loadError: string | null = null;

try {
  supplies = await getDrySupplies(token);
  const triCapaResults = await Promise.allSettled(
    supplies.map((s) => getStockTricapa(s.id, token))
  );
  triCapaResults.forEach((r, i) => {
    if (r.status === "fulfilled" && r.value) triCapaMap[supplies[i].id] = r.value;
  });
} catch (e: any) {
  loadError = e.details ?? e.message ?? "Error al conectar con el servidor";
}

const categoryMeta: Record<string, { label: string; color: string; bg: string; icon: string }> = {
  LABEL:          { label: "Etiqueta",       color: "#3B82F6", bg: "rgba(59,130,246,0.1)",  icon: "M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" },
  CONTRAETIQUETA: { label: "Contraetiqueta", color: "#A855F7", bg: "rgba(168,85,247,0.1)",  icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
  BOX:            { label: "Caja",            color: "#B8860B", bg: "rgba(184,134,11,0.1)",  icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" },
  CORK:           { label: "Corcho",          color: "#556B2F", bg: "rgba(85,107,47,0.1)",   icon: "M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" },
  CAPSULE:        { label: "Cápsula",         color: "#EF4444", bg: "rgba(239,68,68,0.1)",   icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
  BOTTLE:         { label: "Botella",         color: "#4E0707", bg: "rgba(78,7,7,0.1)",      icon: "M9 3v11.5a3.5 3.5 0 007 0V3M9 3h7M9 3H7M16 3h2" },
  OTHER:          { label: "Otro",            color: "#8B7355", bg: "rgba(139,115,85,0.1)",  icon: "M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" },
};

const allCategories = ["ALL", ...Object.keys(categoryMeta)];

const totalPhysical   = Object.values(triCapaMap).reduce((s, t) => s + t.physical_stock,   0);
const totalCommitted  = Object.values(triCapaMap).reduce((s, t) => s + t.committed_stock,  0);
const lowStockCount   = supplies.filter((s) => {
  const t = triCapaMap[s.id];
  if (!t) return false;
  if (s.reorder_point > 0) return t.available_stock < s.reorder_point;
  return t.available_stock < 500;
}).length;
---

<AppLayout title="Insumos Secos">
  <div class="px-8 py-8 max-w-7xl mx-auto">

    <!-- ── Header ───────────────────────────────────────── -->
    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold tracking-tight font-display">Insumos Secos</h1>
        <p class="text-sm text-muted-foreground mt-1">Catálogo · inventario tricapa por insumo</p>
      </div>
      <button id="btn-new-supply"
        class="inline-flex items-center gap-1.5 rounded-md bg-primary text-primary-foreground px-3.5 py-2 text-sm font-medium hover:bg-primary/90 transition-colors shrink-0">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
          <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
        </svg>
        Nuevo Insumo
      </button>
    </div>

    <!-- ── Prediction banner ─────────────────────────────── -->
    {lowStockCount > 0 && (
      <a href="/inventory/predictions"
        class="flex items-center gap-3 rounded-xl border px-5 py-3.5 mb-6 group hover:shadow-md transition-all"
        style="border-color:#b5333330;background:#b5333308;">
        <span class="size-8 rounded-lg flex items-center justify-center shrink-0 text-sm" style="background:#b5333320;">⚠️</span>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold" style="color:#b53333;">
            {lowStockCount} insumo{lowStockCount !== 1 ? "s" : ""} con stock bajo
          </p>
          <p class="text-xs text-muted-foreground mt-0.5">
            Ver predicción de faltantes cruzada con pedidos activos →
          </p>
        </div>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4 text-muted-foreground group-hover:text-foreground shrink-0 transition-colors">
          <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    )}

    <!-- ── Stats ────────────────────────────────────────── -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      {([
        { label: "Insumos",      value: String(supplies.length),                sub: "en catálogo",       color: "#4E0707" },
        { label: "Stock físico", value: totalPhysical.toLocaleString("es-AR"),  sub: "unidades totales",  color: "#556B2F" },
        { label: "Comprometido", value: totalCommitted.toLocaleString("es-AR"), sub: "en producción",     color: "#B8860B" },
        { label: "Stock bajo",   value: String(lowStockCount),                  sub: "bajo punto de reorden", color: lowStockCount > 0 ? "#EF4444" : "#22C55E" },
      ] as const).map(({ label, value, sub, color }) => (
        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-[11px] font-medium text-muted-foreground uppercase tracking-wider">{label}</p>
          <p class="mt-1.5 text-2xl font-bold tracking-tight font-display" style={`color:${color};`}>{value}</p>
          <p class="text-[11px] text-muted-foreground mt-0.5">{sub}</p>
        </div>
      ))}
    </div>

    {loadError && (
      <div class="rounded-xl border border-destructive/30 bg-destructive/5 p-8 text-center">
        <h3 class="font-semibold text-sm text-destructive">No se pudo conectar con el servidor gRPC</h3>
        <p class="text-sm text-muted-foreground mt-1">{loadError}</p>
      </div>
    )}

    {!loadError && supplies.length === 0 && (
      <div class="rounded-xl border border-border bg-card p-14 text-center">
        <p class="text-sm text-muted-foreground">No hay insumos registrados aún.</p>
      </div>
    )}

    {!loadError && supplies.length > 0 && (
      <>
        <!-- ── Toolbar ───────────────────────────────────── -->
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <!-- Search -->
          <div class="relative">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              class="absolute left-3 top-1/2 -translate-y-1/2 size-3.5 text-muted-foreground pointer-events-none">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/>
            </svg>
            <input id="search-input" type="text" placeholder="Buscar insumo…"
              class="pl-8 pr-3 py-1.5 rounded-md border border-input bg-card text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring w-52"/>
          </div>
          <!-- Category filters -->
          <div class="flex flex-wrap gap-1.5">
            {allCategories.map((cat) => {
              const meta = cat === "ALL" ? null : categoryMeta[cat];
              return (
                <button
                  class="cat-filter rounded-full px-3 py-1 text-[11px] font-semibold border transition-colors"
                  data-cat={cat}
                  style={cat === "ALL"
                    ? "background:#4E0707; color:#F5F0EB; border-color:#4E0707;"
                    : `background:transparent; color:${meta?.color}; border-color:${meta?.color}40;`}>
                  {cat === "ALL" ? "Todos" : meta?.label}
                </button>
              );
            })}
          </div>
          <span id="row-count" class="ml-auto text-xs text-muted-foreground shrink-0">
            {supplies.length} {supplies.length === 1 ? "insumo" : "insumos"}
          </span>
        </div>

        <!-- ── Gallery grid ──────────────────────────────── -->
        <div id="supply-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
          {supplies.map((s) => {
            const tri  = triCapaMap[s.id];
            const meta = categoryMeta[s.category] ?? categoryMeta.OTHER;
            const isLow = tri && (s.reorder_point > 0 ? tri.available_stock < s.reorder_point : tri.available_stock < 500);
            const committedPct = tri && tri.physical_stock > 0
              ? Math.min(Math.round((tri.committed_stock / tri.physical_stock) * 100), 100)
              : 0;
            return (
              <a
                href={`/dry-supplies/supply-detail?id=${s.id}`}
                class={`supply-card group rounded-xl bg-card border overflow-hidden hover:shadow-md transition-all duration-200 flex flex-col cursor-pointer ${isLow ? "border-destructive/40" : "border-border"}`}
                data-id={s.id}
                data-cat={s.category}
                data-search={`${s.code} ${s.name}`.toLowerCase()}>

                <!-- Icon hero -->
                <div class="relative flex items-center justify-center py-8"
                  style={`background: ${meta.bg};`}>
                  <div class="size-16 rounded-xl flex items-center justify-center"
                    style={`background: ${meta.color}20; border: 2px solid ${meta.color}30;`}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-8"
                      style={`color: ${meta.color};`}>
                      <path d={meta.icon} stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <!-- category badge -->
                  <span class="absolute top-2.5 left-2.5 rounded-md px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider"
                    style={`background:${meta.color}20; color:${meta.color};`}>
                    {meta.label}
                  </span>
                  <!-- low stock warning -->
                  {isLow && (
                    <span class="absolute top-2.5 right-2.5 rounded-md px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider animate-pulse"
                      style="background:rgba(239,68,68,0.15); color:#EF4444; border:1px solid rgba(239,68,68,0.3);">
                      Stock bajo
                    </span>
                  )}
                </div>

                <!-- Body -->
                <div class="px-3.5 pt-3 pb-3 flex-1 flex flex-col gap-2"
                  style={isLow ? "background: linear-gradient(180deg, rgba(239,68,68,0.12) 0%, rgba(239,68,68,0.06) 100%);" : ""}>
                  <div>
                    <p class="font-mono text-[10px] text-muted-foreground">{s.code}</p>
                    <p class="font-semibold text-[13px] leading-snug mt-0.5 line-clamp-2">{s.name}</p>
                  </div>

                  {tri ? (
                    <div class="space-y-2.5 text-[11px] mt-auto">
                      <div>
                        <div class="flex justify-between mb-1">
                          <span class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">Físico</span>
                          <span class="text-[12px] font-bold font-mono" style={`color:${meta.color};`}>
                            {tri.physical_stock.toLocaleString("es-AR")}
                          </span>
                        </div>
                        <div class="h-1.5 rounded-full overflow-hidden" style="background: rgba(0,0,0,0.08);">
                          <div class="h-full rounded-full" style={`width:100%; background:${meta.color};`}/>
                        </div>
                      </div>
                      <div>
                        <div class="flex justify-between mb-1">
                          <span class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">Comprometido</span>
                          <span class="text-[12px] font-bold font-mono" style="color:#B8860B;">
                            {tri.committed_stock.toLocaleString("es-AR")}
                          </span>
                        </div>
                        <div class="h-1.5 rounded-full overflow-hidden" style="background: rgba(0,0,0,0.08);">
                          <div class="h-full rounded-full" style={`width:${committedPct}%; background:#B8860B;`}/>
                        </div>
                      </div>
                    </div>
                  ) : (
                    <p class="text-[11px] text-muted-foreground mt-auto">Sin datos de stock</p>
                  )}
                </div>

                <!-- Footer action -->
                <div class="px-3.5 pb-3"
                  style={isLow ? "background: rgba(239,68,68,0.06);" : ""}>
                  <button
                    class="btn-add-stock w-full text-[12px] font-semibold py-1.5 rounded-md border border-border bg-background hover:bg-muted/60 transition-colors"
                    data-id={s.id}
                    data-code={s.code}
                    data-name={s.name}>
                    Agregar insumo seco
                  </button>
                </div>
              </a>
            );
          })}
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-center mt-6 gap-1" id="pagination-container"></div>

        <!-- Footer -->
        <div class="mt-6 flex justify-between items-center">
          <p id="footer-count" class="text-xs text-muted-foreground">
            {supplies.length} {supplies.length === 1 ? "insumo" : "insumos"}
          </p>
          <p class="text-xs text-muted-foreground">gRPC · localhost:50051</p>
        </div>
      </>
    )}
  </div>
</AppLayout>

<!-- ── Modal Nuevo Insumo ─────────────────────────────────── -->
<div id="modal-new-supply" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-card border border-border rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
    <h2 class="text-base font-semibold mb-1">Nuevo Insumo Seco</h2>
    <p class="text-xs text-muted-foreground mb-4">Registra un nuevo insumo en el catálogo.</p>
    <div class="space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label for="ns-code" class="text-sm font-medium">Código (SKU) <span class="text-destructive">*</span></label>
          <input id="ns-code" type="text" placeholder="ej: HEYM-CTR-JP"
            class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm font-mono placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"/>
        </div>
        <div>
          <label for="ns-unit" class="text-sm font-medium">Unidad</label>
          <select id="ns-unit" class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
            <option value="UNIT">Unidad</option>
            <option value="BOX">Caja</option>
            <option value="KG">Kg</option>
          </select>
        </div>
      </div>
      <div>
        <label for="ns-name" class="text-sm font-medium">Nombre <span class="text-destructive">*</span></label>
        <input id="ns-name" type="text" placeholder="ej: Contraetiqueta Japón Hey Malbec"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label for="ns-category" class="text-sm font-medium">Categoría</label>
          <select id="ns-category" class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
            <option value="LABEL">Etiqueta</option>
            <option value="CONTRAETIQUETA">Contraetiqueta</option>
            <option value="BOX">Caja</option>
            <option value="CORK">Corcho</option>
            <option value="CAPSULE">Cápsula</option>
            <option value="BOTTLE">Botella</option>
            <option value="OTHER">Otro</option>
          </select>
        </div>
        <div>
          <label for="ns-reorder" class="text-sm font-medium">Punto de reorden</label>
          <input id="ns-reorder" type="number" min="0" placeholder="ej: 5000"
            class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"/>
        </div>
      </div>
      <p id="ns-error" class="hidden text-xs text-destructive"></p>
    </div>
    <div class="flex justify-end gap-2 mt-6">
      <button id="ns-cancel" class="rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-muted/60 transition-colors">Cancelar</button>
      <button id="ns-confirm" class="rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors">Crear insumo</button>
    </div>
  </div>
</div>

<!-- ── Modal Agregar Stock ────────────────────────────────── -->
<div id="modal-add-stock" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-card border border-border rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
    <h2 class="text-base font-semibold mb-4">Agregar Stock</h2>
    <div class="space-y-3">
      <div>
        <label class="text-sm font-medium">Insumo</label>
        <p id="modal-supply-name" class="text-sm text-muted-foreground mt-0.5"></p>
      </div>
      <div>
        <label for="modal-quantity" class="text-sm font-medium">Cantidad <span class="text-destructive">*</span></label>
        <input id="modal-quantity" type="number" min="1" value="100"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <div>
        <label for="modal-reference" class="text-sm font-medium">Referencia</label>
        <input id="modal-reference" type="text" placeholder="ej: OC-2024-001"
          class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"/>
      </div>
      <p id="modal-error" class="hidden text-xs text-destructive"></p>
    </div>
    <div class="flex justify-end gap-2 mt-6">
      <button id="modal-cancel" class="rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-muted/60 transition-colors">Cancelar</button>
      <button id="modal-confirm" class="rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors">Agregar</button>
    </div>
  </div>
</div>

<script>
  function showModal(el: HTMLElement) { el.classList.remove("hidden"); el.classList.add("flex"); }
  function hideModal(el: HTMLElement) { el.classList.add("hidden"); el.classList.remove("flex"); }

  // ── Search + category filter + pagination ────────────────
  const searchInput = document.getElementById("search-input") as HTMLInputElement;
  const grid        = document.getElementById("supply-grid")!;
  const badge       = document.getElementById("row-count")!;
  const footer      = document.getElementById("footer-count")!;
  const paginationContainer = document.getElementById("pagination-container")!;
  let activeCat = "ALL";
  let currentPage = 1;
  const PAGE_SIZE = 20;

  function applyFilters(resetPage = true) {
    if (!grid) return;
    if (resetPage) currentPage = 1;
    const q = searchInput?.value.trim().toLowerCase() ?? "";
    const cards = Array.from(grid.querySelectorAll<HTMLElement>(".supply-card"));
    const visibleCards = cards.filter((card) => {
      const matchSearch = !q || (card.dataset.search ?? "").includes(q);
      const matchCat = activeCat === "ALL" || card.dataset.cat === activeCat;
      return matchSearch && matchCat;
    });

    const total = visibleCards.length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;

    cards.forEach((card) => { card.style.display = "none"; });
    visibleCards.slice(start, end).forEach((card) => { card.style.display = ""; });

    const label = total === 1 ? "insumo" : "insumos";
    badge.textContent = `${total} ${label}`;
    footer.textContent = `${total} ${label}`;

    renderPagination(totalPages);
  }

  function renderPagination(totalPages: number) {
    if (totalPages <= 1) { paginationContainer.innerHTML = ""; return; }
    const WINDOW = 3;
    const pages: (number | "...")[] = [];
    pages.push(1);
    if (currentPage - WINDOW > 2) pages.push("...");
    for (let i = Math.max(2, currentPage - WINDOW); i <= Math.min(totalPages - 1, currentPage + WINDOW); i++) {
      pages.push(i);
    }
    if (currentPage + WINDOW < totalPages - 1) pages.push("...");
    if (totalPages > 1) pages.push(totalPages);

    paginationContainer.innerHTML = pages.map((p) => {
      if (p === "...") return `<span class="px-2 py-1 text-sm text-muted-foreground">...</span>`;
      const isActive = p === currentPage;
      const cls = isActive
        ? "px-3 py-1.5 text-sm font-semibold bg-primary text-primary-foreground rounded-lg"
        : "px-3 py-1.5 text-sm text-stone-600 border border-border rounded-lg hover:bg-muted/60 cursor-pointer";
      return `<button class="${cls}" data-page="${p}" ${isActive ? "disabled" : ""}>${p}</button>`;
    }).join("");

    paginationContainer.querySelectorAll("button[data-page]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const page = Number((btn as HTMLElement).dataset.page);
        if (page !== currentPage) {
          currentPage = page;
          applyFilters(false);
          window.scrollTo({ top: 0, behavior: "smooth" });
        }
      });
    });
  }

  searchInput?.addEventListener("input", () => applyFilters());

  document.querySelectorAll<HTMLElement>(".cat-filter").forEach((btn) => {
    btn.addEventListener("click", () => {
      activeCat = btn.dataset.cat ?? "ALL";
      document.querySelectorAll<HTMLElement>(".cat-filter").forEach((b) => {
        const isActive = b.dataset.cat === activeCat;
        b.style.background = isActive ? "#4E0707" : "transparent";
        b.style.color = isActive ? "#F5F0EB" : (b.dataset.cat === "ALL" ? "#8B7355" : "");
        b.style.borderColor = isActive ? "#4E0707" : "";
      });
      applyFilters();
    });
  });

  // Initial pagination render
  applyFilters();

  // ── Add stock (click "Agregar insumo seco" button) ──────
  let currentSupplyId = "";
  const stockModal  = document.getElementById("modal-add-stock")!;
  const modalName   = document.getElementById("modal-supply-name")!;
  const modalQty    = document.getElementById("modal-quantity") as HTMLInputElement;
  const modalRef    = document.getElementById("modal-reference") as HTMLInputElement;
  const modalError  = document.getElementById("modal-error")!;

  grid?.querySelectorAll<HTMLElement>(".btn-add-stock")?.forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      currentSupplyId = btn.dataset.id ?? "";
      const code = btn.dataset.code ?? "";
      const name = btn.dataset.name ?? "";
      modalName.textContent = `${code} — ${name}`;
      modalError.classList.add("hidden");
      modalQty.value = "100"; modalRef.value = "";
      showModal(stockModal);
    });
  });

  document.getElementById("modal-cancel")!.addEventListener("click", () => hideModal(stockModal));
  stockModal.addEventListener("click", (e) => { if (e.target === stockModal) hideModal(stockModal); });

  document.getElementById("modal-confirm")!.addEventListener("click", async () => {
    if (!currentSupplyId) return;
    const qty = parseInt(modalQty.value, 10);
    if (!qty || qty < 1) { modalError.textContent = "Cantidad debe ser > 0."; modalError.classList.remove("hidden"); return; }
    try {
      const res = await fetch(`/api/dry-supplies/${currentSupplyId}`, {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ quantity: qty, reference: modalRef.value.trim() || "manual" }),
      });
      if (res.ok) { hideModal(stockModal); window.location.reload(); }
      else {
        const body = await res.json().catch(() => ({}));
        modalError.textContent = body.error ?? `Error ${res.status}`; modalError.classList.remove("hidden");
      }
    } catch { modalError.textContent = "Error de red."; modalError.classList.remove("hidden"); }
  });

  // ── New supply modal ─────────────────────────────────────
  const nsModal   = document.getElementById("modal-new-supply")!;
  const nsCode    = document.getElementById("ns-code") as HTMLInputElement;
  const nsName    = document.getElementById("ns-name") as HTMLInputElement;
  const nsCategory = document.getElementById("ns-category") as HTMLSelectElement;
  const nsUnit    = document.getElementById("ns-unit") as HTMLSelectElement;
  const nsReorder = document.getElementById("ns-reorder") as HTMLInputElement;
  const nsError   = document.getElementById("ns-error")!;

  document.getElementById("btn-new-supply")!.addEventListener("click", () => {
    nsCode.value = ""; nsName.value = ""; nsReorder.value = ""; nsError.classList.add("hidden"); showModal(nsModal);
  });
  document.getElementById("ns-cancel")!.addEventListener("click", () => hideModal(nsModal));
  nsModal.addEventListener("click", (e) => { if (e.target === nsModal) hideModal(nsModal); });

  document.getElementById("ns-confirm")!.addEventListener("click", async () => {
    nsError.classList.add("hidden");
    const code = nsCode.value.trim(); const name = nsName.value.trim();
    if (!code || !name) { nsError.textContent = "Código y nombre son obligatorios."; nsError.classList.remove("hidden"); return; }
    try {
      const res = await fetch("/api/dry-supplies", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ code, name, category: nsCategory.value, unit: nsUnit.value, reorder_point: parseInt(nsReorder.value || "0", 10) }),
      });
      if (res.ok) { hideModal(nsModal); window.location.reload(); }
      else {
        const body = await res.json().catch(() => ({}));
        nsError.textContent = body.error ?? `Error ${res.status}`; nsError.classList.remove("hidden");
      }
    } catch { nsError.textContent = "Error de red."; nsError.classList.remove("hidden"); }
  });
</script>
