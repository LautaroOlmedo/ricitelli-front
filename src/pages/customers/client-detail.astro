---
import AppLayout from "@/layouts/AppLayout.astro";
import { getCustomerByID, getOrdersByCustomer } from "@/lib/grpc/customerClient";
import { COOKIE_NAME } from "@/lib/auth";

const token = Astro.cookies.get(COOKIE_NAME)?.value;
const id = Astro.url.searchParams.get("id") ?? "";

let customer: any = null;
let orders: any[] = [];
let loadError = "";

if (!id) return Astro.redirect("/customers");

try {
  [customer, orders] = await Promise.all([
    getCustomerByID(id, token),
    getOrdersByCustomer(id, token).catch(() => []),
  ]);
} catch (e: any) {
  loadError = e.details ?? e.message ?? "Error al cargar";
}

const groupLabel: Record<string, string> = {
  DISTRIBUTOR:  "Distribuidor",
  WINE_SHOP:    "Vinoteca",
  RESTAURANT:   "Restaurante",
  HOTEL:        "Hotel",
  RETAIL:       "Retail",
  PRIVATE:      "Privado",
  EXPORT_AGENT: "Agente Exportación",
};

const marketLabel: Record<string, string> = {
  INTERNAL: "Mercado Interno",
  EXTERNAL: "Exportación",
};

const statusColor: Record<string, string> = {
  NEW:               "bg-gray-100 text-gray-700",
  CONFIRMED:         "bg-yellow-100 text-yellow-800",
  INVOICED:          "bg-orange-100 text-orange-800",
  READY_TO_DISPATCH: "bg-blue-100 text-blue-800",
  DISPATCHED:        "bg-green-100 text-green-800",
  CANCELLED:         "bg-red-100 text-red-800",
};
---

<AppLayout title={customer?.social_reason ?? "Cliente"}>
  <div class="px-8 py-8 max-w-4xl mx-auto">

    {loadError && (
      <div class="rounded-xl border border-destructive/30 bg-destructive/5 p-8 text-center">
        <p class="text-sm text-destructive">{loadError}</p>
        <a href="/customers" class="mt-4 inline-flex text-sm text-primary hover:underline">← Volver a clientes</a>
      </div>
    )}

    {customer && (
      <>
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6">
          <a href="/customers" class="hover:text-foreground transition-colors">Clientes</a>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
            <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-foreground font-medium">{customer.social_reason}</span>
        </nav>

        <!-- Header -->
        <div class="flex items-start justify-between mb-8">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-2xl font-semibold tracking-tight">{customer.social_reason}</h1>
              <span class:list={[
                "inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium",
                customer.active ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800"
              ]}>
                {customer.active ? "Activo" : "Inactivo"}
              </span>
            </div>
            <div class="flex items-center gap-3 text-sm text-muted-foreground">
              <span class="inline-flex items-center rounded-md px-2 py-0.5 bg-secondary text-secondary-foreground text-xs font-medium">
                {marketLabel[customer.market_type] ?? customer.market_type}
              </span>
              <span class="inline-flex items-center rounded-md px-2 py-0.5 bg-muted text-muted-foreground text-xs font-medium">
                {groupLabel[customer.group] ?? customer.group}
              </span>
              {customer.created_at && (
                <span>Registrado: {customer.created_at.slice(0, 10)}</span>
              )}
            </div>
          </div>

          <div class="flex items-center gap-2">
            <a
              href={`/customers/edit?id=${customer.id}`}
              class="inline-flex items-center gap-1.5 rounded-lg border border-input bg-background px-3.5 py-2 text-sm font-medium hover:bg-accent transition-colors"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Editar
            </a>
            {customer.active && (
              <button
                id="btn-deactivate"
                data-id={customer.id}
                class="inline-flex items-center gap-1.5 rounded-lg border border-destructive/30 bg-background text-destructive px-3.5 py-2 text-sm font-medium hover:bg-destructive/5 transition-colors"
              >
                Desactivar
              </button>
            )}
          </div>
        </div>

        <!-- Orders -->
        <div class="rounded-xl border border-border bg-card overflow-hidden">
          <div class="px-5 py-4 border-b border-border flex items-center justify-between">
            <h2 class="text-sm font-semibold">Órdenes de Venta</h2>
            <span class="text-xs text-muted-foreground">{orders.length} {orders.length === 1 ? "orden" : "órdenes"}</span>
          </div>

          {orders.length === 0 ? (
            <div class="px-5 py-10 text-center">
              <p class="text-sm text-muted-foreground">No hay órdenes registradas para este cliente.</p>
            </div>
          ) : (
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-muted/30 border-b border-border">
                  <tr>
                    <th class="px-5 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">ID</th>
                    <th class="px-5 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Estado</th>
                    <th class="px-5 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Moneda</th>
                    <th class="px-5 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Tipo</th>
                    <th class="px-5 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">País</th>
                    <th class="px-5 py-3 text-right text-xs font-medium text-muted-foreground uppercase tracking-wider">Items</th>
                    <th class="px-5 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Fecha</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-border">
                  {orders.map((o) => (
                    <tr
                      class="hover:bg-muted/30 transition-colors cursor-pointer"
                      onclick={`window.location='/sale-orders/${o.id}'`}
                    >
                      <td class="px-5 py-3 font-mono text-xs text-muted-foreground">{o.id.slice(0, 8)}…</td>
                      <td class="px-5 py-3">
                        <span class:list={[
                          "inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium",
                          statusColor[o.status] ?? "bg-secondary text-secondary-foreground"
                        ]}>
                          {o.status}
                        </span>
                      </td>
                      <td class="px-5 py-3">{o.currency}</td>
                      <td class="px-5 py-3 text-muted-foreground">{o.sale_type}</td>
                      <td class="px-5 py-3 text-muted-foreground">{o.destination_country || "—"}</td>
                      <td class="px-5 py-3 text-right">{o.items?.length ?? 0}</td>
                      <td class="px-5 py-3 text-xs text-muted-foreground">{o.created_at?.slice(0, 10) || "—"}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </>
    )}
  </div>
</AppLayout>

<script>
  const btn = document.getElementById("btn-deactivate") as HTMLButtonElement | null;
  if (btn) {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.id;
      if (!confirm("¿Desactivar este cliente? No se podrán crear nuevas órdenes.")) return;
      try {
        const res = await fetch(`/api/customers/${id}`, { method: "DELETE" });
        if (res.ok) window.location.reload();
        else {
          const d = await res.json().catch(() => ({}));
          alert(d.error ?? "Error al desactivar");
        }
      } catch { alert("Error de red"); }
    });
  }
</script>
