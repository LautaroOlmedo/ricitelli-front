---
import AppLayout from "@/layouts/AppLayout.astro";
---

<AppLayout title="Nuevo Cliente">
  <div class="px-8 py-8 max-w-2xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-8">
      <a href="/customers" class="hover:text-foreground transition-colors">Clientes</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3.5">
        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-foreground font-medium">Nuevo cliente</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-2xl font-semibold tracking-tight">Nuevo Cliente</h1>
      <p class="text-sm text-muted-foreground mt-1">
        Registrá un nuevo cliente con su razón social, tipo de mercado y grupo comercial.
      </p>
    </div>

    <!-- Form -->
    <form id="customer-form" novalidate class="space-y-8">

      <div class="rounded-xl border border-border bg-card p-6 space-y-5">
        <div>
          <h2 class="text-sm font-semibold">Información del cliente</h2>
          <p class="text-xs text-muted-foreground mt-0.5">Datos de identificación comercial</p>
        </div>

        <!-- Razón Social -->
        <div class="space-y-1.5">
          <label for="social-reason" class="text-sm font-medium">
            Razón Social
            <span class="text-destructive ml-0.5">*</span>
          </label>
          <input
            id="social-reason"
            type="text"
            placeholder="Ej: Vinoteca El Barril S.A."
            autocomplete="off"
            class="w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring transition-shadow"
          />
          <p id="social-reason-error" class="hidden text-xs text-destructive mt-1">La razón social es obligatoria.</p>
        </div>

        <!-- Tipo de Mercado -->
        <div class="space-y-1.5">
          <label for="market-type" class="text-sm font-medium">
            Tipo de Mercado
            <span class="text-destructive ml-0.5">*</span>
          </label>
          <select
            id="market-type"
            class="w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring transition-shadow"
          >
            <option value="">Seleccionar…</option>
            <option value="INTERNAL">Interno</option>
            <option value="EXTERNAL">Externo</option>
          </select>
          <p id="market-type-error" class="hidden text-xs text-destructive mt-1">El tipo de mercado es obligatorio.</p>
        </div>

        <!-- Grupo -->
        <div class="space-y-1.5">
          <label for="group" class="text-sm font-medium">
            Grupo Comercial
            <span class="text-destructive ml-0.5">*</span>
          </label>
          <select
            id="group"
            class="w-full rounded-lg border border-input bg-background px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ring transition-shadow"
          >
            <option value="">Seleccionar…</option>
            <option value="DISTRIBUTOR">Distribuidor</option>
            <option value="WINE_SHOP">Vinoteca</option>
            <option value="RESTAURANT">Restaurante</option>
            <option value="HOTEL">Hotel</option>
            <option value="RETAIL">Retail</option>
            <option value="PRIVATE">Privado</option>
            <option value="EXPORT_AGENT">Agente de Exportación</option>
          </select>
          <p id="group-error" class="hidden text-xs text-destructive mt-1">El grupo comercial es obligatorio.</p>
        </div>
      </div>

      <!-- Feedback -->
      <div id="form-feedback" class="hidden rounded-lg p-4 text-sm font-medium"></div>

      <!-- Actions -->
      <div class="flex items-center justify-between pt-1">
        <a
          href="/customers"
          class="inline-flex items-center gap-1.5 rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Cancelar
        </a>

        <button
          type="submit"
          id="btn-submit"
          class="inline-flex items-center gap-2 rounded-lg bg-primary text-primary-foreground px-5 py-2 text-sm font-medium hover:bg-primary/90 transition-colors disabled:opacity-50 disabled:pointer-events-none"
        >
          <svg id="submit-spinner" class="hidden size-4 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
          <span id="submit-label">Crear Cliente</span>
        </button>
      </div>

    </form>
  </div>
</AppLayout>

<script>
  const form         = document.getElementById("customer-form")!;
  const feedback     = document.getElementById("form-feedback")!;
  const btnSubmit    = document.getElementById("btn-submit") as HTMLButtonElement;
  const spinner      = document.getElementById("submit-spinner")!;
  const submitLabel  = document.getElementById("submit-label")!;

  const socialReasonInput = document.getElementById("social-reason") as HTMLInputElement;
  const marketTypeSelect  = document.getElementById("market-type") as HTMLSelectElement;
  const groupSelect       = document.getElementById("group") as HTMLSelectElement;

  const socialReasonError = document.getElementById("social-reason-error")!;
  const marketTypeError   = document.getElementById("market-type-error")!;
  const groupError        = document.getElementById("group-error")!;

  function showError(msg: string) {
    feedback.className =
      "rounded-lg p-4 text-sm font-medium border border-destructive/30 bg-destructive/5 text-destructive flex items-center gap-2";
    feedback.innerHTML = `
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4 shrink-0">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15" stroke-linecap="round"/>
        <line x1="9" y1="9" x2="15" y2="15" stroke-linecap="round"/>
      </svg>
      <span>${msg}</span>
    `;
    feedback.classList.remove("hidden");
    feedback.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  function setLoading(on: boolean) {
    btnSubmit.disabled = on;
    spinner.classList.toggle("hidden", !on);
    submitLabel.textContent = on ? "Creando…" : "Crear Cliente";
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    feedback.classList.add("hidden");

    let valid = true;
    const social_reason = socialReasonInput.value.trim();
    const market_type   = marketTypeSelect.value;
    const group         = groupSelect.value;

    if (!social_reason) {
      socialReasonError.classList.remove("hidden");
      valid = false;
    } else {
      socialReasonError.classList.add("hidden");
    }
    if (!market_type) {
      marketTypeError.classList.remove("hidden");
      valid = false;
    } else {
      marketTypeError.classList.add("hidden");
    }
    if (!group) {
      groupError.classList.remove("hidden");
      valid = false;
    } else {
      groupError.classList.add("hidden");
    }

    if (!valid) return;

    setLoading(true);
    try {
      const res = await fetch("/api/customers", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ social_reason, market_type, group }),
      });

      if (res.status === 201) {
        window.location.href = "/customers";
        return;
      }

      const body = await res.json().catch(() => ({}));
      showError(body.error ?? `Error ${res.status} al crear el cliente`);
    } catch {
      showError("Error de red. Verificá que el servidor esté disponible.");
    } finally {
      setLoading(false);
    }
  });

  socialReasonInput.addEventListener("input", () => {
    if (socialReasonInput.value.trim()) socialReasonError.classList.add("hidden");
  });
</script>
