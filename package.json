    "astro": "^5.16.15",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.1.18",
    "tailwindcss": "^4.1.18",
    "ts-proto": "^2.11.4"
  }
}
